<!doctype html>
<html lang="{{ request.locale.iso_code }}" data-theme="dark">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="#111111">

  <link rel="canonical" href="{{ canonical_url }}">

  {% if settings.favicon != blank %}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url }}">
  {% endif %}

  <title>
    {% if page_title %}{{ page_title }}{% endif %}
    {% unless page_title contains shop.name %} | {{ shop.name }}{% endunless %}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {{ content_for_header }}

  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

  {{ 'lb-base.css' | asset_url | stylesheet_tag }}
  {{ 'lb-components.css' | asset_url | stylesheet_tag }}
  {{ 'lb-blueprints.css' | asset_url | stylesheet_tag }}
  {{ 'lb-animations.css' | asset_url | stylesheet_tag }}

<style>
  :root,
  [data-theme="dark"] {
    --lb-bg:       #0A0A0A;
    --lb-bg-2:     #111111;
    --lb-bg-3:     #1A1A1A;
    --lb-text:     #FFFFFF;
    --lb-muted:    #AAAAAA;
    --lb-border:   #2A2A2A;
    --lb-accent:   #7DD8E8;
    --lb-header-bg:   #0A0A0A;
    --lb-header-text: #FFFFFF;

    /* Blueprint variable bridge — dark */
    --void:     #0A0A0A;
    --ink:      #1A1A1A;
    --wall:     #2A2A2A;
    --concrete: #3D3D3D;
    --white:    #FFFFFF;
    --muted:    #AAAAAA;
    --blue:     #7DD8E8;
    --red:      #E8442A;
    --gold:     #F5A623;

  }

  [data-theme="light"] {
    --lb-bg:       #FFFFFF;
    --lb-bg-2:     #F0F0F0;
    --lb-bg-3:     #E5E5E5;
    --lb-text:     #0A0A0A;
    --lb-muted:    #555555;
    --lb-border:   #DDDDDD;
    --lb-accent:   #7DD8E8;
    --lb-header-bg:   #FFFFFF;
    --lb-header-text: #0A0A0A;

    /* Blueprint variable bridge — light */
    --void:     #FFFFFF;
    --ink:      #F0F0F0;
    --wall:     #E0E0E0;
    --concrete: #999999;
    --white:    #0A0A0A;
    --muted:    #555555;
    --blue:     #7DD8E8;
    --red:      #E8442A;
    --gold:     #F5A623;

  }

  html { transition: background-color 0.3s ease; }
  body {
    background: var(--lb-bg);
    color: var(--lb-text);
    transition: background-color 0.3s ease, color 0.3s ease;
  }
  *:not(.lb-hero__bg-img), *::before, *::after {
    transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
  }
</style>

  {%- comment -%} Apply saved theme before paint — prevents flash {%- endcomment -%}
  <script>
    (function() {
      var saved = localStorage.getItem('lb-theme') || 'dark';
      document.documentElement.setAttribute('data-theme', saved);
    })();
  </script>

</head>

<body
  class="
    template-{{ template.name }}
    page-{{ request.page_type }}
    {% if customer %}customer-logged-in{% endif %}
  "
>

  <a class="skip-to-content-link visually-hidden focus-inset" href="#MainContent">
    Skip to content
  </a>

  {% section 'lb-header' %}

  <main id="MainContent" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% section 'lb-footer' %}

  <script src="{{ 'lb-main.js' | asset_url }}" defer></script>

  <script>
  (function() {
    var btn = document.getElementById('lb-theme-toggle');
    if (!btn) return;
    function getTheme() { return localStorage.getItem('lb-theme') || 'dark'; }
    function setTheme(theme) {
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('lb-theme', theme);
    }
    btn.addEventListener('click', function() {
      setTheme(getTheme() === 'dark' ? 'light' : 'dark');
    });
  })();
  </script>

</body>
</html>
