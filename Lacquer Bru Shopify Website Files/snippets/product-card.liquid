{% liquid
  assign card_product = product
  if card_product == blank
    assign card_product = card
  endif
%}

<article class="lb-product-card">

  <a href="{{ card_product.url }}" class="lb-product-card__link">

    {% if card_product.featured_image %}
      {{
        card_product.featured_image
        | image_url: width: 900
        | image_tag:
          loading: 'lazy',
          widths: '400,600,900',
          sizes: '(min-width: 990px) 25vw, 50vw',
          alt: card_product.title
      }}
    {% endif %}

    {% if card_product.compare_at_price > card_product.price %}
      <span class="lb-product-card__badge lb-product-card__badge--sale">
        Sale
      </span>

    {% elsif card_product.available == false %}

      <span class="lb-product-card__badge lb-product-card__badge--soldout">
        Sold Out
      </span>

    {% endif %}

    <div class="lb-product-card__content">

      <h3 class="lb-product-card__title">
        {{ card_product.title }}
      </h3>

      {% if settings.show_vendor %}
        <div class="lb-product-card__vendor">
          {{ card_product.vendor }}
        </div>
      {% endif %}

      <div class="lb-product-card__price">

        {% if card_product.compare_at_price > card_product.price %}

          <span class="lb-product-card__price-sale">
            {{ card_product.price | money }}
          </span>

          <s>
            {{ card_product.compare_at_price | money }}
          </s>

        {% else %}

          {{ card_product.price | money }}

        {% endif %}

      </div>

    </div>

  </a>

</article>