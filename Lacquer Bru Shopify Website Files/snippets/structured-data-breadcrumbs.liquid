{% liquid
  assign crumb_collection = collection
  if template.name == 'product' and crumb_collection == blank and product.collections.first != blank
    assign crumb_collection = product.collections.first
  endif
%}

{% if template.name == 'product' or template.name == 'collection' %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": {{ shop.url | append: routes.root_url | json }}
        }
        {% if template.name == 'product' and crumb_collection != blank %}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ crumb_collection.title | json }},
            "item": {{ shop.url | append: crumb_collection.url | json }}
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": {{ product.title | json }},
            "item": {{ canonical_url | json }}
          }
        {% elsif template.name == 'product' %}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": "Shop",
            "item": {{ shop.url | append: routes.all_products_collection_url | json }}
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": {{ product.title | json }},
            "item": {{ canonical_url | json }}
          }
        {% elsif template.name == 'collection' %}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ collection.title | json }},
            "item": {{ canonical_url | json }}
          }
        {% endif %}
      ]
    }
  </script>
{% endif %}
