    <img src="{{ 'lb-blueprint-gallery-014.jpg' | asset_url }}" alt="Large scale mural" loading="lazy">
    <div class="gal-item-ov">
      <div class="gal-item-title">Large Scale Production</div>
      <div class="gal-item-cat">Mural &middot; Commercial</div>
    </div>
  </div>
  <div class="gal-item wide">
    <img src="{{ 'lb-blueprint-gallery-015.jpg' | asset_url }}" alt="Conceptual mural" loading="lazy">
    <div class="gal-item-ov">
      <div class="gal-item-title">Conceptual Piece</div>
      <div class="gal-item-cat">Conceptual &middot; Mural</div>
    </div>
  </div>
  <div class="gal-item wide">
    <img src="{{ 'lb-blueprint-gallery-016.jpg' | asset_url }}" alt="Indoor mural" loading="lazy">
