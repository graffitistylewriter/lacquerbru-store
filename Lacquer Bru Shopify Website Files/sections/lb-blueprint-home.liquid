<section class="lb-blueprint-page lb-blueprint-page--home">


<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-ol"></div>
  <div class="hero-c">
    <span class="eyebrow">If Not Unique, Why Bother</span>
    <h1 class="hero-h1">Street Artist.<em>Digital Creator.</em></h1>
    <p class="hero-sub">Graffiti murals, digital art, and creative assets born from 16 years of aerosol culture in Cape Town. Brush packs, limited prints, and commissioned work worldwide.</p>
    <div class="hero-btns">
      <a href="https://lacquerbru.co.za/shop" class="btn-primary">Shop the Collection</a>
      <a href="https://lacquerbru.co.za/commission-inquiry" class="btn-ghost">Commission Inquiry</a>
    </div>
  </div>
  <div class="scroll-ind"><div class="scroll-line"></div><span>Scroll</span></div>
</section>

<div class="marquee-wrap"><div class="marquee-track"><span class="mi">Graffiti Murals</span><span class="ms"> &middot; </span><span class="mi">Digital Art</span><span class="ms"> &middot; </span><span class="mi">Brush Packs</span><span class="ms"> &middot; </span><span class="mi">Textured Finishes</span><span class="ms"> &middot; </span><span class="mi">Commission Work</span><span class="ms"> &middot; </span><span class="mi">Cape Town</span><span class="ms"> &middot; </span><span class="mi">Aerosoul</span><span class="ms"> &middot; </span><span class="mi">16 Years Experience</span><span class="ms"> &middot; </span><span class="mi">Mural Painting</span><span class="ms"> &middot; </span><span class="mi">Illustration</span><span class="ms"> &middot; </span><span class="mi">Graffiti Murals</span><span class="ms"> &middot; </span><span class="mi">Digital Art</span><span class="ms"> &middot; </span><span class="mi">Brush Packs</span><span class="ms"> &middot; </span><span class="mi">Textured Finishes</span><span class="ms"> &middot; </span><span class="mi">Commission Work</span><span class="ms"> &middot; </span><span class="mi">Cape Town</span><span class="ms"> &middot; </span><span class="mi">Aerosoul</span><span class="ms"> &middot; </span><span class="mi">16 Years Experience</span><span class="ms"> &middot; </span><span class="mi">Mural Painting</span><span class="ms"> &middot; </span><span class="mi">Illustration</span><span class="ms"> &middot; </span></div></div>

<div class="gg">
  <a href="https://lacquerbru.co.za/gallery" class="gi tall">
    <img src="{{ 'lb-blueprint-home-003.jpg' | asset_url }}" alt="Lacquer Bru mural artwork" loading="lazy">
    <div class="gi-ov"><span class="gi-lbl">View Gallery &rarr;</span></div>
  </a>
  <a href="https://lacquerbru.co.za/gallery" class="gi">
    <img src="{{ 'lb-blueprint-home-004.jpg' | asset_url }}" alt="Graffiti wildstyle" loading="lazy">
    <div class="gi-ov"><span class="gi-lbl">Wildstyle</span></div>
  </a>
  <a href="https://lacquerbru.co.za/gallery" class="gi">
    <img src="{{ 'lb-blueprint-home-005.jpg' | asset_url }}" alt="Portrait mural" loading="lazy">
    <div class="gi-ov"><span class="gi-lbl">Portrait Work</span></div>
  </a>
</div>
<div class="gallery-cta">
  <a href="https://lacquerbru.co.za/gallery" class="btn-blue">Explore the Full Gallery</a>
</div>

<div class="shop-sec">
  <div class="shop-hd">
    <div>
      <span class="section-label">Available Now</span>
      <h2 class="section-h2">The Collection</h2>
      <p class="section-sub">Digital assets built for working creatives. More drops coming.</p>
    </div>
    <a href="https://lacquerbru.co.za/shop" class="shop-lnk">View All Products &rarr;</a>
  </div>
  <div class="pg">
    <div class="pc">
      <span class="pb">Digital Download</span>
      <div class="piw"><span class="pp">FLARE</span></div>
      <div class="pinfo">
        <span class="pcat">Brush Packs &middot; Procreate</span>
        <div class="pname">The Flare Pack</div>
        <div class="pdesc">40 custom Procreate brushes built for authentic flare, energy, and raw expression. Instant ZIP download after purchase.</div>
        <div class="pfoot">
          <span class="pprice">R649</span>
          <a href="https://lacquerbru.co.za/product/the-flare-pack-procreate-brush-pack-lacquer-bru" class="pbtn">Add to Cart</a>
        </div>
      </div>
    </div>
    <div class="pc">
      <div class="piw"><span class="pp" style="color:var(--wall);font-size:40px;letter-spacing:2px;">SOON</span></div>
      <div class="pinfo">
        <span class="pcat" style="color:var(--concrete)">Coming Soon</span>
        <div class="pname" style="color:var(--concrete)">Next Drop</div>
        <div class="pdesc" style="color:var(--wall)">The next brush pack is in development. Join the mailing list to get first access before public release.</div>
        <div class="pfoot">
          <span class="pprice" style="color:var(--wall)">&mdash;</span>
          <a href="https://lacquerbru.co.za/contact" class="pbtn gh">Notify Me</a>
        </div>
      </div>
    </div>
    <div class="pc">
      <div class="piw"><span class="pp" style="color:var(--wall);font-size:40px;letter-spacing:2px;">SOON</span></div>
      <div class="pinfo">
        <span class="pcat" style="color:var(--concrete)">Coming Soon</span>
        <div class="pname" style="color:var(--concrete)">Limited Print</div>
        <div class="pdesc" style="color:var(--wall)">Limited edition fine art prints from the Lacquer Bru original series. Archival quality. Signed and numbered.</div>
        <div class="pfoot">
          <span class="pprice" style="color:var(--wall)">&mdash;</span>
          <a href="https://lacquerbru.co.za/contact" class="pbtn gh">Notify Me</a>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="about-strip">
  <div class="as-img"></div>
  <div class="as-txt">
    <span class="section-label">The Studio</span>
    <div class="as-q">Equal parts<em> Street</em> and<em> Screen.</em></div>
    <p class="as-body">Lacquer Bru is a multidisciplinary creative studio built on over 16 years of professional experience. Rooted in aerosol culture and evolved through real-world execution &mdash; the work exists at the intersection of urban expression and premium craftsmanship.<br><br>At the heart of everything we create is what we call <strong style="color:var(--blue)">Aerosoul</strong> &mdash; the fusion of surface, atmosphere, movement, and expression.</p>
    <div class="as-stats">
      <div><span class="stn">16+</span><span class="stl">Years Active</span></div>
      <div><span class="stn">3+</span><span class="stl">Countries</span></div>
      <div><span class="stn">100+</span><span class="stl">Projects</span></div>
    </div>
    <a href="https://lacquerbru.co.za/about" class="btn-ghost" style="align-self:flex-start">Read the Full Story</a>
  </div>
</div>

<section class="comm-sec">
  <div class="comm-in">
    <div>
      <span class="section-label">Work Together</span>
      <h2 class="section-h2">Commission a Piece</h2>
      <p class="section-sub">From building-scale murals to intimate canvas works. Every commission starts with a conversation.</p>
      <ul class="cl">
        <li>Large scale exterior and interior murals</li>
        <li>Textured feature walls and surface finishes</li>
        <li>Brand spaces and commercial environments</li>
        <li>Event live painting</li>
        <li>Digital illustration and design</li>
        <li>Limited edition print runs</li>
      </ul>
      <a href="https://lacquerbru.co.za/commission-inquiry" class="btn-primary">Start Your Inquiry</a>
    </div>
    <div class="cig">
      <img src="{{ 'lb-blueprint-home-006.jpg' | asset_url }}" alt="Commission mural" loading="lazy">
      <img src="{{ 'lb-blueprint-home-007.jpg' | asset_url }}" alt="Portrait commission" loading="lazy">
      <img src="{{ 'lb-blueprint-home-008.jpg' | asset_url }}" alt="Wildstyle commission" loading="lazy">
      <img src="{{ 'lb-blueprint-home-009.jpg' | asset_url }}" alt="Large mural" loading="lazy">
    </div>
  </div>
</section>

<div class="email-sec">
  <h2 class="email-h">First Access to New Drops</h2>
  <p class="email-sub">New brush packs, limited prints, and exclusive releases &mdash; straight to your inbox before anywhere else.</p>
  <div class="eform">
    <input class="einp" type="email" placeholder="Your email address">
    <button class="esbm">Subscribe</button>
  </div>
</div>




</section>

