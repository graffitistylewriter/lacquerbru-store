<section class="faq-sec">
  {% if section.settings.label != blank %}
    <span class="section-label">{{ section.settings.label }}</span>
  {% endif %}
  {% if section.settings.heading != blank %}
    <h2 class="section-h2">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="faq-grid">
    {% for block in section.blocks %}
      <div class="faq-item" {{ block.shopify_attributes }}>
        <div class="faq-q">{{ block.settings.question }}</div>
        <div class="faq-a">{{ block.settings.answer }}</div>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "LB FAQ",
  "settings": [
    { "type": "text", "id": "label", "label": "Eyebrow Label", "default": "Support" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently Asked Questions" }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Your question here?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Your answer here.</p>" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "LB FAQ",
      "blocks": [
        { "type": "faq_item" },
        { "type": "faq_item" },
        { "type": "faq_item" }
      ]
    }
  ]
}
{% endschema %}
