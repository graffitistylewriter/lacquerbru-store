<section class="lb-gallery-strip">

  <div class="lb-gallery-strip__header">

    <h2>{{ section.settings.heading }}</h2>

    {% if section.settings.view_all_link != blank %}
      <a href="{{ section.settings.view_all_link }}">
        View All Projects
      </a>
    {% endif %}

  </div>

  <div class="lb-gallery-strip__grid">

    {% for block in section.blocks %}

      <div class="lb-gallery-strip__item">

        {% if block.settings.image %}
          {{
            block.settings.image
            | image_url: width: 1200
            | image_tag
          }}
        {% endif %}

      </div>

    {% endfor %}

  </div>

</section>

{% schema %}
{
  "name": "LB Gallery Strip",

  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Work"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View All Link"
    }
  ],

  "blocks": [
    {
      "type": "image",
      "name": "Gallery Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],

  "max_blocks": 12,

  "presets": [
    {
      "name": "LB Gallery Strip"
    }
  ]
}
{% endschema %}