<section class="lb-shop-main lb-search-main">
  <header class="lb-shop-hero lb-shop-hero--compact">
    <div class="lb-shop-hero__overlay"></div>

    <div class="lb-shop-hero__content">
      <p class="lb-shop-hero__kicker">{{ section.settings.hero_kicker }}</p>
      <h1>{{ section.settings.heading }}</h1>

      {% if search.performed %}
        <p class="lb-shop-hero__text">
          Results for "{{ search.terms | escape }}"
        </p>
      {% else %}
        <p class="lb-shop-hero__text">{{ section.settings.intro }}</p>
      {% endif %}
    </div>
  </header>

  <div class="lb-shop-search">
    <form action="{{ routes.search_url }}" method="get" role="search">
      <input type="hidden" name="type" value="product">
      <input type="hidden" name="options[prefix]" value="last">

      <label class="visually-hidden" for="SearchInput-{{ section.id }}">Search products</label>
      <input
        id="SearchInput-{{ section.id }}"
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="{{ section.settings.search_placeholder | escape }}"
      >

      <button type="submit">Search</button>
    </form>
  </div>

  <div class="lb-shop-products">
    <div class="lb-shop-products__header">
      <p class="lb-kicker">Search</p>

      {% if search.performed %}
        <h2>{{ search.results_count }} {{ search.results_count | pluralize: 'result', 'results' }}</h2>
      {% else %}
        <h2>Find Products</h2>
      {% endif %}
    </div>

    {% if search.performed %}
      {% paginate search.results by section.settings.products_per_page %}
        <div class="lb-collection-main__grid">
          {% for item in search.results %}
            {% if item.object_type == 'product' %}
              {% assign product = item %}

              <article class="lb-product-card">
                <a href="{{ product.url }}">
                  <span class="lb-product-card__media">
                    {% if product.featured_image %}
                      {{
                        product.featured_image
                        | image_url: width: 900
                        | image_tag:
                          loading: 'lazy',
                          alt: product.featured_image.alt | default: product.title,
                          sizes: '(min-width: 960px) 33vw, (min-width: 640px) 50vw, 100vw'
                      }}
                    {% else %}
                      {{ 'product-1' | placeholder_svg_tag: 'lb-product-card__placeholder' }}
                    {% endif %}
                  </span>

                  <span class="lb-product-card__content">
                    {% if product.type != blank %}
                      <span class="lb-product-card__type">{{ product.type }}</span>
                    {% endif %}

                    <h3>{{ product.title }}</h3>
                    <span class="lb-product-card__price">{{ product.price | money }}</span>
                  </span>
                </a>
              </article>
            {% endif %}
          {% else %}
            <div class="lb-empty-state">
              <p>No products matched your search.</p>
              <a href="{{ routes.all_products_collection_url }}" class="lb-btn">Browse All Products</a>
            </div>
          {% endfor %}
        </div>

        {% if paginate.pages > 1 %}
          <nav class="lb-pagination" aria-label="Pagination">
            {% if paginate.previous %}
              <a href="{{ paginate.previous.url }}">Previous</a>
            {% endif %}

            <span>Page {{ paginate.current_page }} of {{ paginate.pages }}</span>

            {% if paginate.next %}
              <a href="{{ paginate.next.url }}">Next</a>
            {% endif %}
          </nav>
        {% endif %}
      {% endpaginate %}
    {% else %}
      <div class="lb-empty-state">
        <p>Search the full Lacquer Bru shop catalog, or browse every product.</p>
        <a href="{{ routes.all_products_collection_url }}" class="lb-btn">Browse All Products</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Main Search",
  "settings": [
    {
      "type": "text",
      "id": "hero_kicker",
      "label": "Hero kicker",
      "default": "Shop Search"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Search Products"
    },
    {
      "type": "text",
      "id": "intro",
      "label": "Intro",
      "default": "Search brush packs, digital downloads, prints, merchandise, product descriptions, and tags."
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder",
      "default": "Search products, brush packs, tags..."
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    }
  ]
}
{% endschema %}
