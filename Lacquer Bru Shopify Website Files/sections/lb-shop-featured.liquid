<section class="lb-shop-featured">

  <div class="lb-shop-featured__header">

    <h2>{{ section.settings.heading }}</h2>

  </div>

  {% assign featured_collection = collections[section.settings.collection] %}

  <div class="lb-shop-featured__grid">

    {% for product in featured_collection.products limit: section.settings.products_to_show %}

      <div class="lb-product-card">

        <a href="{{ product.url }}">

          {% if product.featured_image %}
            {{
              product.featured_image
              | image_url: width: 900
              | image_tag
            }}
          {% endif %}

          <h3>{{ product.title }}</h3>

          <p>{{ product.price | money }}</p>

        </a>

      </div>

    {% endfor %}

  </div>

</section>

{% schema %}
{
  "name": "LB Shop Featured",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop Resources"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products To Show",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 6
    }
  ],
  "presets": [
    {
      "name": "LB Shop Featured"
    }
  ]
}
{% endschema %}