<section class="lb-blueprint-page lb-blueprint-page--commission">


<div class="comm-hero">
  <div class="comm-hero-bg"></div>
  <div class="comm-hero-ol"></div>
  <div class="comm-hero-c">
    <h1 class="comm-title">Commission Inquiry</h1>
    <p class="comm-tag">Every great piece starts with a conversation</p>
  </div>
</div>

<div class="marquee-wrap"><div class="marquee-track"><span class="mi">Graffiti Murals</span><span class="ms"> &middot; </span><span class="mi">Digital Art</span><span class="ms"> &middot; </span><span class="mi">Brush Packs</span><span class="ms"> &middot; </span><span class="mi">Textured Finishes</span><span class="ms"> &middot; </span><span class="mi">Commission Work</span><span class="ms"> &middot; </span><span class="mi">Cape Town</span><span class="ms"> &middot; </span><span class="mi">Aerosoul</span><span class="ms"> &middot; </span><span class="mi">16 Years Experience</span><span class="ms"> &middot; </span><span class="mi">Mural Painting</span><span class="ms"> &middot; </span><span class="mi">Illustration</span><span class="ms"> &middot; </span><span class="mi">Graffiti Murals</span><span class="ms"> &middot; </span><span class="mi">Digital Art</span><span class="ms"> &middot; </span><span class="mi">Brush Packs</span><span class="ms"> &middot; </span><span class="mi">Textured Finishes</span><span class="ms"> &middot; </span><span class="mi">Commission Work</span><span class="ms"> &middot; </span><span class="mi">Cape Town</span><span class="ms"> &middot; </span><span class="mi">Aerosoul</span><span class="ms"> &middot; </span><span class="mi">16 Years Experience</span><span class="ms"> &middot; </span><span class="mi">Mural Painting</span><span class="ms"> &middot; </span><span class="mi">Illustration</span><span class="ms"> &middot; </span></div></div>

<div class="comm-body">
  <div class="comm-info">
    <span class="section-label">Work Together</span>
    <h2 class="section-h2">Let's Create Something Original</h2>
    <p>Whether you arrive with a clear concept or allow full creative freedom &mdash; both approaches are equally valued. Every commission becomes a shared journey toward creating something intentional, immersive, and built to leave a lasting impression.</p>
    <ul class="what-list">
      <li>Large scale exterior and interior murals</li>
      <li>Textured feature walls and surface finishes</li>
      <li>Brand spaces and commercial environments</li>
      <li>Private residences and estates</li>
      <li>Hospitality venues and retail environments</li>
      <li>Vehicle graphics and custom artwork</li>
      <li>Event live painting and activations</li>
      <li>Digital illustration and design projects</li>
      <li>Limited edition fine art print runs</li>
    </ul>
    <div class="comm-details">
      <div class="cd"><span class="cd-icon">Email</span><span>Email: <a href="mailto:howzit@lacquerbru.co.za">howzit@lacquerbru.co.za</a></span></div>
      <div class="cd"><span class="cd-icon">Phone</span><span>Call or WhatsApp: <a href="tel:+27656656693">+27 65 665 6693</a></span></div>
      <div class="cd"><span class="cd-icon">Location</span><span>Based in Cape Town, South Africa. Working locally and internationally.</span></div>
      <div class="cd"><span class="cd-icon">Time</span><span>We respond to all inquiries within 24 to 48 hours.</span></div>
    </div>
  </div>
  {% form 'contact', class: 'comm-form' %}
    <div class="form-title">Tell Us About Your Project</div>
    <p class="form-sub">The more detail you can share the better. Fill in what you know &mdash; we'll work through the rest together.</p>
    <div class="fg-row">
      <div class="fgrp"><label>First Name *</label><input type="text" name="contact[first_name]" placeholder="Your first name" required></div>
      <div class="fgrp"><label>Last Name *</label><input type="text" name="contact[last_name]" placeholder="Your last name" required></div>
    </div>
    <div class="fg-row">
      <div class="fgrp"><label>Email Address *</label><input type="email" name="contact[email]" placeholder="your@email.com" required></div>
      <div class="fgrp"><label>Phone / WhatsApp</label><input type="tel" name="contact[phone]" placeholder="+27 ..."></div>
    </div>
    <div class="fgrp"><label>Project Type *</label>
      <select name="contact[project_type]" required>
        <option value="">Select a project type</option>
        <option>Exterior Mural</option>
        <option>Interior Mural</option>
        <option>Textured Feature Wall</option>
        <option>Commercial Painting</option>
        <option>Vehicle Graphics</option>
        <option>Event Live Painting</option>
        <option>Digital Illustration</option>
        <option>Brand / Logo Design</option>
        <option>Fine Art Print Run</option>
        <option>Other</option>
      </select>
    </div>
    <div class="fg-row">
      <div class="fgrp"><label>Location</label><input type="text" name="contact[location]" placeholder="City, Province"></div>
      <div class="fgrp"><label>Approximate Budget</label>
        <select name="contact[budget]">
          <option value="">Select a range</option>
          <option>Under R5,000</option>
          <option>R5,000 &mdash; R15,000</option>
          <option>R15,000 &mdash; R30,000</option>
          <option>R30,000 &mdash; R60,000</option>
          <option>R60,000 &mdash; R100,000</option>
          <option>R100,000+</option>
          <option>To be discussed</option>
        </select>
      </div>
    </div>
    <div class="fgrp"><label>Timeline</label>
      <select name="contact[timeline]">
        <option value="">When do you need it completed?</option>
        <option>Within 2 weeks</option>
        <option>Within 1 month</option>
        <option>Within 3 months</option>
        <option>Within 6 months</option>
        <option>Flexible &mdash; no rush</option>
      </select>
    </div>
    <div class="fgrp">
      <label>Project Description *</label>
      <textarea name="contact[body]" placeholder="Tell us about your project. What are you envisioning? What space or surface is involved? What feeling or atmosphere do you want to create? Any reference images or inspiration you can describe?" required></textarea>
    </div>
    <p class="form-note">By submitting this form you agree to our <a href="https://lacquerbru.co.za/terms-and-conditions" style="color:var(--blue)">Terms and Conditions</a>. We will never share your information with third parties. All inquiries are treated confidentially.</p>
    <button class="form-sbmt" type="submit">Submit Commission Inquiry</button>
  {% endform %}
</div>

<section class="comm-work">
  <span class="section-label">Previous Work</span>
  <h2 class="section-h2">Commission Examples</h2>
  <p class="section-sub">A selection of commissioned projects across different environments and scales.</p>
  <div class="cw-grid">
    <div class="cw-item"><img src="{{ 'lb-blueprint-commission-022.jpg' | asset_url }}" alt="Commission example" loading="lazy"></div>
    <div class="cw-item"><img src="{{ 'lb-blueprint-commission-023.jpg' | asset_url }}" alt="Commission example" loading="lazy"></div>
    <div class="cw-item"><img src="{{ 'lb-blueprint-commission-024.jpg' | asset_url }}" alt="Commission example" loading="lazy"></div>
    <div class="cw-item"><img src="{{ 'lb-blueprint-commission-025.jpg' | asset_url }}" alt="Commission example" loading="lazy"></div>
  </div>
</section>




</section>

