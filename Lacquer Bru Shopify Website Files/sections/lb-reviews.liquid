<section class="reviews-sec">
  {% if section.settings.label != blank %}
    <span class="section-label">{{ section.settings.label }}</span>
  {% endif %}
  {% if section.settings.heading != blank %}
    <h2 class="section-h2">{{ section.settings.heading }}</h2>
  {% endif %}
  {% if section.settings.subheading != blank %}
    <p class="section-sub">{{ section.settings.subheading }}</p>
  {% endif %}

  <div class="rev-grid">
    {% for block in section.blocks %}
      <div class="rev-card" {{ block.shopify_attributes }}>
        <div class="rev-stars">
          {% for i in (1..5) %}{% if i <= block.settings.rating %}&#9733;{% else %}&#9734;{% endif %}{% endfor %}
        </div>
        <p class="rev-body">&ldquo;{{ block.settings.body }}&rdquo;</p>
        <div class="rev-author">{{ block.settings.author }}</div>
        {% if block.settings.verified %}
          <div class="rev-verified">Verified Purchase</div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "LB Reviews",
  "settings": [
    { "type": "text", "id": "label", "label": "Eyebrow Label", "default": "From the Community" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What Artists Are Saying" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Real feedback from artists using these products every day." }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "range", "id": "rating", "label": "Rating", "min": 1, "max": 5, "default": 5 },
        { "type": "textarea", "id": "body", "label": "Review Text", "default": "This changed how I approach my work." },
        { "type": "text", "id": "author", "label": "Author", "default": "Customer Name, City" },
        { "type": "checkbox", "id": "verified", "label": "Show Verified Purchase badge", "default": true }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "LB Reviews",
      "blocks": [
        { "type": "review" },
        { "type": "review" },
        { "type": "review" }
      ]
    }
  ]
}
{% endschema %}
