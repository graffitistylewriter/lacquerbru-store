<section class="license-sec">
  {% if section.settings.label != blank %}
    <span class="section-label">{{ section.settings.label }}</span>
  {% endif %}
  {% if section.settings.heading != blank %}
    <h2 class="section-h2">{{ section.settings.heading }}</h2>
  {% endif %}
  {% if section.settings.subheading != blank %}
    <p class="section-sub">{{ section.settings.subheading }}</p>
  {% endif %}

  <div class="lic-grid">
    {% for block in section.blocks %}
      <div class="lic-card{% if block.settings.featured %} featured{% endif %}" {{ block.shopify_attributes }}>
        <span class="lic-type">{{ block.settings.type_label }}</span>
        <div class="lic-name">{{ block.settings.name }}</div>
        <p class="lic-desc">{{ block.settings.description }}</p>
        <ul class="lic-list">
          {% assign items = block.settings.list_items | newline_to_br | split: '<br />' %}
          {% for item in items %}
            {% if item != blank %}<li>{{ item | strip }}</li>{% endif %}
          {% endfor %}
        </ul>
        {% if block.settings.note != blank %}
          <p class="lic-note">{{ block.settings.note }}</p>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "LB Licensing",
  "settings": [
    { "type": "text", "id": "label", "label": "Eyebrow Label", "default": "Licensing" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "How You Can Use These Brushes" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Every purchase includes a Personal License." }
  ],
  "blocks": [
    {
      "type": "license_card",
      "name": "License Card",
      "settings": [
        { "type": "checkbox", "id": "featured", "label": "Highlight this card", "default": false },
        { "type": "text", "id": "type_label", "label": "Type Label", "default": "Included with Purchase" },
        { "type": "text", "id": "name", "label": "License Name", "default": "Personal License" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Included automatically with every purchase." },
        { "type": "textarea", "id": "list_items", "label": "List Items (one per line)", "default": "Use in personal artwork\nCreate and sell artwork made with this\nPrint and display your artwork" },
        { "type": "text", "id": "note", "label": "Footnote", "default": "" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "LB Licensing",
      "blocks": [
        { "type": "license_card", "settings": { "featured": true, "type_label": "Included with Purchase", "name": "Personal License" } },
        { "type": "license_card", "settings": { "type_label": "Available on Request", "name": "Commercial License" } }
      ]
    }
  ]
}
{% endschema %}
