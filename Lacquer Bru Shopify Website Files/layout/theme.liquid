<!doctype html>
<html lang="{{ request.locale.iso_code }}">

<head>
  <meta charset="utf-8">

  <meta
    name="viewport"
    content="width=device-width,initial-scale=1"
  >

  <meta
    name="theme-color"
    content="#111111"
  >

  <link rel="canonical" href="{{ canonical_url }}">

  {% if settings.favicon != blank %}
    <link
      rel="icon"
      type="image/png"
      href="{{ settings.favicon | image_url }}"
    >
  {% endif %}

  <title>
    {% if page_title %}
      {{ page_title }}
    {% endif %}

    {% unless page_title contains shop.name %}
      | {{ shop.name }}
    {% endunless %}
  </title>

  {% if page_description %}
    <meta
      name="description"
      content="{{ page_description | escape }}"
    >
  {% endif %}

  {{ content_for_header }}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Oswald:wght@400;500;700&display=swap"
    rel="stylesheet"
  >

  {{ 'lb-base.css' | asset_url | stylesheet_tag }}
  {{ 'lb-components.css' | asset_url | stylesheet_tag }}
  {{ 'lb-blueprints.css' | asset_url | stylesheet_tag }}
  {{ 'lb-animations.css' | asset_url | stylesheet_tag }}

</head>

<body
  class="
    template-{{ template.name }}
    page-{{ request.page_type }}
    {% if customer %}customer-logged-in{% endif %}
  "
>

  <a
    class="skip-to-content-link visually-hidden focus-inset"
    href="#MainContent"
  >
    Skip to content
  </a>

  {% section 'lb-header' %}

  <main
    id="MainContent"
    role="main"
    tabindex="-1"
  >

    {{ content_for_layout }}

  </main>

  {% section 'lb-footer' %}

  <script src="{{ 'lb-main.js' | asset_url }}" defer></script>

</body>

</html>