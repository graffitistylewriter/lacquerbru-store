<section class="lb-marquee" aria-label="{{ section.settings.accessibility_label | escape }}">

  <div class="lb-marquee__track">

    {% for repeat in (1..2) %}

      {% for block in section.blocks %}

        {% if block.settings.text != blank %}
          <span class="lb-marquee__item" {{ block.shopify_attributes }}>
            {{ block.settings.text }}
          </span>

          {% unless forloop.last and repeat == 2 %}
            <span class="lb-marquee__separator" aria-hidden="true">
              {{ section.settings.separator }}
            </span>
          {% endunless %}
        {% endif %}

      {% endfor %}

    {% endfor %}

  </div>

</section>

{% schema %}
{
  "name": "LB Marquee",
  "settings": [
    {
      "type": "text",
      "id": "accessibility_label",
      "label": "Accessibility Label",
      "default": "Lacquer Bru creative services"
    },
    {
      "type": "text",
      "id": "separator",
      "label": "Separator",
      "default": "&middot;"
    }
  ],
  "blocks": [
    {
      "type": "marquee_item",
      "name": "Marquee Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Graffiti Murals"
        }
      ]
    }
  ],
  "presets": [
    {
