<section class="lb-commission-strip">

  <div class="lb-commission-strip__inner">

    <h2>{{ section.settings.heading }}</h2>

    <div class="lb-commission-strip__text">
      {{ section.settings.content }}
    </div>

    <a
      href="{{ section.settings.button_link }}"
      class="lb-btn"
    >
      {{ section.settings.button_text }}
    </a>

  </div>

</section>

{% schema %}
{
  "name": "LB Commission Strip",

  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Let's Build Something Together"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Request A Quote"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],

  "presets": [
    {
      "name": "LB Commission Strip"
    }
  ]
}
{% endschema %}