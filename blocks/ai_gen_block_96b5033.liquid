{% doc %}
  @prompt
    Update the existing Payment Methods block to support full light/dark theme toggle styling. The block should: 1. Have a solid bar background that is BLACK in dark mode and WHITE in light mode, responding automatically to the theme's light/dark color scheme toggle. 2. Text color must invert with the theme: WHITE text on BLACK background (dark mode), BLACK text on WHITE background (light mode). 3. Payment method logos (PayPal, PayFast, Visa, Mastercard, Amex) should always display in FULL COLOUR - never greyscale - in both light and dark modes using CSS filter: none. 4. Social media icons must also always remain in full brand colour in both light and dark modes. 5. Use CSS custom properties or data-color-scheme attributes consistent with how the theme handles its light/dark toggle.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-payment-methods-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-payment-methods-container-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: var(--ai-payment-bg-{{ ai_gen_id }});
    color: var(--ai-payment-text-{{ ai_gen_id }});
    border-radius: {{ block.settings.border_radius }}px;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  [data-color-scheme="light"] .ai-payment-methods-container-{{ ai_gen_id }},
  .ai-payment-methods-container-{{ ai_gen_id }}[data-theme="light"] {
    --ai-payment-bg-{{ ai_gen_id }}: #ffffff;
    --ai-payment-text-{{ ai_gen_id }}: #000000;
  }

  [data-color-scheme="dark"] .ai-payment-methods-container-{{ ai_gen_id }},
  .ai-payment-methods-container-{{ ai_gen_id }}[data-theme="dark"] {
    --ai-payment-bg-{{ ai_gen_id }}: #000000;
    --ai-payment-text-{{ ai_gen_id }}: #ffffff;
  }

  @media (prefers-color-scheme: light) {
    .ai-payment-methods-container-{{ ai_gen_id }} {
      --ai-payment-bg-{{ ai_gen_id }}: #ffffff;
      --ai-payment-text-{{ ai_gen_id }}: #000000;
    }
  }

  @media (prefers-color-scheme: dark) {
    .ai-payment-methods-container-{{ ai_gen_id }} {
      --ai-payment-bg-{{ ai_gen_id }}: #000000;
      --ai-payment-text-{{ ai_gen_id }}: #ffffff;
    }
  }

  .ai-payment-methods-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.section_gap }}px;
    align-items: {{ block.settings.alignment }};
  }

  .ai-payment-methods-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 600;
    margin: 0;
    color: var(--ai-payment-text-{{ ai_gen_id }});
  }

  .ai-payment-methods-logos-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.logo_gap }}px;
    align-items: center;
    justify-content: {{ block.settings.alignment }};
  }

  .ai-payment-methods-logo-{{ ai_gen_id }} {
    height: {{ block.settings.logo_height }}px;
    width: auto;
    object-fit: contain;
    filter: none;
    opacity: 1;
  }

  .ai-payment-methods-social-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.social_gap }}px;
    align-items: center;
    justify-content: {{ block.settings.alignment }};
  }

  .ai-payment-methods-social-link-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: {{ block.settings.social_icon_size }}px;
    height: {{ block.settings.social_icon_size }}px;
    transition: transform 0.2s ease;
  }

  .ai-payment-methods-social-link-{{ ai_gen_id }}:hover {
    transform: scale(1.1);
  }

  .ai-payment-methods-social-icon-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    filter: none;
  }

  @media screen and (max-width: 749px) {
    .ai-payment-methods-container-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-payment-methods-logo-{{ ai_gen_id }} {
      height: {{ block.settings.logo_height | times: 0.8 }}px;
    }

    .ai-payment-methods-social-link-{{ ai_gen_id }} {
      width: {{ block.settings.social_icon_size | times: 0.9 }}px;
      height: {{ block.settings.social_icon_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

