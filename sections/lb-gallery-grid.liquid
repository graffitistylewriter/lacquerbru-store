<section
  class="lb-gallery-grid"
  style="background:{{ section.settings.bg_color }};padding:{{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;"
>

  {% if section.settings.label != blank or section.settings.heading != blank %}
    <div class="lb-gallery-grid__header" style="padding:0 60px;margin-bottom:40px;">
      {% if section.settings.label != blank %}
        <span class="lb-gallery-grid__label" style="color:{{ section.settings.accent_color }};">{{ section.settings.label }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="lb-gallery-grid__heading" style="color:{{ section.settings.text_color }};">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subtext != blank %}
        <p class="lb-gallery-grid__subtext" style="color:{{ section.settings.muted_color }};">{{ section.settings.subtext }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="lb-gallery-grid__grid lb-gallery-grid__grid--{{ section.settings.layout }}">
    {% for block in section.blocks %}
      {% if block.type == 'image' and block.settings.image != blank %}
        <div
          class="lb-gallery-grid__item{% if block.settings.wide %} lb-gallery-grid__item--wide{% endif %}{% if block.settings.tall %} lb-gallery-grid__item--tall{% endif %}"
          {{ block.shopify_attributes }}
        >
          {{ block.settings.image | image_url: width: 1400 | image_tag:
            loading: 'lazy',
            alt: block.settings.caption | default: section.settings.heading,
            class: 'lb-gallery-grid__img',
            width: 1400,
            height: 1000
          }}
          {% if block.settings.caption != blank or block.settings.category != blank %}
            <div class="lb-gallery-grid__overlay">
              {% if block.settings.caption != blank %}
                <div class="lb-gallery-grid__caption">{{ block.settings.caption }}</div>
              {% endif %}
              {% if block.settings.category != blank %}
                <div class="lb-gallery-grid__category" style="color:{{ section.settings.accent_color }};">{{ block.settings.category }}</div>
              {% endif %}
            </div>
          {% endif %}
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}" class="lb-gallery-grid__link" aria-label="{{ block.settings.caption | default: 'View' }}"></a>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>

  {% if section.settings.cta_label != blank %}
    <div class="lb-gallery-grid__cta" style="padding:48px 60px 0;">
      {% if section.settings.cta_eyebrow != blank %}
        <span class="lb-gallery-grid__label" style="color:{{ section.settings.accent_color }};">{{ section.settings.cta_eyebrow }}</span>
      {% endif %}
      <h2 class="lb-gallery-grid__cta-heading" style="color:{{ section.settings.text_color }};">{{ section.settings.cta_heading }}</h2>
      {% if section.settings.cta_subtext != blank %}
        <p style="color:{{ section.settings.muted_color }};">{{ section.settings.cta_subtext }}</p>
      {% endif %}
      <a href="{{ section.settings.cta_url }}" class="lb-btn lb-btn--primary" style="background:{{ section.settings.accent_color }};color:#000;border-color:{{ section.settings.accent_color }};">
        {{ section.settings.cta_label }}
      </a>
    </div>
  {% endif %}

</section>

<style>
  .lb-gallery-grid__label { display: block; font-size: 10px; font-weight: 500; letter-spacing: 0.28em; text-transform: uppercase; margin-bottom: 12px; }
  .lb-gallery-grid__heading { font-size: clamp(24px, 4vw, 48px); font-weight: 700; letter-spacing: -0.01em; text-transform: uppercase; margin: 0 0 10px; }
  .lb-gallery-grid__subtext { font-size: 14px; line-height: 1.75; margin: 0; max-width: 560px; }

  .lb-gallery-grid__grid { display: grid; gap: {{ section.settings.gap }}px; }
  .lb-gallery-grid__grid--masonry { grid-template-columns: repeat({{ section.settings.columns }}, 1fr); }
  .lb-gallery-grid__grid--uniform { grid-template-columns: repeat({{ section.settings.columns }}, 1fr); }
  .lb-gallery-grid__grid--featured { grid-template-columns: repeat(3, 1fr); grid-auto-rows: 300px; }

  .lb-gallery-grid__item { position: relative; overflow: hidden; }
  .lb-gallery-grid__item--wide { grid-column: span 2; }
  .lb-gallery-grid__item--tall { grid-row: span 2; }
  .lb-gallery-grid__img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.5s; }
  .lb-gallery-grid__item:hover .lb-gallery-grid__img { transform: scale(1.04); }

  .lb-gallery-grid__overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 20px;
    background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, transparent 100%);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .lb-gallery-grid__item:hover .lb-gallery-grid__overlay { opacity: 1; }
  .lb-gallery-grid__caption { font-size: 14px; font-weight: 600; color: #fff; }
  .lb-gallery-grid__category { font-size: 10px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; margin-top: 4px; }
  .lb-gallery-grid__link { position: absolute; inset: 0; z-index: 2; }

  .lb-gallery-grid__cta { display: flex; flex-direction: column; gap: 14px; max-width: 600px; }
  .lb-gallery-grid__cta-heading { font-size: clamp(22px, 3vw, 38px); font-weight: 700; text-transform: uppercase; margin: 0; }

  .lb-btn { font-size: 11px; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; padding: 16px 40px; text-decoration: none; display: inline-block; transition: all 0.2s; border: 1.5px solid transparent; }
  .lb-btn--primary:hover { background: transparent !important; color: {{ section.settings.accent_color }} !important; border-color: {{ section.settings.accent_color }} !important; }

  @media (max-width: 860px) {
    .lb-gallery-grid__header, .lb-gallery-grid__cta { padding-left: 24px !important; padding-right: 24px !important; }
    .lb-gallery-grid__grid { grid-template-columns: 1fr 1fr !important; }
    .lb-gallery-grid__item--wide { grid-column: span 1; }
    .lb-gallery-grid__item--tall { grid-row: span 1; }
  }
  @media (max-width: 540px) {
    .lb-gallery-grid__grid { grid-template-columns: 1fr !important; }
  }
</style>

{% schema %}
{
  "name": "LB Gallery Grid",
  "tag": "section",
  "blocks": [
    {
      "type": "image",
      "name": "Gallery Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "caption", "label": "Caption" },
        { "type": "text", "id": "category", "label": "Category Tag" },
        { "type": "url", "id": "link", "label": "Link (optional)" },
        { "type": "checkbox", "id": "wide", "label": "Wide (spans 2 columns)", "default": false },
        { "type": "checkbox", "id": "tall", "label": "Tall (spans 2 rows)", "default": false }
      ]
    }
  ],
  "settings": [
    { "type": "header", "content": "Section Header" },
    { "type": "text", "id": "label", "label": "Section Label", "default": "The Work" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Gallery" },
    { "type": "textarea", "id": "subtext", "label": "Subtext" },
    { "type": "header", "content": "Grid Layout" },
    { "type": "select", "id": "layout", "label": "Layout Style", "options": [
      { "value": "masonry", "label": "Masonry (mixed sizes)" },
      { "value": "uniform", "label": "Uniform Grid" },
      { "value": "featured", "label": "Featured (fixed row height)" }
    ], "default": "masonry" },
    { "type": "select", "id": "columns", "label": "Columns (desktop)", "options": [
      { "value": "2", "label": "2" },
      { "value": "3", "label": "3" },
      { "value": "4", "label": "4" }
    ], "default": "3" },
    { "type": "range", "id": "gap", "label": "Gap Between Images", "min": 0, "max": 24, "step": 2, "default": 4, "unit": "px" },
    { "type": "header", "content": "Bottom CTA" },
    { "type": "text", "id": "cta_eyebrow", "label": "CTA Eyebrow" },
    { "type": "text", "id": "cta_heading", "label": "CTA Heading", "default": "See Something You Like?" },
    { "type": "textarea", "id": "cta_subtext", "label": "CTA Subtext", "default": "Every wall, canvas, and surface is an opportunity." },
    { "type": "text", "id": "cta_label", "label": "CTA Button Label", "default": "Start a Commission" },
    { "type": "url", "id": "cta_url", "label": "CTA Button URL" },
    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#0A0A0A" },
    { "type": "color", "id": "text_color", "label": "Text Colour", "default": "#FFFFFF" },
    { "type": "color", "id": "muted_color", "label": "Muted Colour", "default": "#AAAAAA" },
    { "type": "color", "id": "accent_color", "label": "Accent Colour", "default": "#7DD8E8" },
    { "type": "range", "id": "padding_top", "label": "Top Padding", "min": 0, "max": 160, "step": 10, "default": 100, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Bottom Padding", "min": 0, "max": 160, "step": 10, "default": 100, "unit": "px" }
  ],
  "presets": [
    {
      "name": "Gallery Grid",
      "blocks": [
        { "type": "image", "settings": { "caption": "Wildstyle Production", "category": "Graffiti · Mural", "wide": true } },
        { "type": "image", "settings": { "caption": "Portrait Study", "category": "Portrait · Mural" } },
        { "type": "image", "settings": { "caption": "Fire & Motion", "category": "Character · Mural" } },
        { "type": "image", "settings": { "caption": "Large Scale Production", "category": "Mural · Commercial", "wide": true } }
      ]
    }
  ]
}
{% endschema %}
