<section class="lb-product-feature" style="background:{{ section.settings.bg_color }};padding:{{ section.settings.padding_top }}px 60px {{ section.settings.padding_bottom }}px;">

  <div class="lpf-inner">

    {%- comment -%} VISUAL SIDE {%- endcomment -%}
    <div class="lpf-visual">
      <div class="lpf-bg-word">{{ section.settings.bg_word }}</div>
      <div class="lpf-pack-name">{{ section.settings.pack_name }}</div>
      <div class="lpf-pack-sub">{{ section.settings.pack_subtitle }}</div>

      <div class="lpf-badge-row">
        {% for block in section.blocks %}
          {% if block.type == 'badge' %}
            <span class="lpf-badge" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    {%- comment -%} INFO SIDE {%- endcomment -%}
    <div class="lpf-info">

      {% if section.settings.eyebrow != blank %}
        <span class="lpf-eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}

      {% if section.settings.product != blank %}
        {%- assign feat_product = all_products[section.settings.product] -%}
        <h2 class="lpf-name">{{ feat_product.title }}</h2>
        <p class="lpf-desc">{{ feat_product.description | strip_html | truncate: 320 }}</p>
      {% else %}
        <h2 class="lpf-name">{{ section.settings.heading }}</h2>
        <p class="lpf-desc">{{ section.settings.description }}</p>
      {% endif %}

      {%- comment -%} INCLUDES {%- endcomment -%}
      {% assign has_includes = false %}
      {% for block in section.blocks %}{% if block.type == 'include_item' %}{% assign has_includes = true %}{% endif %}{% endfor %}
      {% if has_includes %}
        <div class="lpf-includes">
          <h4>What's Included</h4>
          <ul class="lpf-inc-list">
            {% for block in section.blocks %}
              {% if block.type == 'include_item' %}
                <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
              {% endif %}
            {% endfor %}
          </ul>
        </div>
      {% endif %}

      {%- comment -%} COMPAT {%- endcomment -%}
      {% assign has_compat = false %}
      {% for block in section.blocks %}{% if block.type == 'compat_item' %}{% assign has_compat = true %}{% endif %}{% endfor %}
      {% if has_compat %}
        <div class="lpf-compat">
          {% for block in section.blocks %}
            {% if block.type == 'compat_item' %}
              <div class="lpf-compat-item{% if block.settings.available %} active{% endif %}" {{ block.shopify_attributes }}>
                {{ block.settings.label }}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}

      {%- comment -%} PRICE + CTA {%- endcomment -%}
      {% if feat_product != blank %}
        <div class="lpf-price-row">
          <div class="lpf-price">{{ feat_product.price | money }}</div>
          {% if section.settings.license_note != blank %}
            <div class="lpf-license">{{ section.settings.license_note }}</div>
          {% endif %}
        </div>
        <div class="lpf-btns">
          <a href="{{ feat_product.url }}" class="lpf-cart">
            {{ section.settings.cta_label | default: 'Add to Cart' }} — {{ feat_product.price | money }}
          </a>
        </div>
      {% endif %}

      {% if section.settings.guarantee != blank %}
        <div class="lpf-guarantee">{{ section.settings.guarantee }}</div>
      {% endif %}

    </div>
  </div>

</section>

<style>
  .lb-product-feature { width: 100%; box-sizing: border-box; }
  .lpf-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; max-width: 1200px; margin: 0 auto; }
  .lpf-visual { position: relative; display: flex; flex-direction: column; gap: 16px; }
  .lpf-bg-word { font-size: clamp(60px, 10vw, 120px); font-weight: 900; letter-spacing: -0.04em; text-transform: uppercase; color: rgba(255,255,255,0.04); line-height: 1; pointer-events: none; user-select: none; }
  .lpf-pack-name { font-size: clamp(28px, 4vw, 48px); font-weight: 800; letter-spacing: -0.02em; text-transform: uppercase; color: #fff; margin-top: -20px; }
  .lpf-pack-sub { font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: #aaa; }
  .lpf-badge-row { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 8px; }
  .lpf-badge { font-size: 10px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; padding: 6px 14px; border: 1px solid rgba(255,255,255,0.15); color: #fff; }
  .lpf-eyebrow { font-size: 10px; font-weight: 500; letter-spacing: 0.28em; text-transform: uppercase; color: #7DD8E8; display: block; margin-bottom: 12px; }
  .lpf-name { font-size: clamp(24px, 3vw, 40px); font-weight: 700; letter-spacing: -0.01em; text-transform: uppercase; color: #fff; margin: 0 0 16px; }
  .lpf-desc { font-size: 14px; line-height: 1.75; color: #aaa; margin: 0 0 24px; }
  .lpf-includes h4 { font-size: 10px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: #fff; margin: 0 0 12px; }
  .lpf-inc-list { list-style: none; padding: 0; margin: 0 0 24px; display: flex; flex-direction: column; gap: 8px; }
  .lpf-inc-list li { font-size: 13px; color: #ccc; padding-left: 16px; position: relative; }
  .lpf-inc-list li::before { content: '—'; position: absolute; left: 0; color: #7DD8E8; }
  .lpf-compat { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 24px; }
  .lpf-compat-item { font-size: 11px; font-weight: 500; letter-spacing: 0.1em; padding: 6px 14px; border: 1px solid rgba(255,255,255,0.1); color: #666; }
  .lpf-compat-item.active { border-color: #7DD8E8; color: #7DD8E8; }
  .lpf-price-row { display: flex; align-items: center; gap: 20px; margin-bottom: 20px; flex-wrap: wrap; }
  .lpf-price { font-size: 32px; font-weight: 700; color: #fff; }
  .lpf-license { font-size: 12px; color: #aaa; line-height: 1.5; }
  .lpf-btns { margin-bottom: 16px; }
  .lpf-cart { display: inline-block; background: #7DD8E8; color: #000; font-size: 11px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; padding: 16px 32px; text-decoration: none; transition: opacity 0.2s; }
  .lpf-cart:hover { opacity: 0.85; }
  .lpf-guarantee { font-size: 11px; color: #666; letter-spacing: 0.06em; }
  @media (max-width: 860px) {
    .lpf-inner { grid-template-columns: 1fr; gap: 40px; }
    .lb-product-feature { padding-left: 24px !important; padding-right: 24px !important; }
  }
</style>

{% schema %}
{
  "name": "LB Product Feature",
  "tag": "section",
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        { "type": "text", "id": "text", "label": "Badge Text" }
      ]
    },
    {
      "type": "include_item",
      "name": "Include Item",
      "settings": [
        { "type": "text", "id": "text", "label": "Item Text" }
      ]
    },
    {
      "type": "compat_item",
      "name": "Compatibility Item",
      "settings": [
        { "type": "text", "id": "label", "label": "Label" },
        { "type": "checkbox", "id": "available", "label": "Available", "default": true }
      ]
    }
  ],
  "settings": [
    { "type": "header", "content": "Product" },
    { "type": "product", "id": "product", "label": "Featured Product", "info": "Select a product to pull live title, description and price. Leave blank to use manual fields below." },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow Text", "default": "Available Now · Digital Download" },
    { "type": "text", "id": "heading", "label": "Heading (manual fallback)", "default": "The Flare Pack" },
    { "type": "textarea", "id": "description", "label": "Description (manual fallback)" },
    { "type": "text", "id": "cta_label", "label": "CTA Button Label", "default": "Add to Cart" },
    { "type": "text", "id": "license_note", "label": "License Note", "default": "Personal license included." },
    { "type": "text", "id": "guarantee", "label": "Guarantee Line", "default": "Secure checkout · Instant delivery · 3 download attempts · 14-day link validity" },
    { "type": "header", "content": "Visual Panel" },
    { "type": "text", "id": "bg_word", "label": "Background Word", "default": "FLARE" },
    { "type": "text", "id": "pack_name", "label": "Pack Name", "default": "FLARE" },
    { "type": "text", "id": "pack_subtitle", "label": "Pack Subtitle", "default": "Procreate Brush Pack by Lacquer Bru" },
    { "type": "header", "content": "Colours & Spacing" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#0A0A0A" },
    { "type": "range", "id": "padding_top", "label": "Top Padding", "min": 40, "max": 160, "step": 10, "default": 100, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Bottom Padding", "min": 40, "max": 160, "step": 10, "default": 100, "unit": "px" }
  ],
  "presets": [
    {
      "name": "LB Product Feature",
      "blocks": [
        { "type": "badge", "settings": { "text": "Procreate 5+" } },
        { "type": "badge", "settings": { "text": ".brushset Format" } },
        { "type": "badge", "settings": { "text": "Instant Download" } },
        { "type": "include_item", "settings": { "text": "Delivered as a single file" } },
        { "type": "include_item", "settings": { "text": "Imports directly in seconds" } },
        { "type": "include_item", "settings": { "text": "Installation guide included" } },
        { "type": "include_item", "settings": { "text": "Free updates when new versions release" } },
        { "type": "compat_item", "settings": { "label": "Procreate 5+", "available": true } },
        { "type": "compat_item", "settings": { "label": "All iPad Models", "available": true } }
      ]
    }
  ]
}
{% endschema %}
