<section
  class="lb-text-columns"
  style="background:{{ section.settings.bg_color }};padding:{{ section.settings.padding_top }}px 60px {{ section.settings.padding_bottom }}px;"
>
  {% if section.settings.label != blank or section.settings.heading != blank %}
    <div class="lb-text-columns__header lb-text-columns__header--{{ section.settings.header_align }}" style="margin-bottom:48px;">
      {% if section.settings.label != blank %}
        <span class="lb-text-columns__label" style="color:{{ section.settings.accent_color }};">{{ section.settings.label }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="lb-text-columns__heading" style="color:{{ section.settings.text_color }};">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subtext != blank %}
        <p class="lb-text-columns__subtext" style="color:{{ section.settings.muted_color }};">{{ section.settings.subtext }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="lb-text-columns__grid" style="grid-template-columns:repeat({{ section.settings.columns }},1fr);gap:{{ section.settings.gap }}px;">
    {% for block in section.blocks %}
      {% if block.type == 'column' %}
        <div class="lb-text-columns__col" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            <div class="lb-text-columns__icon" style="color:{{ section.settings.accent_color }};">{{ block.settings.icon }}</div>
          {% endif %}
          {% if block.settings.image != blank %}
            <div class="lb-text-columns__img-wrap">
              {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: block.settings.title, class: 'lb-text-columns__img' }}
            </div>
          {% endif %}
          {% if block.settings.title != blank %}
            <h3 class="lb-text-columns__col-title" style="color:{{ section.settings.text_color }};">{{ block.settings.title }}</h3>
          {% endif %}
          {% if block.settings.body != blank %}
            <div class="lb-text-columns__col-body" style="color:{{ section.settings.muted_color }};">{{ block.settings.body }}</div>
          {% endif %}
          {% if block.settings.link_label != blank %}
            <a href="{{ block.settings.link_url }}" class="lb-text-columns__link" style="color:{{ section.settings.accent_color }};">
              {{ block.settings.link_label }} &rarr;
            </a>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

<style>
  .lb-text-columns__header--left { text-align: left; }
  .lb-text-columns__header--center { text-align: center; }
  .lb-text-columns__label { display: block; font-size: var(--lb-text-xs); font-weight: 500; letter-spacing: 0.28em; text-transform: uppercase; margin-bottom: var(--lb-space-sm); }
  .lb-text-columns__heading { font-size: var(--lb-text-xl); font-weight: 700; text-transform: uppercase; letter-spacing: -0.01em; margin: 0 0 var(--lb-space-xs); }
  .lb-text-columns__subtext { font-size: var(--lb-text-sm); line-height: 1.75; margin: 0; max-width: 560px; }
  .lb-text-columns__header--center .lb-text-columns__subtext { margin: 0 auto; }
  .lb-text-columns__grid { display: grid; }
  .lb-text-columns__col { display: flex; flex-direction: column; gap: var(--lb-space-sm); }
  .lb-text-columns__icon { font-size: 32px; line-height: 1; }
  .lb-text-columns__img-wrap { aspect-ratio: 16/9; overflow: hidden; }
  .lb-text-columns__img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .lb-text-columns__col-title { font-size: var(--lb-text-lg); font-weight: 700; margin: 0; letter-spacing: -0.01em; }
  .lb-text-columns__col-body { font-size: var(--lb-text-sm); line-height: 1.75; }
  .lb-text-columns__link { font-size: var(--lb-text-xs); font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; text-decoration: none; transition: opacity var(--lb-transition); }
  .lb-text-columns__link:hover { opacity: 0.7; }
  @media (max-width: 860px) {
    .lb-text-columns { padding-left: var(--lb-container-pad) !important; padding-right: var(--lb-container-pad) !important; }
    .lb-text-columns__grid { grid-template-columns: 1fr 1fr !important; }
  }
  @media (max-width: 540px) {
    .lb-text-columns__grid { grid-template-columns: 1fr !important; }
  }
</style>

{% schema %}
{
  "name": "LB Text Columns",
  "tag": "section",
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "🎨" },
        { "type": "image_picker", "id": "image", "label": "Image (optional, replaces icon)" },
        { "type": "text", "id": "title", "label": "Title", "default": "Column Title" },
        { "type": "richtext", "id": "body", "label": "Body Text" },
        { "type": "text", "id": "link_label", "label": "Link Label" },
        { "type": "url", "id": "link_url", "label": "Link URL" }
      ]
    }
  ],
  "settings": [
    { "type": "text", "id": "label", "label": "Section Label" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What We Do" },
    { "type": "textarea", "id": "subtext", "label": "Subtext" },
    { "type": "select", "id": "header_align", "label": "Header Alignment", "options": [
      { "value": "left", "label": "Left" },
      { "value": "center", "label": "Center" }
    ], "default": "left" },
    { "type": "select", "id": "columns", "label": "Columns (desktop)", "options": [
      { "value": "2", "label": "2" },
      { "value": "3", "label": "3" },
      { "value": "4", "label": "4" }
    ], "default": "3" },
    { "type": "range", "id": "gap", "label": "Column Gap", "min": 16, "max": 80, "step": 8, "default": 40, "unit": "px" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#0A0A0A" },
    { "type": "color", "id": "text_color", "label": "Text Colour", "default": "#FFFFFF" },
    { "type": "color", "id": "muted_color", "label": "Muted Colour", "default": "#AAAAAA" },
    { "type": "color", "id": "accent_color", "label": "Accent Colour", "default": "#7DD8E8" },
    { "type": "range", "id": "padding_top", "label": "Top Padding", "min": 40, "max": 160, "step": 10, "default": 100, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Bottom Padding", "min": 40, "max": 160, "step": 10, "default": 100, "unit": "px" }
  ],
  "presets": [
    {
      "name": "Text Columns",
      "blocks": [
        { "type": "column", "settings": { "icon": "🎨", "title": "Mural Painting", "body": "<p>Large scale exterior and interior murals for any environment.</p>" } },
        { "type": "column", "settings": { "icon": "✏️", "title": "Illustration", "body": "<p>Custom illustration and graphic design for any project.</p>" } },
        { "type": "column", "settings": { "icon": "📱", "title": "Digital Assets", "body": "<p>Procreate brush packs and digital tools for working artists.</p>" } }
      ]
    }
  ]
}
{% endschema %}
