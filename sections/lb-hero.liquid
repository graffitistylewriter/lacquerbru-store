{%- assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0 -%}

<section
  class="lb-hero"
  style="
    min-height: {{ section.settings.min_height }}px;
    {% if section.settings.bg_color != blank %}background-color: {{ section.settings.bg_color }};{% endif %}
  "
>

  {%- comment -%} BACKGROUND {%- endcomment -%}
  {% if section.settings.bg_image != blank %}
    <div class="lb-hero__bg">
      {{ section.settings.bg_image | image_url: width: 1920 | image_tag:
        loading: 'eager',
        fetchpriority: 'high',
        class: 'lb-hero__bg-img',
        alt: section.settings.heading
      }}
    </div>
  {% endif %}

  {% if section.settings.show_overlay %}
    <div
      class="lb-hero__overlay"
      style="background:{{ section.settings.overlay_color }};opacity:{{ overlay_opacity }};"
    ></div>
  {% endif %}

  {%- comment -%} TEXT BAND OVERLAY {%- endcomment -%}
  {%- if section.settings.show_text_band -%}
    {%- assign band_opacity = section.settings.text_band_opacity | divided_by: 100.0 -%}
    <div
      class="lb-hero__text-band"
      style="
        background: {{ section.settings.text_band_color }};
        opacity: {{ band_opacity }};
        height: {{ section.settings.text_band_height }};
      "
    ></div>
  {%- endif -%}


  {%- comment -%} CONTENT {%- endcomment -%}
  <div class="lb-hero__content lb-hero__content--{{ section.settings.content_align }}">

    {% if section.settings.eyebrow != blank %}
      <span class="lb-hero__eyebrow">{{ section.settings.eyebrow }}</span>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h1 class="lb-hero__heading">
        {{ section.settings.heading }}
        {% if section.settings.heading_em != blank %}
          <em>{{ section.settings.heading_em }}</em>
        {% endif %}
      </h1>
    {% endif %}

    {% if section.settings.subtext != blank %}
      <p class="lb-hero__subtext">{{ section.settings.subtext }}</p>
    {% endif %}

    {% if section.settings.btn1_label != blank or section.settings.btn2_label != blank %}
      <div class="lb-hero__btns">
        {% if section.settings.btn1_label != blank %}
          <a href="{{ section.settings.btn1_url }}" class="lb-btn lb-btn--primary">
            {{ section.settings.btn1_label }}
          </a>
        {% endif %}
        {% if section.settings.btn2_label != blank %}
          <a href="{{ section.settings.btn2_url }}" class="lb-btn lb-btn--ghost">
            {{ section.settings.btn2_label }}
          </a>
        {% endif %}
      </div>
    {% endif %}

  </div>

  {% if section.settings.show_scroll_indicator %}
    <div class="lb-hero__scroll">
      <div class="lb-hero__scroll-line"></div>
      <span>{{ section.settings.scroll_label | default: 'Scroll' }}</span>
    </div>
  {% endif %}

</section>

<style>
  .lb-hero {
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
    width: 100%;
  }
  .lb-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .lb-hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
  }
  .lb-hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }
  .lb-hero__content {
    position: relative;
    z-index: 2;
    padding: {{ section.settings.padding_v }}px 60px;
    max-width: {{ section.settings.content_max_width }}px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .lb-hero__content--left { align-items: flex-start; margin-right: auto; }
  .lb-hero__content--center { align-items: center; text-align: center; margin: 0 auto; }
  .lb-hero__content--right { align-items: flex-end; text-align: right; margin-left: auto; }

  .lb-hero__eyebrow {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
  }
  .lb-hero__heading {
    font-size: clamp(36px, 6vw, 80px);
    font-weight: 700;
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: {{ section.settings.text_color }};
    margin: 0;
  }
  .lb-hero__heading em {
    font-style: italic;
    color: {{ section.settings.accent_color }};
  }
  .lb-hero__subtext {
    font-size: clamp(14px, 1.5vw, 17px);
    line-height: 1.75;
    color: {{ section.settings.subtext_color }};
    max-width: 560px;
    margin: 0;
  }
  .lb-hero__btns {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 8px;
  }

  /* SHARED BUTTON STYLES */
  .lb-btn {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 16px 40px;
    text-decoration: none;
    display: inline-block;
    transition: all 0.2s;
    font-family: inherit;
    cursor: pointer;
    border: 1.5px solid transparent;
  }
  .lb-btn--primary {
    background: {{ section.settings.accent_color }};
    color: #000;
    border-color: {{ section.settings.accent_color }};
  }
  .lb-btn--primary:hover {
    background: transparent;
    color: {{ section.settings.accent_color }};
  }
  .lb-btn--ghost {
    background: transparent;
    color: {{ section.settings.text_color }};
    border-color: rgba(255,255,255,0.35);
  }
  .lb-btn--ghost:hover {
    border-color: {{ section.settings.accent_color }};
    color: {{ section.settings.accent_color }};
  }

  /* SCROLL INDICATOR */
  .lb-hero__scroll {
    position: absolute;
    bottom: 32px;
    left: 60px;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    opacity: 0.5;
  }
  .lb-hero__scroll-line {
    width: 1px;
    height: 48px;
    background: {{ section.settings.text_color }};
    animation: lb-scroll-pulse 2s ease-in-out infinite;
  }
  .lb-hero__scroll span {
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: {{ section.settings.text_color }};
    writing-mode: vertical-rl;
  }
  .lb-hero__text-band {
    position: absolute;
    left: 0;
    right: 0;
    z-index: 1;
    pointer-events: none;
    top: 50%;
    transform: translateY(-50%);
    width: 100%;
    transition: opacity 0.3s ease, height 0.3s ease;
  }

  @keyframes lb-scroll-pulse {
    0%, 100% { opacity: 0.25; transform: scaleY(0.8); }
    50% { opacity: 1; transform: scaleY(1); }
  }

  @media (max-width: 768px) {
    .lb-hero__content { padding: {{ section.settings.padding_v | divided_by: 1.5 | round }}px 24px; }
    .lb-hero__scroll { left: 24px; }
    .lb-btn { padding: 14px 28px; }
  }
</style>

{% schema %}
{
  "name": "LB Hero",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Background" },
    { "type": "image_picker", "id": "bg_image", "label": "Background Image" },
    { "type": "header", "content": "Text Band Overlay (Dark Theme)" },
    { "type": "checkbox", "id": "show_text_band", "label": "Show Text Band", "default": true },
    { "type": "color", "id": "text_band_color", "label": "Band Colour", "default": "#000000" },
    { "type": "range", "id": "text_band_opacity", "label": "Band Opacity", "min": 0, "max": 100, "step": 5, "default": 35, "unit": "%" },
    { "type": "select", "id": "text_band_height", "label": "Band Height", "options": [
      { "value": "60px", "label": "Narrow (60px)" },
      { "value": "100px", "label": "Medium (100px)" },
      { "value": "140px", "label": "Tall (140px)" },
      { "value": "200px", "label": "Extra Tall (200px)" }
    ], "default": "100px" },
    { "type": "checkbox", "id": "show_overlay", "label": "Show Overlay", "default": true },
    { "type": "color", "id": "overlay_color", "label": "Overlay Colour", "default": "#000000" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay Opacity", "min": 0, "max": 90, "step": 5, "default": 55, "unit": "%" },

    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow Text", "default": "If Not Unique, Why Bother" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Street Artist." },
    { "type": "text", "id": "heading_em", "label": "Heading Italic Part", "default": "Digital Creator." },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Graffiti murals, digital art, and creative assets born from 16 years of aerosol culture in Cape Town." },

    { "type": "header", "content": "Buttons" },
    { "type": "text", "id": "btn1_label", "label": "Button 1 Label", "default": "Shop the Collection" },
    { "type": "url", "id": "btn1_url", "label": "Button 1 URL" },
    { "type": "text", "id": "btn2_label", "label": "Button 2 Label", "default": "Commission Inquiry" },
    { "type": "url", "id": "btn2_url", "label": "Button 2 URL" },

    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "content_align", "label": "Content Alignment", "options": [
      { "value": "left", "label": "Left" },
      { "value": "center", "label": "Center" },
      { "value": "right", "label": "Right" }
    ], "default": "left" },
    { "type": "range", "id": "min_height", "label": "Minimum Height", "min": 300, "max": 1000, "step": 50, "default": 750, "unit": "px" },
    { "type": "range", "id": "padding_v", "label": "Vertical Padding", "min": 40, "max": 200, "step": 10, "default": 120, "unit": "px" },
    { "type": "range", "id": "content_max_width", "label": "Content Max Width", "min": 400, "max": 1200, "step": 50, "default": 700, "unit": "px" },

    { "type": "header", "content": "Scroll Indicator" },
    { "type": "checkbox", "id": "show_scroll_indicator", "label": "Show Scroll Indicator", "default": true },
    { "type": "text", "id": "scroll_label", "label": "Scroll Label", "default": "Scroll" },

    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "text_color", "label": "Heading & Text Colour", "default": "#FFFFFF" },
    { "type": "color", "id": "subtext_color", "label": "Subtext Colour", "default": "#AAAAAA" },
    { "type": "color", "id": "accent_color", "label": "Accent Colour", "default": "#7DD8E8" }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "settings": {
        "heading": "Your Brand.",
        "heading_em": "Your Story.",
        "eyebrow": "Welcome",
        "subtext": "Tell your story here. Add a background image and make it yours.",
        "btn1_label": "Shop Now",
        "btn2_label": "Learn More"
      }
    }
  ]
}
{% endschema %}
