{%- assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0 -%}

<section
  class="lb-hero"
  style="
    min-height: {{ section.settings.min_height }}px;
    {% if section.settings.bg_color != blank %}background-color: {{ section.settings.bg_color }};{% endif %}
  "
>

  {%- comment -%} BACKGROUND {%- endcomment -%}
  {% if section.settings.bg_image != blank %}
    <div class="lb-hero__bg">
      {{ section.settings.bg_image | image_url: width: 1920 | image_tag:
        loading: 'eager',
        fetchpriority: 'high',
        class: 'lb-hero__bg-img',
        alt: section.settings.heading
      }}
    </div>
  {% endif %}

  {% if section.settings.show_overlay %}
    <div
      class="lb-hero__overlay"
      style="background:{{ section.settings.overlay_color }};opacity:{{ overlay_opacity }};"
    ></div>
  {% endif %}

  {%- comment -%} CONTENT {%- endcomment -%}
  <div class="lb-hero__content lb-hero__content--{{ section.settings.content_align }}">

    {% if section.settings.eyebrow != blank %}
      <span class="lb-hero__eyebrow">{{ section.settings.eyebrow }}</span>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h1 class="lb-hero__heading">
        {{ section.settings.heading }}
        {% if section.settings.heading_em != blank %}
          <em>{{ section.settings.heading_em }}</em>
        {% endif %}
      </h1>
    {% endif %}

    {% if section.settings.subtext != blank %}
      <p class="lb-hero__subtext">{{ section.settings.subtext }}</p>
    {% endif %}

    {% if section.settings.btn1_label != blank or section.settings.btn2_label != blank %}
      <div class="lb-hero__btns">
        {% if section.settings.btn1_label != blank %}
          <a href="{{ section.settings.btn1_url }}" class="lb-btn lb-btn--primary">
            {{ section.settings.btn1_label }}
          </a>
        {% endif %}
        {% if section.settings.btn2_label != blank %}
          <a href="{{ section.settings.btn2_url }}" class="lb-btn lb-btn--ghost">
            {{ section.settings.btn2_label }}
          </a>
        {% endif %}
      </div>
    {% endif %}

  </div>

  {% if section.settings.show_scroll_indicator %}
    <div class="lb-hero__scroll">
      <div class="lb-hero__scroll-line"></div>
      <span>{{ section.settings.scroll_label | default: 'Scroll' }}</span>
    </div>
  {% endif %}

</section>

<style>
  .lb-hero {
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
    width: 100%;
  }
  .lb-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
