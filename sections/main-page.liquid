<section class="lb-page-main">

  <div class="lb-page-header">
    {% if section.settings.show_eyebrow and section.settings.eyebrow_text != blank %}
      <span class="eyebrow">{{ section.settings.eyebrow_text }}</span>
    {% endif %}
    <h1 class="lb-page-title">{{ page.title }}</h1>
    {% if section.settings.show_divider %}
      <div class="lb-page-divider"></div>
    {% endif %}
  </div>

  {% if page.content != blank %}
    <div class="lb-page-content rte">
      {{ page.content }}
    </div>
  {% endif %}

</section>

<style>
  .lb-page-main {
    max-width: {{ section.settings.content_width }}px;
    margin: 0 auto;
    padding: {{ section.settings.padding_top }}px 2rem {{ section.settings.padding_bottom }}px;
  }

  .lb-page-header {
    text-align: {{ section.settings.heading_align }};
    margin-bottom: 2.5rem;
  }

  .lb-page-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0.5rem 0 0;
    color: var(--cream, #f0ede6);
  }

  .lb-page-divider {
    width: 60px;
    height: 3px;
    background: var(--blue, #3b82f6);
    margin: {% if section.settings.heading_align == 'center' %}1.5rem auto 0{% else %}1.5rem 0 0{% endif %};
    border-radius: 2px;
  }

  .lb-page-content {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--cream, #f0ede6);
    text-align: {{ section.settings.content_align }};
  }

  .lb-page-content h2 { font-size: clamp(1.4rem, 3vw, 2rem); margin: 2rem 0 0.75rem; }
  .lb-page-content h3 { font-size: clamp(1.1rem, 2.5vw, 1.5rem); margin: 1.5rem 0 0.5rem; }
  .lb-page-content p { margin: 0 0 1.25rem; }
  .lb-page-content a { color: var(--blue, #3b82f6); text-decoration: underline; }
  .lb-page-content ul, .lb-page-content ol { padding-left: 1.5rem; margin-bottom: 1.25rem; }
  .lb-page-content li { margin-bottom: 0.4rem; }
  .lb-page-content img { max-width: 100%; border-radius: 8px; margin: 1rem 0; }
  .lb-page-content blockquote {
    border-left: 3px solid var(--blue, #3b82f6);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--concrete, #888);
  }
</style>

{% schema %}
{
  "name": "Main Page",
  "settings": [
    {
      "type": "header",
      "content": "Page Header"
    },
    {
      "type": "select",
      "id": "heading_align",
      "label": "Heading Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "show_eyebrow",
      "label": "Show Eyebrow Text",
      "default": false
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow Text"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show Accent Divider",
      "default": true
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Content Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Max Content Width",
      "min": 600,
      "max": 1400,
      "step": 50,
      "default": 900,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding",
      "min": 20,
      "max": 160,
      "step": 10,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding",
      "min": 20,
      "max": 160,
      "step": 10,
      "default": 100,
      "unit": "px"
    }
  ]
}
{% endschema %}
