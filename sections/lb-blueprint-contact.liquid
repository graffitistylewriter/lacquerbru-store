<section class="lb-blueprint-page lb-blueprint-page--contact">

<div class="ct-body">
  <div class="ct-info">
    {% if section.settings.info_label != blank %}<span class="section-label">{{ section.settings.info_label }}</span>{% endif %}
    <h2 class="section-h2">{{ section.settings.info_heading }}</h2>
    <p>{{ section.settings.info_body }}</p>
    {% if settings.contact_email != blank %}
      <div class="cinfo-item">
        <span class="cinfo-icon">Email</span>
        <div>
          <span class="cinfo-label">Email</span>
          <div class="cinfo-val"><a href="mailto:{{ settings.contact_email }}">{{ settings.contact_email }}</a></div>
        </div>
      </div>
    {% endif %}
    {% if settings.contact_phone != blank %}
      <div class="cinfo-item">
        <span class="cinfo-icon">Phone</span>
        <div>
          <span class="cinfo-label">Phone &amp; WhatsApp</span>
          <div class="cinfo-val">
            <a href="tel:{{ settings.contact_phone | remove: ' ' }}">{{ settings.contact_phone }}</a>
            {% if section.settings.phone_hours != blank %}<br><span style="font-size:12px;opacity:0.6;">{{ section.settings.phone_hours }}</span>{% endif %}
          </div>
        </div>
      </div>
    {% endif %}
    {% if section.settings.location_text != blank %}
      <div class="cinfo-item">
        <span class="cinfo-icon">Location</span>
        <div>
          <span class="cinfo-label">Location</span>
          <div class="cinfo-val">{{ section.settings.location_text }}</div>
        </div>
      </div>
    {% endif %}
    {% if section.settings.response_time != blank %}
      <div class="cinfo-item">
        <span class="cinfo-icon">Time</span>
        <div>
          <span class="cinfo-label">Response Time</span>
          <div class="cinfo-val">{{ section.settings.response_time }}</div>
        </div>
      </div>
    {% endif %}
    {% if section.settings.show_social and settings.instagram != blank %}
      <div class="ct-social">
        <h4>{{ section.settings.social_heading }}</h4>
        <div class="soc-links">
          <a href="{{ settings.instagram }}" target="_blank" class="soc-link">
            <span></span>
            <div>
              <div class="soc-handle">Instagram</div>
              <div class="soc-desc">{{ section.settings.instagram_desc }}</div>
            </div>
          </a>
          {% if section.settings.instagram2_handle != blank %}
            <a href="{{ section.settings.instagram2_url }}" target="_blank" class="soc-link">
              <span></span>
              <div>
                <div class="soc-handle">{{ section.settings.instagram2_handle }}</div>
                <div class="soc-desc">{{ section.settings.instagram2_desc }}</div>
              </div>
            </a>
          {% endif %}
        </div>
      </div>
    {% endif %}
  </div>

  {% form 'contact', class: 'ct-form' %}
    <div class="ct-form-title">{{ section.settings.form_title }}</div>
    <p class="ct-form-sub">{{ section.settings.form_subtext }}</p>
    <div class="fg-row">
      <div class="fgrp"><label>First Name *</label><input type="text" name="contact[first_name]" placeholder="Your first name" required></div>
      <div class="fgrp"><label>Last Name *</label><input type="text" name="contact[last_name]" placeholder="Your last name" required></div>
    </div>
    <div class="fgrp"><label>Email Address *</label><input type="email" name="contact[email]" placeholder="your@email.com" required></div>
    <div class="fgrp"><label>Subject *</label>
      <select name="contact[subject]">
        <option value="">What is your message about?</option>
        <option>Commission Inquiry</option>
        <option>Digital Products</option>
        <option>Brush Packs</option>
        <option>Print or Canvas Order</option>
        <option>General Question</option>
        <option>Collaboration</option>
        <option>Press or Media</option>
        <option>Other</option>
      </select>
    </div>
    <div class="fgrp"><label>Your Message *</label><textarea name="contact[body]" placeholder="{{ section.settings.message_placeholder | default: 'Tell us what is on your mind...' }}" required></textarea></div>
    <button class="form-sbmt" type="submit">{{ section.settings.form_btn_label | default: 'Send Message' }}</button>
  {% endform %}
</div>

</section>

{% schema %}
{
  "name": "LB Blueprint Contact",
  "settings": [
    { "type": "header", "content": "Contact Info Panel" },
    { "type": "text", "id": "info_label", "label": "Section Label", "default": "Contact" },
    { "type": "text", "id": "info_heading", "label": "Heading", "default": "Let's Talk" },
    { "type": "textarea", "id": "info_body", "label": "Intro Text", "default": "Whether you have a project in mind, a question about our work, or just want to connect — we would love to hear from you." },
    { "type": "text", "id": "phone_hours", "label": "Phone Hours", "default": "Available Mon–Fri, 8am–6pm SAST" },
    { "type": "text", "id": "location_text", "label": "Location", "default": "Cape Town, Western Cape, South Africa" },
    { "type": "text", "id": "response_time", "label": "Response Time", "default": "We respond to all messages within 24 to 48 hours." },
    { "type": "header", "content": "Social Links" },
    { "type": "checkbox", "id": "show_social", "label": "Show Social Links", "default": true },
    { "type": "text", "id": "social_heading", "label": "Social Section Heading", "default": "Follow the Work" },
    { "type": "text", "id": "instagram_desc", "label": "Instagram Description", "default": "Studio work, murals, and new releases" },
    { "type": "text", "id": "instagram2_handle", "label": "Second Instagram Handle" },
    { "type": "url", "id": "instagram2_url", "label": "Second Instagram URL" },
    { "type": "text", "id": "instagram2_desc", "label": "Second Instagram Description" },
    { "type": "header", "content": "Contact Form" },
    { "type": "text", "id": "form_title", "label": "Form Title", "default": "Send a Message" },
    { "type": "textarea", "id": "form_subtext", "label": "Form Subtext", "default": "Use this form for general inquiries, questions about our services, digital products, or anything else." },
    { "type": "text", "id": "message_placeholder", "label": "Message Placeholder", "default": "Tell us what's on your mind..." },
    { "type": "text", "id": "form_btn_label", "label": "Submit Button Label", "default": "Send Message" }
  ]
}
{% endschema %}
