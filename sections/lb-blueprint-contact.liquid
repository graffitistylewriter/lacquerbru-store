<section class="lb-blueprint-page lb-blueprint-page--contact">

<div class="ct-hero">
  <div class="ct-hero-bg"></div>
  <div class="ct-hero-ol"></div>
  <div class="ct-hero-c">
    <h1 class="ct-title">{{ section.settings.hero_title }}</h1>
    <p class="ct-tag">{{ section.settings.hero_tagline }}</p>
  </div>
</div>

<div class="ct-body">
  <div class="ct-info">
    <h2 class="section-h2">{{ section.settings.info_heading }}</h2>
    <p>{{ section.settings.info_body }}</p>
  </div>
  {% form 'contact', class: 'ct-form' %}
    <div class="fgrp"><label>Email *</label><input type="email" name="contact[email]" required></div>
    <div class="fgrp"><label>Message *</label><textarea name="contact[body]" required></textarea></div>
    <button class="form-sbmt" type="submit">Send Message</button>
  {% endform %}
</div>

</section>
{% schema %}
{
  "name": "LB Blueprint Contact",
  "settings": [
    { "type": "text", "id": "hero_title", "label": "Hero Title", "default": "Get In Touch" },
    { "type": "text", "id": "hero_tagline", "label": "Hero Tagline" },
    { "type": "text", "id": "info_heading", "label": "Heading", "default": "Let's Talk" },
    { "type": "textarea", "id": "info_body", "label": "Intro Text" }
  ]
}
{% endschema %}
