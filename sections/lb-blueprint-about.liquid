<section class="lb-blueprint-page lb-blueprint-page--about">

<div class="abt-intro">
  {% if section.settings.intro_image != blank %}
    <div class="abt-img">
      {{ section.settings.intro_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: section.settings.intro_heading }}
    </div>
  {% else %}
    <div class="abt-img"></div>
  {% endif %}
  <div class="abt-txt">
    {% if section.settings.intro_label != blank %}<span class="section-label">{{ section.settings.intro_label }}</span>{% endif %}
    <h2 class="section-h2">{{ section.settings.intro_heading }}</h2>
    <div>{{ section.settings.intro_body }}</div>
  </div>
</div>

<div class="stats-bar">
  <div class="stat-item"><span class="stat-n">{{ section.settings.stat1_number }}</span><span class="stat-l">{{ section.settings.stat1_label }}</span></div>
  <div class="stat-item"><span class="stat-n">{{ section.settings.stat2_number }}</span><span class="stat-l">{{ section.settings.stat2_label }}</span></div>
  <div class="stat-item"><span class="stat-n">{{ section.settings.stat3_number }}</span><span class="stat-l">{{ section.settings.stat3_label }}</span></div>
  <div class="stat-item"><span class="stat-n">{{ section.settings.stat4_number }}</span><span class="stat-l">{{ section.settings.stat4_label }}</span></div>
</div>

<section class="abt-services">
  {% if section.settings.services_label != blank %}<span class="section-label">{{ section.settings.services_label }}</span>{% endif %}
  <h2 class="section-h2">{{ section.settings.services_heading }}</h2>
  <p class="section-sub">{{ section.settings.services_subtext }}</p>
  <div class="srv-grid">
    {% for i in (1..6) %}
      {% assign name_key = 'service_' | append: i | append: '_name' %}
      {% assign desc_key = 'service_' | append: i | append: '_desc' %}
      {% assign name_val = section.settings[name_key] %}
      {% assign desc_val = section.settings[desc_key] %}
      {% if name_val != blank %}
        <div class="srv-card">
          <span class="srv-icon"></span>
          <div class="srv-name">{{ name_val }}</div>
          <p class="srv-desc">{{ desc_val }}</p>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

<div class="aerosoul-sec">
  <div class="aerosoul-bg"></div>
  <div class="aerosoul-c">
    <div class="aerosoul-word">{{ section.settings.aerosoul_word }}</div>
    <div class="aerosoul-def">{{ section.settings.aerosoul_body }}</div>
    {% if section.settings.aerosoul_btn_label != blank %}
      <a href="{{ section.settings.aerosoul_btn_url }}" class="btn-blue">{{ section.settings.aerosoul_btn_label }}</a>
    {% endif %}
  </div>
</div>

<div class="abt-cta">
  <h2>{{ section.settings.cta_heading }}</h2>
  <p>{{ section.settings.cta_subtext }}</p>
  {% if section.settings.cta_btn_label != blank %}
    <a href="{{ section.settings.cta_btn_url }}" class="btn-primary">{{ section.settings.cta_btn_label }}</a>
  {% endif %}
</div>

</section>

{% schema %}
{
  "name": "LB Blueprint About",
  "settings": [
    { "type": "header", "content": "Intro Section" },
    { "type": "image_picker", "id": "intro_image", "label": "Intro Image" },
    { "type": "text", "id": "intro_label", "label": "Section Label", "default": "The Studio" },
    { "type": "text", "id": "intro_heading", "label": "Heading", "default": "Where Urban Expression Meets Premium Craft" },
    { "type": "richtext", "id": "intro_body", "label": "Body Text" },
    { "type": "header", "content": "Stats Bar" },
    { "type": "text", "id": "stat1_number", "label": "Stat 1 Number", "default": "16+" },
    { "type": "text", "id": "stat1_label", "label": "Stat 1 Label", "default": "Years of Experience" },
    { "type": "text", "id": "stat2_number", "label": "Stat 2 Number", "default": "3+" },
    { "type": "text", "id": "stat2_label", "label": "Stat 2 Label", "default": "Countries" },
    { "type": "text", "id": "stat3_number", "label": "Stat 3 Number", "default": "100+" },
    { "type": "text", "id": "stat3_label", "label": "Stat 3 Label", "default": "Projects Completed" },
    { "type": "text", "id": "stat4_number", "label": "Stat 4 Number", "default": "∞" },
    { "type": "text", "id": "stat4_label", "label": "Stat 4 Label", "default": "Surfaces Transformed" },
    { "type": "header", "content": "Services Section" },
    { "type": "text", "id": "services_label", "label": "Section Label", "default": "What We Do" },
    { "type": "text", "id": "services_heading", "label": "Heading", "default": "Services & Disciplines" },
    { "type": "textarea", "id": "services_subtext", "label": "Subtext", "default": "Every service is rooted in the same philosophy — authentic expression executed with precision and professionalism." },
    { "type": "text", "id": "service_1_name", "label": "Service 1 Name", "default": "Mural Painting" },
    { "type": "textarea", "id": "service_1_desc", "label": "Service 1 Description", "default": "Large scale exterior and interior murals for private residences, commercial properties, hospitality venues, public spaces, and developments." },
    { "type": "text", "id": "service_2_name", "label": "Service 2 Name", "default": "Illustration & Design" },
    { "type": "textarea", "id": "service_2_desc", "label": "Service 2 Description", "default": "Custom illustration, graphic design, branding visuals, and digital creative assets for businesses, events, and personal projects." },
    { "type": "text", "id": "service_3_name", "label": "Service 3 Name", "default": "Digital Art & Assets" },
    { "type": "textarea", "id": "service_3_desc", "label": "Service 3 Description", "default": "Procreate brush packs, digital texture packs, and downloadable creative assets built by a working artist for working artists." },
    { "type": "text", "id": "service_4_name", "label": "Service 4 Name", "default": "Textured Finishes" },
    { "type": "textarea", "id": "service_4_desc", "label": "Service 4 Description", "default": "High-end decorative surface finishing and textured feature walls using advanced airless spray application systems." },
    { "type": "text", "id": "service_5_name", "label": "Service 5 Name", "default": "Commercial Painting" },
    { "type": "textarea", "id": "service_5_desc", "label": "Service 5 Description", "default": "Professional surface finishing for driveways, roofs, garage doors, exterior walls, and large-scale property transformations." },
    { "type": "text", "id": "service_6_name", "label": "Service 6 Name", "default": "Live Event Painting" },
    { "type": "textarea", "id": "service_6_desc", "label": "Service 6 Description", "default": "Live painting at events, activations, exhibitions, and brand experiences. A performance as compelling as the finished piece." },
    { "type": "header", "content": "Aerosoul Section" },
    { "type": "text", "id": "aerosoul_word", "label": "Feature Word", "default": "Aerosoul" },
    { "type": "richtext", "id": "aerosoul_body", "label": "Aerosoul Description" },
    { "type": "text", "id": "aerosoul_btn_label", "label": "Button Label", "default": "Experience the Work" },
    { "type": "url", "id": "aerosoul_btn_url", "label": "Button URL" },
    { "type": "header", "content": "Bottom CTA" },
    { "type": "text", "id": "cta_heading", "label": "CTA Heading", "default": "Ready to Create Something Unique?" },
    { "type": "text", "id": "cta_subtext", "label": "CTA Subtext", "default": "Every great project starts with a conversation. Tell us what you have in mind." },
    { "type": "text", "id": "cta_btn_label", "label": "CTA Button Label", "default": "Start a Commission Inquiry" },
    { "type": "url", "id": "cta_btn_url", "label": "CTA Button URL" }
  ]
}
{% endschema %}
