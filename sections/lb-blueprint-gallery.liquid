{%- assign gallery_items = shop.metaobjects.lb_gallery_item.values -%}
{%- assign all_projects = shop.metaobjects.project.values -%}

<section class="lb-blueprint-page lb-blueprint-page--gallery">

<style>
  #lb-lightbox-img-wrap::after {
    content: '{{ section.settings.watermark_text | escape }}';
    position: absolute;
    {%- if section.settings.watermark_position == 'top' -%}top:0.75rem;bottom:auto;{%- else -%}bottom:0.75rem;top:auto;{%- endif -%}
    left: 0; right: 0; width: 100%;
    text-align: {{ section.settings.watermark_align }};
    color: rgba(255,255,255,{{ section.settings.watermark_text_opacity | divided_by: 100.0 }});
    font-size: 0.85rem; letter-spacing: 0.12em; text-transform: uppercase;
    z-index: 3; pointer-events: none; padding: 0 1rem; box-sizing: border-box;
  }
</style>

  <div class="gal-intro">
    {%- if section.settings.intro_label != blank -%}
      <span class="section-label">{{ section.settings.intro_label }}</span>
    {%- endif -%}
    <p>{{ section.settings.intro_text }}</p>
  </div>

  <div class="gal-masonry" id="gal-masonry">

    {%- for item in gallery_items -%}

      {%- assign img_url = item.image.value | image_url: width: 1200 -%}
      {%- assign item_title = item.title.value -%}
      {%- assign cats = item.categories.value -%}
      {%- assign wide = item.wide.value -%}
      {%- assign project_handle = item.project_handle.value -%}

      {%- if img_url != blank -%}

        {%- assign cat_slugs = '' -%}
        {%- for cat in cats -%}
          {%- assign slug = cat | downcase | replace: ' ', '-' -%}
          {%- assign cat_slugs = cat_slugs | append: slug | append: ' ' -%}
        {%- endfor -%}

        {%- assign linked_project = nil -%}
        {%- if project_handle != blank -%}
          {%- for p in all_projects -%}
            {%- if p.system.handle == project_handle -%}
              {%- assign linked_project = p -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}

        <div
          class="gal-item{% if wide == true %} wide{% endif %}"
          data-cats="{{ cat_slugs | strip }}"
          {% if linked_project != nil %}data-project-handle="{{ project_handle }}"{% endif %}
        >
          <img
            src="{{ img_url }}"
            alt="{{ item_title | escape }}"
            loading="lazy"
          >
          <div class="gal-item-ov">
            {%- if item_title != blank -%}
              <div class="gal-item-title">{{ item_title }}</div>
            {%- endif -%}
            {%- if cats.size > 0 -%}
              <div class="gal-item-cat">{{ cats | join: ' · ' }}</div>
            {%- endif -%}
            {%- if linked_project != nil -%}
              <div class="gal-item-project-cta">View Project →</div>
            {%- endif -%}
          </div>
        </div>

        {%- if linked_project != nil -%}
          <script type="application/json" id="project-data-{{ project_handle | replace: '-', '_' }}">
          {
            "handle": {{ project_handle | json }},
            "title": {{ linked_project.title.value | json }},
            "category": {{ linked_project.category.value | default: '' | json }},
            "year": {{ linked_project.completion_date.value | date: "%Y" | json }},
            "client": {{ linked_project.client.value | default: '' | json }},
            "summary": {{ linked_project.summary.value | default: '' | json }},
            "story": {{ linked_project.story.value | default: '' | json }},
            "featured": {{ linked_project.featured.value | json }},
            "hero": {{ linked_project.featured_image.value | image_url: width: 1600 | json }},
            "gallery": [
              {%- for gimg in linked_project.gallery.value -%}
                {{ gimg | image_url: width: 1200 | json }}{% unless forloop.last %},{% endunless %}
              {%- endfor -%}
            ]
          }
          </script>
        {%- endif -%}

      {%- endif -%}

    {%- endfor -%}

  </div>

  <div class="gal-cta">
    {%- if section.settings.cta_label != blank -%}
      <span class="section-label">{{ section.settings.cta_label }}</span>
    {%- endif -%}
    <h2 class="section-h2">{{ section.settings.cta_heading }}</h2>
    <p>{{ section.settings.cta_subtext }}</p>
    {%- if section.settings.cta_btn_label != blank -%}
      <a href="{{ section.settings.cta_btn_url }}" class="btn-primary">{{ section.settings.cta_btn_label }}</a>
    {%- endif -%}
  </div>

  <div id="lb-lightbox" style="display:none;">
    <div id="lb-lightbox-overlay"></div>
    <div id="lb-lightbox-inner">
      <button id="lb-lightbox-close">&#x2715;</button>
      <div id="lb-lightbox-img-wrap">
        <img id="lb-lightbox-img" src="" alt="" draggable="false">
        <div id="lb-lightbox-shield"></div>
        {%- if section.settings.watermark_logo != blank -%}
          <div id="lb-watermark-logo" style="position:absolute;z-index:4;pointer-events:none;padding:0.75rem;width:100%;
            {%- if section.settings.watermark_logo_position == 'top' -%}top:0;bottom:auto;{%- else -%}bottom:0;top:auto;{%- endif -%}
            {%- if section.settings.watermark_logo_align == 'left' -%}text-align:left;{%- elsif section.settings.watermark_logo_align == 'right' -%}text-align:right;{%- else -%}text-align:center;{%- endif -%}">
            <img
              src="{{ section.settings.watermark_logo | image_url: width: 200 }}"
              width="{{ section.settings.watermark_logo_width }}"
              alt="Watermark"
              style="opacity:{{ section.settings.watermark_logo_opacity | divided_by: 100.0 }};"
            >
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

  <div id="lb-project-lightbox" aria-hidden="true">
    <div id="lb-project-lightbox-backdrop"></div>
    <div id="lb-project-lightbox-panel">
      <button id="lb-project-lightbox-close" aria-label="Close">✕</button>
      <div id="lb-project-lightbox-content">
        <div id="lbpl-hero">
          <img id="lbpl-hero-img" src="" alt="">
          <div id="lbpl-hero-overlay"></div>
          <div id="lbpl-hero-content">
            <p id="lbpl-kicker"></p>
            <h2 id="lbpl-title"></h2>
            <p id="lbpl-summary"></p>
          </div>
        </div>
        <div id="lbpl-meta-strip">
          <div class="lbpl-meta-item" id="lbpl-meta-client-wrap">
            <span class="lbpl-meta-label">Client</span>
            <span class="lbpl-meta-value" id="lbpl-meta-client"></span>
          </div>
          <div class="lbpl-meta-item" id="lbpl-meta-type-wrap">
            <span class="lbpl-meta-label">Type</span>
            <span class="lbpl-meta-value" id="lbpl-meta-type"></span>
          </div>
          <div class="lbpl-meta-item" id="lbpl-meta-year-wrap">
            <span class="lbpl-meta-label">Year</span>
            <span class="lbpl-meta-value" id="lbpl-meta-year"></span>
          </div>
        </div>
        <div id="lbpl-story-wrap">
          <p class="lbpl-section-label">Project Story</p>
          <div id="lbpl-story"></div>
        </div>
        <div id="lbpl-gallery-wrap">
          <p class="lbpl-section-label">Project Gallery</p>
          <div id="lbpl-gallery-grid"></div>
        </div>
        <div id="lbpl-footer">
          <a id="lbpl-full-link" href="#">View Full Project Page →</a>
        </div>
      </div>
    </div>
  </div>

</section>

<style>
  .gal-masonry { display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; }
  @media (min-width: 768px) { .gal-masonry { grid-template-columns: repeat(3, 1fr); } }
  .gal-item { overflow: hidden; position: relative; cursor: pointer; aspect-ratio: 4/3; }
  .gal-item.wide { grid-column: span 2; aspect-ratio: 16/7; }
  .gal-item img { display: block; width: 100%; height: 100%; object-fit: cover; }
  .gal-item.hidden { display: none; }
  .gal-item-ov { position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: flex-end; padding: 1rem; background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 60%); opacity: 0; transition: opacity 0.25s ease; }
  .gal-item:hover .gal-item-ov { opacity: 1; }
  .gal-item-title { font-size: 0.8rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #fff; }
  .gal-item-cat { font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: #aaa; margin-top: 2px; }
  .gal-item-project-cta { font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: #7dd8e8; margin-top: 6px; font-weight: 600; }
  .gal-filters { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-bottom: 2.5rem; }
  .gal-filter { background: transparent; border: 1px solid currentColor; color: inherit; cursor: pointer; font-family: inherit; font-size: 0.8rem; letter-spacing: 0.1em; padding: 0.5rem 1.25rem; text-transform: uppercase; transition: background 0.2s, color 0.2s; }
  .gal-filter.active, .gal-filter:hover { background: currentColor; }
  .gal-filter.active span, .gal-filter:hover span { color: var(--color-background, #0a0a0a); }
  #lb-lightbox { position: fixed; inset: 0; z-index: 9999; display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.3s ease; }
  #lb-lightbox.active { display: flex !important; opacity: 1; }
  #lb-lightbox-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.92); }
  #lb-lightbox-inner { position: relative; z-index: 1; max-width: 90vw; max-height: 90vh; }
  #lb-lightbox-img-wrap { position: relative; }
  #lb-lightbox-img { display: block; max-width: 90vw; max-height: 85vh; object-fit: contain; user-select: none; pointer-events: none; }
  #lb-lightbox-shield { position: absolute; inset: 0; z-index: 2; }
  #lb-lightbox-close { position: absolute; top: -2.5rem; right: 0; background: none; border: none; color: white; font-size: 1.5rem; cursor: pointer; }
  #lb-project-lightbox { position: fixed; inset: 0; z-index: 10000; display: flex; align-items: stretch; justify-content: flex-end; opacity: 0; pointer-events: none; transition: opacity 0.3s ease; }
  #lb-project-lightbox.is-open { opacity: 1; pointer-events: all; }
  #lb-project-lightbox-backdrop { position: absolute; inset: 0; background: rgba(0,0,0,0.85); }
  #lb-project-lightbox-panel { position: relative; z-index: 1; width: min(780px, 100vw); background: #0a0a0a; overflow-y: auto; transform: translateX(100%); transition: transform 0.4s cubic-bezier(0.16,1,0.3,1); }
  #lb-project-lightbox.is-open #lb-project-lightbox-panel { transform: translateX(0); }
  #lb-project-lightbox-close { position: sticky; top: 0; float: right; margin: 16px 16px 0 0; background: none; border: none; color: #fff; font-size: 18px; cursor: pointer; z-index: 10; transition: color 0.2s; }
  #lb-project-lightbox-close:hover { color: #7dd8e8; }
  #lb-project-lightbox-content { padding-bottom: 60px; }
  #lbpl-hero { position: relative; height: 55vh; overflow: hidden; }
  #lbpl-hero-img { width: 100%; height: 100%; object-fit: cover; display: block; }
  #lbpl-hero-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(10,10,10,0) 30%, rgba(10,10,10,0.95) 100%); }
  #lbpl-hero-content { position: absolute; bottom: 0; left: 0; right: 0; padding: 32px; }
  #lbpl-kicker { font-size: 9px; letter-spacing: 0.22em; text-transform: uppercase; color: #7dd8e8; margin: 0 0 8px; }
  #lbpl-title { font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 900; text-transform: uppercase; letter-spacing: 0.04em; color: #fff; margin: 0 0 10px; line-height: 1.1; }
  #lbpl-summary { font-size: 13px; color: #aaa; line-height: 1.6; margin: 0; }
  #lbpl-meta-strip { display: flex; gap: 32px; flex-wrap: wrap; padding: 20px 32px; border-bottom: 1px solid #1e1e1e; background: #111; }
  .lbpl-meta-item { display: flex; flex-direction: column; gap: 3px; }
  .lbpl-meta-label { font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: #555; }
  .lbpl-meta-value { font-size: 12px; font-weight: 600; color: #fff; letter-spacing: 0.04em; }
  #lbpl-story-wrap { padding: 40px 32px 0; }
  .lbpl-section-label { font-size: 9px; letter-spacing: 0.22em; text-transform: uppercase; color: #7dd8e8; margin: 0 0 16px; }
  #lbpl-story { font-size: 13px; color: #ccc; line-height: 1.9; }
  #lbpl-gallery-wrap { padding: 40px 32px 0; }
  #lbpl-gallery-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 16px; }
  #lbpl-gallery-grid img { width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block; }
  #lbpl-gallery-grid img:first-child { grid-column: 1/-1; aspect-ratio: 16/7; }
  #lbpl-footer { padding: 32px 32px 0; }
  #lbpl-full-link { font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: #555; text-decoration: none; transition: color 0.2s; }
  #lbpl-full-link:hover { color: #7dd8e8; }
</style>

<script>
(function () {
  var filters = document.querySelectorAll('.gal-filter');
  var items = document.querySelectorAll('#gal-masonry .gal-item');
  filters.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var selected = this.dataset.filter;
      filters.forEach(function (b) { b.classList.remove('active'); });
      this.classList.add('active');
      items.forEach(function (item) {
        if (selected === 'all') {
          item.classList.remove('hidden');
        } else {
          var cats = (item.dataset.cats || '').split(' ');
          item.classList.toggle('hidden', cats.indexOf(selected) === -1);
        }
      });
    });
  });

  var lightbox = document.getElementById('lb-lightbox');
  var lbImg = document.getElementById('lb-lightbox-img');
  var lbClose = document.getElementById('lb-lightbox-close');
  var lbOverlay = document.getElementById('lb-lightbox-overlay');

  function openStandardLightbox(src, alt) {
    lbImg.src = src; lbImg.alt = alt;
    lightbox.style.display = 'flex';
    setTimeout(function () { lightbox.classList.add('active'); }, 10);
  }
  function closeStandardLightbox() {
    lightbox.classList.remove('active');
    setTimeout(function () { lightbox.style.display = 'none'; lbImg.src = ''; }, 300);
  }
  lbClose.addEventListener('click', closeStandardLightbox);
  lbOverlay.addEventListener('click', closeStandardLightbox);

  var plLightbox = document.getElementById('lb-project-lightbox');
  var plBackdrop = document.getElementById('lb-project-lightbox-backdrop');
  var plClose = document.getElementById('lb-project-lightbox-close');
  var plHeroImg = document.getElementById('lbpl-hero-img');
  var plKicker = document.getElementById('lbpl-kicker');
  var plTitle = document.getElementById('lbpl-title');
  var plSummary = document.getElementById('lbpl-summary');
  var plClient = document.getElementById('lbpl-meta-client');
  var plClientWrap = document.getElementById('lbpl-meta-client-wrap');
  var plType = document.getElementById('lbpl-meta-type');
  var plTypeWrap = document.getElementById('lbpl-meta-type-wrap');
  var plYear = document.getElementById('lbpl-meta-year');
  var plYearWrap = document.getElementById('lbpl-meta-year-wrap');
  var plStory = document.getElementById('lbpl-story');
  var plStoryWrap = document.getElementById('lbpl-story-wrap');
  var plGalleryGrid = document.getElementById('lbpl-gallery-grid');
  var plGalleryWrap = document.getElementById('lbpl-gallery-wrap');
  var plFullLink = document.getElementById('lbpl-full-link');

  function openProjectLightbox(handle) {
    var safeKey = handle.replace(/-/g, '_');
    var dataEl = document.getElementById('project-data-' + safeKey);
    if (!dataEl) return false;
    var data;
    try { data = JSON.parse(dataEl.textContent); } catch(e) { return false; }
    plHeroImg.src = data.hero || ''; plHeroImg.alt = data.title || '';
    plKicker.textContent = [data.category, data.year].filter(Boolean).join(' · ');
    plTitle.textContent = data.title || '';
    plSummary.textContent = data.summary || '';
    if (data.client) { plClient.textContent = data.client; plClientWrap.style.display = ''; } else { plClientWrap.style.display = 'none'; }
    if (data.category) { plType.textContent = data.category; plTypeWrap.style.display = ''; } else { plTypeWrap.style.display = 'none'; }
    if (data.year) { plYear.textContent = data.year; plYearWrap.style.display = ''; } else { plYearWrap.style.display = 'none'; }
    if (data.story) { plStory.innerHTML = data.story; plStoryWrap.style.display = ''; } else { plStoryWrap.style.display = 'none'; }
    plGalleryGrid.innerHTML = '';
    if (data.gallery && data.gallery.length > 0) {
      data.gallery.forEach(function (src) {
        var img = document.createElement('img');
        img.src = src; img.alt = data.title; img.loading = 'lazy';
        plGalleryGrid.appendChild(img);
      });
      plGalleryWrap.style.display = '';
    } else { plGalleryWrap.style.display = 'none'; }
    plFullLink.href = '/pages/project/' + handle;
    plLightbox.classList.add('is-open');
    plLightbox.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    document.getElementById('lb-project-lightbox-panel').scrollTop = 0;
    return true;
  }

  function closeProjectLightbox() {
    plLightbox.classList.remove('is-open');
    plLightbox.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  plClose.addEventListener('click', closeProjectLightbox);
  plBackdrop.addEventListener('click', closeProjectLightbox);

  document.querySelectorAll('.gal-item').forEach(function (item) {
    item.addEventListener('click', function () {
      var projectHandle = item.dataset.projectHandle;
      if (projectHandle) {
        openProjectLightbox(projectHandle);
      } else {
        var img = item.querySelector('img');
        openStandardLightbox(img.src, img.alt);
      }
    });
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      if (plLightbox.classList.contains('is-open')) closeProjectLightbox();
      else closeStandardLightbox();
    }
  });

  document.querySelectorAll('#gal-masonry .gal-item img').forEach(function (img) {
    img.addEventListener('contextmenu', function (e) { e.preventDefault(); });
    img.setAttribute('draggable', 'false');
  });
})();
</script>

{% schema %}
{
  "name": "Portfolio Gallery",
  "settings": [
    { "type": "header", "content": "Intro" },
    { "type": "text", "id": "intro_label", "label": "Section Label", "default": "The Work" },
    { "type": "textarea", "id": "intro_text", "label": "Intro Text", "default": "A portfolio of murals, digital art, and immersive visual work." },
    { "type": "header", "content": "Category Filters" },
    { "type": "textarea", "id": "filter_categories", "label": "Filter Categories (separate with |)", "default": "Commercial|Private|Freestyle|New Work", "info": "These must match the category names used in the Gallery Manager app." },
    { "type": "header", "content": "Bottom CTA" },
    { "type": "text", "id": "cta_label", "label": "CTA Label", "default": "Commission Your Own Piece" },
    { "type": "text", "id": "cta_heading", "label": "CTA Heading", "default": "See Something You Like?" },
    { "type": "textarea", "id": "cta_subtext", "label": "CTA Subtext", "default": "Every wall, canvas, and surface is an opportunity. Get in touch to discuss your project." },
    { "type": "text", "id": "cta_btn_label", "label": "CTA Button Label", "default": "Start a Commission" },
    { "type": "url", "id": "cta_btn_url", "label": "CTA Button URL" },
    { "type": "header", "content": "Watermark — Text" },
    { "type": "text", "id": "watermark_text", "label": "Watermark Text", "default": "© Lacquer Bru" },
    { "type": "select", "id": "watermark_align", "label": "Horizontal Alignment", "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ], "default": "right" },
    { "type": "select", "id": "watermark_position", "label": "Vertical Position", "options": [
        { "value": "top", "label": "Header" },
        { "value": "bottom", "label": "Footer" }
      ], "default": "bottom" },
    { "type": "number", "id": "watermark_text_opacity", "label": "Text Opacity (%)", "default": 45 },
    { "type": "header", "content": "Watermark — Logo" },
    { "type": "image_picker", "id": "watermark_logo", "label": "Logo Image" },
    { "type": "range", "id": "watermark_logo_width", "label": "Logo Width (px)", "min": 40, "max": 200, "step": 10, "default": 80 },
    { "type": "select", "id": "watermark_logo_align", "label": "Horizontal Alignment", "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ], "default": "left" },
    { "type": "select", "id": "watermark_logo_position", "label": "Vertical Position", "options": [
        { "value": "top", "label": "Header" },
        { "value": "bottom", "label": "Footer" }
      ], "default": "bottom" },
    { "type": "number", "id": "watermark_logo_opacity", "label": "Logo Opacity (%)", "default": 50 }
  ],
  "presets": [
    {
      "name": "Portfolio Gallery",
      "settings": {
        "intro_label": "The Work",
        "intro_text": "A portfolio of murals, digital art, and immersive visual work.",
        "filter_categories": "Commercial|Private|Freestyle|New Work",
        "cta_label": "Commission Your Own Piece",
        "cta_heading": "See Something You Like?",
        "cta_subtext": "Every wall, canvas, and surface is an opportunity. Get in touch to discuss your project.",
        "cta_btn_label": "Start a Commission"
      }
    }
  ]
}
{% endschema %}
