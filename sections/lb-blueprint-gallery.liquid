{%- assign gallery_items = 'lb_gallery_item' | metaobject_list -%}
{%- assign filter_cats = section.settings.filter_categories | split: '|' -%}

<section class="lb-blueprint-page lb-blueprint-page--gallery">

  <div class="gal-intro">
    {%- if section.settings.intro_label != blank -%}
      <span class="section-label">{{ section.settings.intro_label }}</span>
    {%- endif -%}
    <p>{{ section.settings.intro_text }}</p>
  </div>

  {%- if filter_cats.size > 0 -%}
    <div class="gal-filters">
      <button class="gal-filter active" data-filter="all">All</button>
      {%- for cat in filter_cats -%}
        {%- assign cat_clean = cat | strip -%}
        {%- if cat_clean != blank -%}
          <button class="gal-filter" data-filter="{{ cat_clean | downcase | replace: ' ', '-' }}">{{ cat_clean }}</button>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}

  <div class="gal-masonry" id="gal-masonry">
    {%- for item in gallery_items -%}
      {%- assign img = item.image -%}
      {%- assign title = item.title -%}
      {%- assign cats = item.categories -%}
      {%- assign wide = item.wide -%}
      {%- if img != blank -%}
        {%- assign cat_slugs = '' -%}
        {%- for cat in cats -%}
          {%- assign slug = cat | downcase | replace: ' ', '-' -%}
          {%- assign cat_slugs = cat_slugs | append: slug | append: ' ' -%}
        {%- endfor -%}
        <div class="gal-item{% if wide == true %} wide{% endif %}" data-cats="{{ cat_slugs | strip }}">
          {{ img.image | image_url: width: 1200 | image_tag: loading: 'lazy', width: 1200, height: 800, alt: title }}
          <div class="gal-item-ov">
            {%- if title != blank -%}<div class="gal-item-title">{{ title }}</div>{%- endif -%}
            {%- if cats.size > 0 -%}
              <div class="gal-item-cat">{{ cats | join: ' · ' }}</div>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <div class="gal-cta">
    {%- if section.settings.cta_label != blank -%}
      <span class="section-label">{{ section.settings.cta_label }}</span>
    {%- endif -%}
    <h2 class="section-h2">{{ section.settings.cta_heading }}</h2>
    <p>{{ section.settings.cta_subtext }}</p>
    {%- if section.settings.cta_btn_label != blank -%}
      <a href="{{ section.settings.cta_btn_url }}" class="btn-primary">{{ section.settings.cta_btn_label }}</a>
    {%- endif -%}
  </div>

</section>

<style>
  .gal-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }
  .gal-filter {
    background: transparent;
    border: 1px solid currentColor;
    color: inherit;
    cursor: pointer;
    font-family: inherit;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    padding: 0.5rem 1.25rem;
    text-transform: uppercase;
    transition: background 0.2s, color 0.2s;
  }
  .gal-filter.active,
  .gal-filter:hover {
    background: currentColor;
  }
  .gal-filter.active span,
  .gal-filter:hover {
    color: var(--color-background, #0a0a0a);
  }
  .gal-item {
    transition: opacity 0.3s ease;
  }
  .gal-item.hidden {
    display: none;
  }
</style>

<script>
  (function () {
    var filters = document.querySelectorAll('.gal-filter');
    var items = document.querySelectorAll('#gal-masonry .gal-item');

    filters.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var selected = this.dataset.filter;

        filters.forEach(function (b) { b.classList.remove('active'); });
        this.classList.add('active');

        items.forEach(function (item) {
          if (selected === 'all') {
            item.classList.remove('hidden');
          } else {
            var cats = (item.dataset.cats || '').split(' ');
            if (cats.indexOf(selected) > -1) {
              item.classList.remove('hidden');
            } else {
              item.classList.add('hidden');
            }
          }
        });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Portfolio Gallery",
  "settings": [
    { "type": "header", "content": "Intro" },
    { "type": "text", "id": "intro_label", "label": "Section Label", "default": "The Work" },
    { "type": "textarea", "id": "intro_text", "label": "Intro Text", "default": "A portfolio of murals, digital art, and immersive visual work." },
    { "type": "header", "content": "Category Filters" },
    { "type": "textarea", "id": "filter_categories", "label": "Filter Categories (separate with |)", "default": "Commercial|Private|Freestyle|New Work", "info": "These must match the category names used in the Gallery Manager app." },
    { "type": "header", "content": "Bottom CTA" },
    { "type": "text", "id": "cta_label", "label": "CTA Label", "default": "Commission Your Own Piece" },
    { "type": "text", "id": "cta_heading", "label": "CTA Heading", "default": "See Something You Like?" },
    { "type": "textarea", "id": "cta_subtext", "label": "CTA Subtext", "default": "Every wall, canvas, and surface is an opportunity. Get in touch to discuss your project." },
    { "type": "text", "id": "cta_btn_label", "label": "CTA Button Label", "default": "Start a Commission" },
    { "type": "url", "id": "cta_btn_url", "label": "CTA Button URL" }
  ],
  "presets": [
    {
      "name": "Portfolio Gallery",
      "settings": {
        "intro_label": "The Work",
        "intro_text": "A portfolio of murals, digital art, and immersive visual work.",
        "filter_categories": "Commercial|Private|Freestyle|New Work",
        "cta_label": "Commission Your Own Piece",
        "cta_heading": "See Something You Like?",
        "cta_subtext": "Every wall, canvas, and surface is an opportunity. Get in touch to discuss your project.",
        "cta_btn_label": "Start a Commission"
      }
    }
  ]
}
{% endschema %}
