<section class="lb-blueprint-page lb-blueprint-page--gallery">

<div class="pg-hero">
  <div class="pg-hero-bg">
    {% if section.settings.hero_bg_image != blank %}
      {{ section.settings.hero_bg_image | image_url: width: 1920 | image_tag: loading: 'eager', class: 'hero-bg-img' }}
    {% endif %}
  </div>
  <div class="pg-hero-ol"></div>
  <div class="pg-hero-c">
    <h1 class="pg-title">{{ section.settings.hero_title }}</h1>
    <p class="pg-sub">{{ section.settings.hero_subtitle }}</p>
  </div>
</div>

{% if section.settings.marquee_text != blank %}
<div class="marquee-wrap"><div class="marquee-track">
  {% assign marquee_items = section.settings.marquee_text | split: ',' %}
  {% for item in marquee_items %}{% for i in (1..2) %}
    <span class="mi">{{ item | strip }}</span><span class="ms"> &middot; </span>
  {% endfor %}{% endfor %}
</div></div>
{% endif %}

<div class="gal-intro">
  {% if section.settings.intro_label != blank %}<span class="section-label">{{ section.settings.intro_label }}</span>{% endif %}
  <p>{{ section.settings.intro_text }}</p>
</div>

<div class="gal-masonry">
  {% for i in (1..12) %}
    {% assign img_key = 'gallery_img_' | append: i %}
    {% assign title_key = 'gallery_title_' | append: i %}
    {% assign cat_key = 'gallery_cat_' | append: i %}
    {% assign wide_key = 'gallery_wide_' | append: i %}
    {% assign img_val = section.settings[img_key] %}
    {% if img_val != blank %}
      <div class="gal-item{% if section.settings[wide_key] %} wide{% endif %}">
        {{ img_val | image_url: width: 1200 | image_tag: loading: 'lazy', width: 1200, height: 800, alt: section.settings[title_key] }}
        <div class="gal-item-ov">
          <div class="gal-item-title">{{ section.settings[title_key] }}</div>
          <div class="gal-item-cat">{{ section.settings[cat_key] }}</div>
        </div>
      </div>
    {% endif %}
  {% endfor %}
</div>

<div class="gal-cta">
  {% if section.settings.cta_label != blank %}<span class="section-label">{{ section.settings.cta_label }}</span>{% endif %}
  <h2 class="section-h2">{{ section.settings.cta_heading }}</h2>
  <p>{{ section.settings.cta_subtext }}</p>
  {% if section.settings.cta_btn_label != blank %}
    <a href="{{ section.settings.cta_btn_url }}" class="btn-primary">{{ section.settings.cta_btn_label }}</a>
  {% endif %}
</div>

</section>

