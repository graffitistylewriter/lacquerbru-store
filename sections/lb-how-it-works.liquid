<section class="how-section">
  {% if section.settings.label != blank %}
    <span class="section-label">{{ section.settings.label }}</span>
  {% endif %}
  {% if section.settings.heading != blank %}
    <h2 class="section-h2">{{ section.settings.heading }}</h2>
  {% endif %}
  {% if section.settings.subheading != blank %}
    <p class="section-sub">{{ section.settings.subheading }}</p>
  {% endif %}

  <div class="how-steps">
    {% for block in section.blocks %}
      <div class="hs-item" {{ block.shopify_attributes }}>
        <span class="hs-num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
        {% if block.settings.icon != blank %}
          <span class="hs-icon">{{ block.settings.icon }}</span>
        {% endif %}
        <div class="hs-title">{{ block.settings.title }}</div>
        <p class="hs-desc">{{ block.settings.description }}</p>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "LB How It Works",
  "settings": [
    { "type": "text", "id": "label", "label": "Eyebrow Label", "default": "Getting Started" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "How It Works" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "From purchase to creating \u2014 the whole process takes under five minutes." }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji or symbol)" },
        { "type": "text", "id": "title", "label": "Title", "default": "Step Title" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Describe this step." }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "LB How It Works",
      "blocks": [
        { "type": "step", "settings": { "title": "Add to Cart & Pay", "description": "Complete checkout securely. Takes under two minutes." } },
        { "type": "step", "settings": { "title": "Check Your Inbox", "description": "Your download link arrives by email immediately after payment." } },
        { "type": "step", "settings": { "title": "Download & Import", "description": "Unzip and import your files. Ready to use instantly." } }
      ]
    }
  ]
}
{% endschema %}
