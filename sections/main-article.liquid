{%- assign article_bg = section.settings.bg_color -%}

<article
  class="lb-article"
  style="background:{{ article_bg }};"
  itemscope
  itemtype="https://schema.org/BlogPosting"
>

  {%- comment -%} ARTICLE HERO {%- endcomment -%}
  <div
    class="lb-article__hero"
    style="
      background: {{ section.settings.hero_bg }};
      min-height: {{ section.settings.hero_height }}px;
      {% if article.image %}position:relative;overflow:hidden;{% endif %}
    "
  >
    {% if article.image %}
      {{ article.image | image_url: width: 1920 | image_tag:
        loading: 'eager',
        fetchpriority: 'high',
        alt: article.title,
        class: 'lb-article__hero-img',
        width: 1920,
        height: 1080
      }}
      <div class="lb-article__hero-overlay" style="background:{{ section.settings.overlay_color }};opacity:{{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
    {% endif %}
    <div class="lb-article__hero-content">
      <div class="lb-article__hero-inner">
        {% if blog.title != blank %}
          <a href="{{ blog.url }}" class="lb-article__blog-link" style="color:{{ section.settings.accent_color }};">
            {{ blog.title }}
          </a>
        {% endif %}
        <h1 class="lb-article__title" style="color:{{ section.settings.text_color }};" itemprop="headline">
          {{ article.title }}
        </h1>
        <div class="lb-article__meta" style="color:{{ section.settings.muted_color }};">
          {% if section.settings.show_author %}
            <span itemprop="author">{{ article.author }}</span>
            <span class="lb-article__meta-sep">·</span>
          {% endif %}
          <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}" itemprop="datePublished">
            {{ article.published_at | date: '%B %d, %Y' }}
          </time>
          {% if section.settings.show_read_time %}
            <span class="lb-article__meta-sep">·</span>
            <span>{{ article.content | strip_html | split: ' ' | size | divided_by: 200 | plus: 1 }} min read</span>
          {% endif %}
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} ARTICLE BODY {%- endcomment -%}
  <div class="lb-article__body">
    <div
      class="lb-article__content rte"
      style="color:{{ section.settings.body_color }};"
      itemprop="articleBody"
    >
      {{ article.content }}
    </div>

    {% if section.settings.show_tags and article.tags.size > 0 %}
      <div class="lb-article__tags">
        {% for tag in article.tags %}
          <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="lb-article__tag" style="color:{{ section.settings.accent_color }};border-color:{{ section.settings.accent_color }};">
            {{ tag }}
          </a>
        {% endfor %}
      </div>
    {% endif %}

    {% if section.settings.show_share %}
      <div class="lb-article__share">
        <span style="color:{{ section.settings.muted_color }};">Share:</span>
        <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ article.url }}" target="_blank" rel="noopener" class="lb-article__share-btn" style="color:{{ section.settings.muted_color }};">Facebook</a>
        <a href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ article.url }}&text={{ article.title | url_encode }}" target="_blank" rel="noopener" class="lb-article__share-btn" style="color:{{ section.settings.muted_color }};">Twitter</a>
      </div>
    {% endif %}

    {%- comment -%} PREV / NEXT NAVIGATION {%- endcomment -%}
    {% if section.settings.show_nav and blog.articles_count > 1 %}
      <nav class="lb-article__nav" style="border-color:rgba(255,255,255,0.08);">
        {% if blog.previous_article %}
          <a href="{{ blog.previous_article }}" class="lb-article__nav-btn lb-article__nav-btn--prev" style="color:{{ section.settings.muted_color }};">
            <span class="lb-article__nav-label" style="color:{{ section.settings.accent_color }};">← Previous</span>
            <span class="lb-article__nav-title" style="color:{{ section.settings.text_color }};">{{ blog.previous_article.title }}</span>
          </a>
        {% else %}
          <div></div>
        {% endif %}
        {% if blog.next_article %}
          <a href="{{ blog.next_article }}" class="lb-article__nav-btn lb-article__nav-btn--next" style="color:{{ section.settings.muted_color }};">
            <span class="lb-article__nav-label" style="color:{{ section.settings.accent_color }};">Next →</span>
            <span class="lb-article__nav-title" style="color:{{ section.settings.text_color }};">{{ blog.next_article.title }}</span>
          </a>
        {% else %}
          <div></div>
        {% endif %}
      </nav>
    {% endif %}

    <div class="lb-article__back">
      <a href="{{ blog.url }}" class="lb-article__back-link" style="color:{{ section.settings.accent_color }};">
        ← Back to {{ blog.title }}
      </a>
    </div>

  </div>

  {%- comment -%} RELATED POSTS {%- endcomment -%}
  {% if section.settings.show_related and blog.articles_count > 1 %}
    <div class="lb-article__related" style="border-top:0.5px solid rgba(255,255,255,0.08);padding:{{ section.settings.padding_bottom }}px 60px;">
      <div class="lb-article__related-header">
        <span class="lb-article__related-label" style="color:{{ section.settings.accent_color }};">{{ section.settings.related_label | default: 'More from the Journal' }}</span>
        <h2 class="lb-article__related-heading" style="color:{{ section.settings.text_color }};">{{ section.settings.related_heading | default: 'Keep Reading' }}</h2>
      </div>
      <div class="lb-article__related-grid">
        {% for related in blog.articles limit: 3 %}
          {% unless related.id == article.id %}
            <a href="{{ related.url }}" class="lb-article__related-card" style="background:{{ section.settings.card_bg }};">
              {% if related.image %}
                {{ related.image | image_url: width: 800 | image_tag:
                  loading: 'lazy',
                  alt: related.title,
                  class: 'lb-article__related-img',
                  width: 800, height: 500
                }}
              {% else %}
                <div class="lb-article__related-img-placeholder"></div>
              {% endif %}
              <div class="lb-article__related-info">
                <time style="color:{{ section.settings.muted_color }};font-size:11px;letter-spacing:0.1em;text-transform:uppercase;">
                  {{ related.published_at | date: '%b %d, %Y' }}
                </time>
                <div class="lb-article__related-title" style="color:{{ section.settings.text_color }};">{{ related.title }}</div>
                {% if related.excerpt != blank %}
                  <p class="lb-article__related-excerpt" style="color:{{ section.settings.muted_color }};">{{ related.excerpt | strip_html | truncate: 100 }}</p>
                {% endif %}
              </div>
            </a>
          {% endunless %}
        {% endfor %}
      </div>
    </div>
  {% endif %}

</article>

<style>
  .lb-article__hero {
    display: flex;
    align-items: flex-end;
    padding-bottom: 60px;
  }
  .lb-article__hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .lb-article__hero-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .lb-article__hero-content {
    position: relative;
    z-index: 2;
    width: 100%;
    padding: 0 60px;
  }
  .lb-article__hero-inner { max-width: {{ section.settings.content_width }}px; }
  .lb-article__blog-link {
    display: inline-block;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    text-decoration: none;
    margin-bottom: 14px;
    transition: opacity 0.2s;
  }
  .lb-article__blog-link:hover { opacity: 0.7; }
  .lb-article__title {
    font-size: clamp(28px, 5vw, 64px);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin: 0 0 20px;
    text-transform: uppercase;
    max-width: 900px;
  }
  .lb-article__meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    letter-spacing: 0.06em;
    flex-wrap: wrap;
  }
  .lb-article__meta-sep { opacity: 0.4; }

  .lb-article__body {
    max-width: {{ section.settings.content_width }}px;
    margin: 0 auto;
    padding: {{ section.settings.padding_top }}px 60px {{ section.settings.padding_bottom }}px;
  }

  .lb-article__content { font-size: 16px; line-height: 1.9; }
  .lb-article__content h2 { font-size: clamp(20px, 3vw, 32px); font-weight: 700; text-transform: uppercase; letter-spacing: -0.01em; margin: 2.5rem 0 1rem; color: {{ section.settings.text_color }}; }
  .lb-article__content h3 { font-size: clamp(16px, 2.5vw, 24px); font-weight: 600; margin: 2rem 0 0.75rem; color: {{ section.settings.text_color }}; }
  .lb-article__content p { margin: 0 0 1.5rem; }
  .lb-article__content a { color: {{ section.settings.accent_color }}; text-decoration: underline; }
  .lb-article__content img { max-width: 100%; display: block; margin: 2rem 0; }
  .lb-article__content ul, .lb-article__content ol { padding-left: 1.5rem; margin-bottom: 1.5rem; }
  .lb-article__content li { margin-bottom: 0.5rem; }
  .lb-article__content blockquote {
    border-left: 3px solid {{ section.settings.accent_color }};
    padding: 1rem 1.5rem;
    margin: 2rem 0;
    font-size: 18px;
    font-style: italic;
    opacity: 0.8;
  }
  .lb-article__content hr { border: none; border-top: 0.5px solid rgba(255,255,255,0.1); margin: 2.5rem 0; }

  .lb-article__tags { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 40px; padding-top: 32px; border-top: 0.5px solid rgba(255,255,255,0.08); }
  .lb-article__tag { font-size: 10px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; padding: 6px 14px; border: 1px solid; text-decoration: none; transition: opacity 0.2s; }
  .lb-article__tag:hover { opacity: 0.7; }

  .lb-article__share { display: flex; align-items: center; gap: 16px; margin-top: 24px; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; }
  .lb-article__share-btn { text-decoration: none; transition: opacity 0.2s; }
  .lb-article__share-btn:hover { opacity: 0.7; }

  .lb-article__nav { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 48px; padding-top: 40px; border-top: 0.5px solid; }
  .lb-article__nav-btn { display: flex; flex-direction: column; gap: 6px; text-decoration: none; transition: opacity 0.2s; }
  .lb-article__nav-btn:hover { opacity: 0.7; }
  .lb-article__nav-btn--next { text-align: right; }
  .lb-article__nav-label { font-size: 10px; font-weight: 500; letter-spacing: 0.16em; text-transform: uppercase; }
  .lb-article__nav-title { font-size: 14px; font-weight: 600; line-height: 1.3; }

  .lb-article__back { margin-top: 32px; }
  .lb-article__back-link { font-size: 11px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; text-decoration: none; transition: opacity 0.2s; }
  .lb-article__back-link:hover { opacity: 0.7; }

  .lb-article__related { }
  .lb-article__related-header { margin-bottom: 32px; }
  .lb-article__related-label { display: block; font-size: 10px; font-weight: 500; letter-spacing: 0.24em; text-transform: uppercase; margin-bottom: 10px; }
  .lb-article__related-heading { font-size: clamp(22px, 3vw, 36px); font-weight: 700; text-transform: uppercase; margin: 0; }
  .lb-article__related-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .lb-article__related-card { text-decoration: none; display: flex; flex-direction: column; overflow: hidden; transition: opacity 0.2s; }
  .lb-article__related-card:hover { opacity: 0.8; }
  .lb-article__related-img { width: 100%; aspect-ratio: 16/9; object-fit: cover; display: block; }
  .lb-article__related-img-placeholder { width: 100%; aspect-ratio: 16/9; background: rgba(255,255,255,0.04); }
  .lb-article__related-info { padding: 16px; display: flex; flex-direction: column; gap: 8px; }
  .lb-article__related-title { font-size: 15px; font-weight: 600; line-height: 1.3; }
  .lb-article__related-excerpt { font-size: 13px; line-height: 1.6; margin: 0; }

  @media (max-width: 860px) {
    .lb-article__hero-content { padding: 0 24px; }
    .lb-article__body { padding-left: 24px !important; padding-right: 24px !important; }
    .lb-article__related { padding-left: 24px !important; padding-right: 24px !important; }
    .lb-article__related-grid { grid-template-columns: 1fr; }
    .lb-article__nav { grid-template-columns: 1fr; }
    .lb-article__nav-btn--next { text-align: left; }
  }
</style>

{% schema %}
{
  "name": "Article",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "range", "id": "hero_height", "label": "Hero Min Height", "min": 300, "max": 800, "step": 50, "default": 550, "unit": "px" },
    { "type": "color", "id": "hero_bg", "label": "Hero Background (no image)", "default": "#111111" },
    { "type": "color", "id": "overlay_color", "label": "Image Overlay Colour", "default": "#000000" },
    { "type": "range", "id": "overlay_opacity", "label": "Image Overlay Opacity", "min": 0, "max": 80, "step": 5, "default": 50, "unit": "%" },
    { "type": "header", "content": "Content" },
    { "type": "range", "id": "content_width", "label": "Max Content Width", "min": 600, "max": 1200, "step": 50, "default": 800, "unit": "px" },
    { "type": "checkbox", "id": "show_author", "label": "Show Author", "default": true },
    { "type": "checkbox", "id": "show_read_time", "label": "Show Read Time", "default": true },
    { "type": "checkbox", "id": "show_tags", "label": "Show Tags", "default": true },
    { "type": "checkbox", "id": "show_share", "label": "Show Share Links", "default": true },
    { "type": "checkbox", "id": "show_nav", "label": "Show Prev/Next Navigation", "default": true },
    { "type": "header", "content": "Related Posts" },
    { "type": "checkbox", "id": "show_related", "label": "Show Related Posts", "default": true },
    { "type": "text", "id": "related_label", "label": "Related Label", "default": "More from the Journal" },
    { "type": "text", "id": "related_heading", "label": "Related Heading", "default": "Keep Reading" },
    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "bg_color", "label": "Page Background", "default": "#0A0A0A" },
    { "type": "color", "id": "card_bg", "label": "Related Card Background", "default": "#1A1A1A" },
    { "type": "color", "id": "text_color", "label": "Text Colour", "default": "#FFFFFF" },
    { "type": "color", "id": "body_color", "label": "Body Text Colour", "default": "#CCCCCC" },
    { "type": "color", "id": "muted_color", "label": "Muted Colour", "default": "#AAAAAA" },
    { "type": "color", "id": "accent_color", "label": "Accent Colour", "default": "#7DD8E8" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Content Top Padding", "min": 40, "max": 160, "step": 10, "default": 80, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Content Bottom Padding", "min": 40, "max": 160, "step": 10, "default": 100, "unit": "px" }
  ]
}
{% endschema %}
