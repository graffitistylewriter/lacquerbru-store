{% assign projects = shop.metaobjects.project.values %}

<section class="lb-project-grid">
  <div class="lb-project-grid__header">
    {% if section.settings.eyebrow != blank %}
      <p class="lb-kicker">{{ section.settings.eyebrow }}</p>
    {% endif %}
    <h2>{{ section.settings.heading }}</h2>
    {% if section.settings.copy != blank %}
      <p>{{ section.settings.copy }}</p>
    {% endif %}
  </div>

  {% if section.settings.show_filters %}
    <div class="lb-project-grid__filters">
      <button class="lb-filter-button is-active" type="button" data-category="all">All</button>
      {% assign categories_string = '' %}
      {% for project in projects %}
        {% assign project_category = project.category.value | default: project.category %}
        {% if project_category != blank %}
          {% assign category_token = project_category | strip | append: '||' %}
          {% unless categories_string contains category_token %}
            {% assign categories_string = categories_string | append: category_token %}
          {% endunless %}
        {% endif %}
      {% endfor %}
      {% assign categories = categories_string | split: '||' %}
      {% for category in categories %}
        {% if category != blank %}
          <button class="lb-filter-button" type="button" data-category="{{ category | handleize }}">{{ category }}</button>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}

  <div class="lb-project-grid__grid">
    {% assign visible_count = 0 %}
    {% for project in projects %}
      {% assign project_featured = project.featured.value | default: project.featured %}
      {% assign project_category = project.category.value | default: project.category %}
      {% assign project_title = project.title.value | default: project.title %}
      {% assign project_summary = project.summary.value | default: project.summary %}
      {% assign project_image = project.featured_image.value | default: project.featured_image %}
      {% assign project_handle = project.system.handle %}
      {% assign project_client = project.client.value | default: '' %}
      {% assign project_year = project.completion_date.value | date: "%Y" %}
      {% assign project_story = project.story.value | default: '' | strip_html %}
      {% assign project_hero = project_image | image_url: width: 1600 %}
      {% capture gallery_urls %}{% for gimg in project.gallery.value %}{{ gimg | image_url: width: 1200 }}{% unless forloop.last %}|{% endunless %}{% endfor %}{% endcapture %}


      {% if section.settings.only_featured and project_featured != true and project_featured != 'true' %}
        {% continue %}
      {% endif %}
      {% if section.settings.category != blank and project_category != section.settings.category %}
        {% continue %}
      {% endif %}

      {% assign visible_count = visible_count | plus: 1 %}

      {% if visible_count <= section.settings.limit %}
        <article
          class="lb-project-card"
          data-handle="{{ project_handle }}"
          data-title="{{ project_title | escape }}"
          data-category="{{ project_category | escape }}"
          data-year="{{ project_year }}"
          data-client="{{ project_client | escape }}"
          data-summary="{{ project_summary | escape }}"
          data-story="{{ project_story | escape }}"
          data-hero="{{ project_hero }}"
          data-gallery="{{ gallery_urls }}"
          role="button"
          tabindex="0"
        >
          {% if project_image != blank %}
            {{ project_image | image_url: width: 1200 | image_tag: class: 'lb-project-card__image', loading: 'lazy', draggable: 'false' }}
          {% endif %}
          <div class="lb-project-card__content">
            {% if project_category != blank %}
              <p class="lb-project-card__category">{{ project_category }}</p>
            {% endif %}
            <h3>{{ project_title }}</h3>
            {% if project_summary != blank %}
              <p>{{ project_summary | truncate: 100 }}</p>
            {% endif %}
            <span class="lb-project-card__cta">View Project →</span>
          </div>
          <div class="lb-project-card__shield"></div>
        </article>
      {% endif %}
    {% endfor %}

    {% if visible_count == 0 %}
      <p class="lb-empty-state">Add Project metaobjects in Shopify Admin to populate this section.</p>
    {% endif %}
  </div>
</section>

<div id="lbpg-lightbox" aria-hidden="true">
  <div id="lbpg-backdrop"></div>
  <div id="lbpg-panel">
    <button id="lbpg-close" aria-label="Close">✕</button>
    <div id="lbpg-content">
      <div id="lbpg-hero">
        <img id="lbpg-hero-img" src="data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs=" alt="" draggable="false">
        <div id="lbpg-hero-overlay"></div>
        <div id="lbpg-hero-text">
          <p id="lbpg-kicker"></p>
          <h2 id="lbpg-title"></h2>
          <p id="lbpg-summary"></p>
        </div>
      </div>
      <div id="lbpg-meta-strip">
        <div class="lbpg-meta-item" id="lbpg-client-wrap">
          <span class="lbpg-meta-label">Client</span>
          <span class="lbpg-meta-value" id="lbpg-client"></span>
        </div>
        <div class="lbpg-meta-item" id="lbpg-type-wrap">
          <span class="lbpg-meta-label">Type</span>
          <span class="lbpg-meta-value" id="lbpg-type"></span>
        </div>
        <div class="lbpg-meta-item" id="lbpg-year-wrap">
          <span class="lbpg-meta-label">Year</span>
          <span class="lbpg-meta-value" id="lbpg-year"></span>
        </div>
      </div>
      <div id="lbpg-gallery-wrap">
        <p class="lbpg-section-label">Project Gallery</p>
        <div id="lbpg-gallery-wrap">
          <p class="lbpg-section-label">Project Gallery</p>
          <div id="lbpg-gallery-grid"></div>
        </div>
        <div id="lbpg-footer">
          <a id="lbpg-more-link" href="/pages/featured-projects">View More Projects →</a>
        </div>
  </div>
</div>

<style>
  .lb-project-grid__header{padding:0 60px;margin-bottom:48px;}
  .lb-project-grid__header h2{font-size:clamp(1.8rem,3vw,2.8rem);font-weight:900;text-transform:uppercase;letter-spacing:.03em;margin:8px 0 12px;}
  .lb-project-grid__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;padding:0 60px;}
  .lb-project-card{position:relative;overflow:hidden;cursor:pointer;aspect-ratio:4/3;background:#111;display:block;}
  .lb-project-card__image{width:100%;height:100%;object-fit:cover;display:block;transition:transform .5s ease;pointer-events:none;user-select:none;-webkit-user-drag:none;}
  .lb-project-card:hover .lb-project-card__image{transform:scale(1.04);}
  .lb-project-card__shield{position:absolute;inset:0;z-index:2;}
  .lb-project-card__content{position:absolute;bottom:0;left:0;right:0;padding:24px;background:linear-gradient(to top,rgba(0,0,0,.85) 0%,transparent 100%);z-index:3;opacity:0;transition:opacity .3s;}
  .lb-project-card:hover .lb-project-card__content{opacity:1;}
  .lb-project-card__category{font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:#7dd8e8;margin:0 0 6px;}
  .lb-project-card h3{font-size:1rem;font-weight:700;text-transform:uppercase;color:#fff;margin:0 0 6px;}
  .lb-project-card p{font-size:12px;color:#aaa;margin:0 0 10px;line-height:1.5;}
  .lb-project-card__cta{font-size:10px;letter-spacing:.15em;text-transform:uppercase;color:#7dd8e8;font-weight:600;}
  #lbpg-lightbox{position:fixed;inset:0;z-index:10000;display:flex;align-items:stretch;justify-content:flex-end;opacity:0;pointer-events:none;transition:opacity .3s ease;}
  #lbpg-lightbox.is-open{opacity:1;pointer-events:all;}
  #lbpg-backdrop{position:absolute;inset:0;background:rgba(0,0,0,0.85);}
  #lbpg-panel{position:relative;z-index:1;width:min(780px,100vw);background:#0a0a0a;overflow-y:auto;transform:translateX(100%);transition:transform .4s cubic-bezier(0.16,1,0.3,1);}
  #lbpg-lightbox.is-open #lbpg-panel{transform:translateX(0);}
  #lbpg-close{position:sticky;top:0;float:right;margin:16px 16px 0 0;background:none;border:none;color:#fff;font-size:18px;cursor:pointer;z-index:10;transition:color .2s;}
  #lbpg-close:hover{color:#7dd8e8;}
  #lbpg-content{padding-bottom:60px;}
  #lbpg-hero{position:relative;height:55vh;overflow:hidden;}
  #lbpg-hero-img{width:100%;height:100%;object-fit:cover;display:block;pointer-events:none;user-select:none;}
  #lbpg-hero-overlay{position:absolute;inset:0;background:linear-gradient(to bottom,rgba(10,10,10,0) 30%,rgba(10,10,10,.95) 100%);}
  #lbpg-hero-text{position:absolute;bottom:0;left:0;right:0;padding:32px;}
  #lbpg-kicker{font-size:9px;letter-spacing:.22em;text-transform:uppercase;color:#7dd8e8;margin:0 0 8px;}
  #lbpg-title{font-size:clamp(1.4rem,3vw,2rem);font-weight:900;text-transform:uppercase;letter-spacing:.04em;color:#fff;margin:0 0 10px;line-height:1.1;}
  #lbpg-summary{font-size:13px;color:#aaa;line-height:1.6;margin:0;}
  #lbpg-meta-strip{display:flex;gap:32px;flex-wrap:wrap;padding:20px 32px;border-bottom:1px solid #1e1e1e;background:#111;}
  .lbpg-meta-item{display:flex;flex-direction:column;gap:3px;}
  .lbpg-meta-label{font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:#555;}
  .lbpg-meta-value{font-size:12px;font-weight:600;color:#fff;letter-spacing:.04em;}
  #lbpg-story-wrap{padding:40px 32px 0;}
  #lbpg-story-wrap{padding:40px 32px 0;}
  #lbpg-story{font-size:13px;color:#ccc;line-height:1.9;}
  #lbpg-footer{padding:32px 32px 0;}
  #lbpg-more-link{font-size:10px;letter-spacing:.15em;text-transform:uppercase;color:#7dd8e8;text-decoration:none;font-weight:600;display:inline-block;border:1px solid #7dd8e8;padding:12px 28px;}
  #lbpg-more-link:hover{opacity:.7;}
  @media(max-width:860px){
      .lb-project-grid__header{padding:0 24px;}
      .lb-project-grid__grid{grid-template-columns:1fr;padding:0 24px;}
    }
    #lbpg-gallery-wrap{padding:40px 32px 0;}
    #lbpg-gallery-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:16px;}
    #lbpg-gallery-grid img{width:100%;aspect-ratio:4/3;object-fit:cover;display:block;pointer-events:none;user-select:none;}
    #lbpg-gallery-grid img:first-child{grid-column:1/-1;aspect-ratio:16/7;}
</style>

<script>
(function(){
  var lightbox=document.getElementById('lbpg-lightbox');
  var backdrop=document.getElementById('lbpg-backdrop');
  var closeBtn=document.getElementById('lbpg-close');
  var heroImg=document.getElementById('lbpg-hero-img');
  var kicker=document.getElementById('lbpg-kicker');
  var lbTitle=document.getElementById('lbpg-title');
  var lbSummary=document.getElementById('lbpg-summary');
  var client=document.getElementById('lbpg-client');
  var clientWrap=document.getElementById('lbpg-client-wrap');
  var lbType=document.getElementById('lbpg-type');
  var typeWrap=document.getElementById('lbpg-type-wrap');
  var lbYear=document.getElementById('lbpg-year');
  var yearWrap=document.getElementById('lbpg-year-wrap');
  var story=document.getElementById('lbpg-story');
  var storyWrap=document.getElementById('lbpg-story-wrap');

  function openPanel(card){
    var d=card.dataset;
    heroImg.src=d.hero||'';
    heroImg.alt=d.title||'';
    kicker.textContent=[d.category,d.year].filter(Boolean).join(' · ');
    lbTitle.textContent=d.title||'';
    lbSummary.textContent=d.summary||'';
    if(d.client){client.textContent=d.client;clientWrap.style.display='';}else{clientWrap.style.display='none';}
    if(d.category){lbType.textContent=d.category;typeWrap.style.display='';}else{typeWrap.style.display='none';}
    if(d.year){lbYear.textContent=d.year;yearWrap.style.display='';}else{yearWrap.style.display='none';}
    if(d.story){story.textContent=d.story;storyWrap.style.display='';}else{storyWrap.style.display='none';}
    var galleryGrid=document.getElementById('lbpg-gallery-grid');
    var galleryWrap=document.getElementById('lbpg-gallery-wrap');
    galleryGrid.innerHTML='';
    if(d.gallery&&d.gallery.length>0){
      var imgs=d.gallery.split('|').filter(Boolean);
      if(imgs.length>0){
        imgs.forEach(function(src){
          var img=document.createElement('img');
          img.src=src;img.alt=d.title;img.loading='lazy';img.draggable=false;
          img.addEventListener('contextmenu',function(e){e.preventDefault();});
          galleryGrid.appendChild(img);
        });
        galleryWrap.style.display='';
      }else{galleryWrap.style.display='none';}
    }else{galleryWrap.style.display='none';}
    lightbox.classList.add('is-open');
    lightbox.setAttribute('aria-hidden','false');
    document.body.style.overflow='hidden';
    document.getElementById('lbpg-panel').scrollTop=0;
  }

  function closePanel(){
    lightbox.classList.remove('is-open');
    lightbox.setAttribute('aria-hidden','true');
    document.body.style.overflow='';
  }

  document.querySelectorAll('.lb-project-card').forEach(function(card){
    card.addEventListener('click',function(){openPanel(card);});
    card.addEventListener('keydown',function(e){if(e.key==='Enter'||e.key===' ')openPanel(card);});
  });

  closeBtn.addEventListener('click',closePanel);
  backdrop.addEventListener('click',closePanel);
  document.addEventListener('keydown',function(e){
    if(e.key==='Escape'&&lightbox.classList.contains('is-open'))closePanel();
  });

  document.querySelectorAll('.lb-project-card__image').forEach(function(img){
    img.addEventListener('contextmenu',function(e){e.preventDefault();});
  });
})();
</script>

{% schema %}
{
  "name": "LB Project Grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Portfolio" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Featured Projects" },
    { "type": "textarea", "id": "copy", "label": "Intro Copy", "default": "Murals, campaigns, installations, and commercial creative work." },
    { "type": "checkbox", "id": "only_featured", "label": "Only Show Featured Projects", "default": false },
    { "type": "text", "id": "category", "label": "Category Filter", "info": "Optional. Must match the Project Category field exactly." },
    { "type": "checkbox", "id": "show_filters", "label": "Show Category Filter Buttons", "default": false },
    { "type": "range", "id": "limit", "label": "Projects To Show", "min": 3, "max": 24, "step": 1, "default": 6 }
  ],
  "presets": [{ "name": "LB Project Grid" }]
}
{% endschema %}
