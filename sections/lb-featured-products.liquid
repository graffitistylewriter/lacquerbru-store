<section
  class="lb-featured-products"
  style="
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 60px {{ section.settings.padding_bottom }}px;
  "
>

  {%- comment -%} SECTION HEADER {%- endcomment -%}
  {% if section.settings.label != blank or section.settings.heading != blank %}
    <div class="lb-featured-products__header">
      <div>
        {% if section.settings.label != blank %}
          <span class="lb-section-label" style="color:{{ section.settings.accent_color }};">
            {{ section.settings.label }}
          </span>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="lb-section-h2" style="color:{{ section.settings.heading_color }};">
            {{ section.settings.heading }}
          </h2>
        {% endif %}
        {% if section.settings.subtext != blank %}
          <p class="lb-section-sub" style="color:{{ section.settings.muted_color }};">
            {{ section.settings.subtext }}
          </p>
        {% endif %}
      </div>
      {% if section.settings.view_all_label != blank and section.settings.collection != blank %}
        <a
          href="{{ collections[section.settings.collection].url }}"
          class="lb-featured-products__view-all"
          style="color:{{ section.settings.accent_color }};"
        >
          {{ section.settings.view_all_label }} &rarr;
        </a>
      {% endif %}
    </div>
  {% endif %}

  {%- comment -%} PRODUCT GRID {%- endcomment -%}
  {%- if section.settings.collection != blank -%}
    {%- assign featured_collection = collections[section.settings.collection] -%}
    {%- assign product_limit = section.settings.product_limit -%}
  {%- endif -%}

  <div
    class="lb-featured-products__grid"
    style="grid-template-columns: repeat({{ section.settings.columns }}, 1fr);"
  >

    {%- comment -%} COLLECTION-BASED PRODUCTS {%- endcomment -%}
    {% if featured_collection != blank %}
      {% for product in featured_collection.products limit: product_limit %}
        {% render 'lb-product-card',
          product: product,
          accent_color: section.settings.accent_color,
          card_bg: section.settings.card_bg,
          text_color: section.settings.text_color,
          muted_color: section.settings.muted_color,
          show_vendor: section.settings.show_vendor,
          show_badge: section.settings.show_badge
        %}
      {% endfor %}

    {%- comment -%} MANUAL PRODUCT PICKS {%- endcomment -%}
    {% elsif section.blocks.size > 0 %}
      {% for block in section.blocks %}
        {% if block.settings.product != blank %}
          {%- assign product = all_products[block.settings.product] -%}
          {% render 'lb-product-card',
            product: product,
            accent_color: section.settings.accent_color,
            card_bg: section.settings.card_bg,
            text_color: section.settings.text_color,
            muted_color: section.settings.muted_color,
            show_vendor: section.settings.show_vendor,
            show_badge: section.settings.show_badge
          %}
        {% endif %}
      {% endfor %}

    {%- comment -%} PLACEHOLDER WHEN NOTHING SELECTED {%- endcomment -%}
    {% else %}
      {% for i in (1..4) %}
        <div class="lb-product-card lb-product-card--placeholder" style="background:{{ section.settings.card_bg }};">
          <div class="lb-product-card__img-wrap">
            {{ 'product-' | append: i | placeholder_svg_tag: 'lb-product-card__placeholder-svg' }}
          </div>
          <div class="lb-product-card__info">
            <span class="lb-product-card__type" style="color:{{ section.settings.muted_color }};">Product Type</span>
            <div class="lb-product-card__title" style="color:{{ section.settings.text_color }};">Product Title</div>
            <div class="lb-product-card__footer">
              <span class="lb-product-card__price" style="color:{{ section.settings.text_color }};">R0.00</span>
              <span class="lb-product-card__btn" style="background:{{ section.settings.accent_color }};color:#000;">Add to Cart</span>
            </div>
          </div>
        </div>
      {% endfor %}
    {% endif %}

  </div>

</section>

<style>
  .lb-featured-products__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 40px;
    flex-wrap: wrap;
    gap: 16px;
  }
  .lb-section-label {
    display: block;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .lb-section-h2 {
    font-size: clamp(26px, 4vw, 46px);
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.05;
    margin: 0 0 10px;
    text-transform: uppercase;
  }
  .lb-section-sub {
    font-size: 14px;
    line-height: 1.75;
    margin: 0;
    max-width: 480px;
  }
  .lb-featured-products__view-all {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.2s;
    flex-shrink: 0;
  }
  .lb-featured-products__view-all:hover { opacity: 0.7; }

  .lb-featured-products__grid {
    display: grid;
    gap: {{ section.settings.grid_gap }}px;
  }

  /* PRODUCT CARD */
  .lb-product-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    overflow: hidden;
    transition: transform 0.25s;
  }
  .lb-product-card:hover { transform: translateY(-4px); }
  .lb-product-card__img-wrap {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    position: relative;
    background: rgba(255,255,255,0.04);
  }
  .lb-product-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s;
  }
  .lb-product-card:hover .lb-product-card__img { transform: scale(1.04); }
  .lb-product-card__placeholder-svg {
    width: 100%;
    height: 100%;
    opacity: 0.15;
  }
  .lb-product-card__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 4px 10px;
    background: #000;
    color: #fff;
  }
  .lb-product-card__info {
    padding: 16px 0 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }
  .lb-product-card__type {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .lb-product-card__title {
    font-size: 15px;
    font-weight: 600;
    line-height: 1.3;
  }
  .lb-product-card__desc {
    font-size: 13px;
    line-height: 1.65;
    opacity: 0.7;
  }
  .lb-product-card__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    padding-top: 14px;
    gap: 12px;
  }
  .lb-product-card__price {
    font-size: 16px;
    font-weight: 700;
  }
  .lb-product-card__price--compare {
    font-size: 12px;
    text-decoration: line-through;
    opacity: 0.5;
    margin-left: 6px;
  }
  .lb-product-card__btn {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 10px 18px;
    text-decoration: none;
    transition: opacity 0.2s;
    white-space: nowrap;
    display: inline-block;
  }
  .lb-product-card__btn:hover { opacity: 0.85; }

  @media (max-width: 960px) {
    .lb-featured-products { padding-left: 24px !important; padding-right: 24px !important; }
    .lb-featured-products__grid { grid-template-columns: repeat(2, 1fr) !important; }
  }
  @media (max-width: 540px) {
    .lb-featured-products__grid { grid-template-columns: 1fr !important; }
  }
</style>

{% schema %}
{
  "name": "LB Featured Products",
  "tag": "section",
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "settings": [
    { "type": "header", "content": "Section Header" },
    { "type": "text", "id": "label", "label": "Section Label", "default": "Available Now" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Collection" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Digital assets built for working creatives. More drops coming." },
    { "type": "text", "id": "view_all_label", "label": "View All Link Label", "default": "View All Products" },

    { "type": "header", "content": "Products Source" },
    { "type": "collection", "id": "collection", "label": "Collection", "info": "Pick a collection to auto-populate products. Or leave blank and add products manually using blocks below." },
    { "type": "range", "id": "product_limit", "label": "Max Products to Show", "min": 2, "max": 12, "step": 1, "default": 4 },

    { "type": "header", "content": "Grid Layout" },
    { "type": "select", "id": "columns", "label": "Columns (desktop)", "options": [
      { "value": "2", "label": "2 Columns" },
      { "value": "3", "label": "3 Columns" },
      { "value": "4", "label": "4 Columns" }
    ], "default": "3" },
    { "type": "range", "id": "grid_gap", "label": "Gap Between Cards", "min": 8, "max": 48, "step": 4, "default": 24, "unit": "px" },

    { "type": "header", "content": "Card Options" },
    { "type": "checkbox", "id": "show_vendor", "label": "Show Vendor / Product Type", "default": true },
    { "type": "checkbox", "id": "show_badge", "label": "Show Sale / New Badge", "default": true },

    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "bg_color", "label": "Section Background", "default": "#0A0A0A" },
    { "type": "color", "id": "card_bg", "label": "Card Background", "default": "#1A1A1A" },
    { "type": "color", "id": "text_color", "label": "Text Colour", "default": "#FFFFFF" },
    { "type": "color", "id": "muted_color", "label": "Muted Text Colour", "default": "#AAAAAA" },
    { "type": "color", "id": "accent_color", "label": "Accent Colour", "default": "#7DD8E8" },
    { "type": "color", "id": "heading_color", "label": "Heading Colour", "default": "#FFFFFF" },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Top Padding", "min": 20, "max": 160, "step": 10, "default": 100, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Bottom Padding", "min": 20, "max": 160, "step": 10, "default": 100, "unit": "px" }
  ],
  "presets": [
    {
      "name": "Featured Products",
      "settings": {
        "label": "Available Now",
        "heading": "The Collection",
        "subtext": "Pick a collection above or add products manually using the blocks below."
      }
    }
  ]
}
{% endschema %}
