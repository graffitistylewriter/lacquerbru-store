<div
  class="lb-marquee"
  style="
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_v }}px 0;
  "
  aria-hidden="true"
>
  <div
    class="lb-marquee__track"
    style="animation-duration: {{ section.settings.speed }}s;"
  >
    {%- assign items = section.settings.items | split: ',' -%}
    {%- for _repeat in (1..2) -%}
      {%- for item in items -%}
        <span class="lb-marquee__item" style="color:{{ section.settings.text_color }};">
          {{- item | strip -}}
        </span>
        <span class="lb-marquee__sep" style="color:{{ section.settings.sep_color }};">
          {{ section.settings.separator | default: '·' }}
        </span>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</div>

<style>
  .lb-marquee {
    overflow: hidden;
    width: 100%;
  }
  .lb-marquee__track {
    display: flex;
    white-space: nowrap;
    animation: lb-marquee-scroll linear infinite;
    width: max-content;
  }
  {% if section.settings.direction == 'right' %}
  .lb-marquee__track { animation-direction: reverse; }
  {% endif %}
  {% if section.settings.pause_on_hover %}
  .lb-marquee:hover .lb-marquee__track { animation-play-state: paused; }
  {% endif %}
  .lb-marquee__item {
    font-size: {{ section.settings.font_size }}px;
    font-weight: {{ section.settings.font_weight }};
    letter-spacing: {{ section.settings.letter_spacing }}em;
    text-transform: uppercase;
    padding: 0 {{ section.settings.item_gap }}px;
    display: inline-block;
  }
  .lb-marquee__sep {
    font-size: {{ section.settings.font_size }}px;
    opacity: 0.4;
    display: inline-block;
  }
  @keyframes lb-marquee-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
</style>

{% schema %}
{
  "name": "LB Marquee",
  "tag": "div",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "textarea",
      "id": "items",
      "label": "Marquee Items (comma separated)",
      "default": "Graffiti Murals, Digital Art, Brush Packs, Textured Finishes, Commission Work, Cape Town, Aerosoul, 16 Years Experience, Mural Painting, Illustration"
    },
    {
      "type": "text",
      "id": "separator",
      "label": "Separator Character",
      "default": "·"
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll Speed",
      "min": 10,
      "max": 80,
      "step": 5,
      "default": 30,
      "info": "Lower = faster, Higher = slower",
      "unit": "s"
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Scroll Direction",
      "options": [
        { "value": "left", "label": "Left (default)" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on Hover",
      "default": false
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font Size",
      "min": 8,
      "max": 24,
      "step": 1,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font Weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter Spacing",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 18,
      "info": "Value × 0.01em",
      "unit": "×"
    },
    {
      "type": "range",
      "id": "item_gap",
      "label": "Item Padding",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 22,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Colours & Spacing"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Colour",
      "default": "#7DD8E8"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Colour",
      "default": "#0A0A0A"
    },
    {
      "type": "color",
      "id": "sep_color",
      "label": "Separator Colour",
      "default": "#0A0A0A"
    },
    {
      "type": "range",
      "id": "padding_v",
      "label": "Vertical Padding",
      "min": 6,
      "max": 40,
      "step": 2,
      "default": 13,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Marquee Strip",
      "settings": {
        "items": "Your Brand, Your Story, Your Work, Your Vision, Your Style"
      }
    }
  ]
}
{% endschema %}
