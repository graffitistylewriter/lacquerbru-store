<footer class="lb-footer">

  {%- comment -%} EMAIL BAR {%- endcomment -%}
  {% if section.settings.show_email_bar %}
  <div class="lb-footer__email-bar" style="background:{{ section.settings.email_bar_bg }};color:{{ section.settings.email_bar_color }};">
    <span class="lb-footer__email-msg">{{ section.settings.email_bar_text }}</span>
    {% form 'customer', class: 'lb-footer__email-form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input
        class="lb-footer__email-inp"
        type="email"
        name="contact[email]"
        placeholder="{{ section.settings.email_placeholder | default: 'your@email.com' }}"
        required
        aria-label="Email address"
      >
      <button class="lb-footer__email-btn" type="submit">
        {{ section.settings.email_btn_label | default: 'Subscribe' }}
      </button>
    {% endform %}
  </div>
  {% endif %}

  {%- comment -%} MAIN COLUMNS {%- endcomment -%}
  <div class="lb-footer__main">

    {%- comment -%} BRAND COLUMN {%- endcomment -%}
    <div class="lb-footer__brand">
      <a href="{{ routes.root_url }}" class="lb-footer__logo" aria-label="{{ shop.name }}">
        {% if settings.logo != blank %}
          {{ settings.logo | image_url: width: 240 | image_tag: alt: shop.name, class: 'lb-footer__logo-img' }}
        {% else %}
          <span class="lb-footer__logo-top">{{ section.settings.logo_top | default: shop.name }}</span>
          <span class="lb-footer__logo-bot">{{ section.settings.logo_bot }}</span>
        {% endif %}
      </a>

      {% if section.settings.brand_desc != blank %}
        <p class="lb-footer__brand-desc">{{ section.settings.brand_desc }}</p>
      {% endif %}

      {% if section.settings.brand_tagline != blank %}
        <span class="lb-footer__brand-tag">{{ section.settings.brand_tagline }}</span>
      {% endif %}

      <div class="lb-footer__contact">
        {% if settings.contact_email != blank %}
          <a href="mailto:{{ settings.contact_email }}">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            {{ settings.contact_email }}
          </a>
        {% endif %}
        {% if settings.contact_phone != blank %}
          <a href="tel:{{ settings.contact_phone | remove: ' ' }}">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.62 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            {{ settings.contact_phone }}
          </a>
        {% endif %}
        {% if section.settings.location != blank %}
          <span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            {{ section.settings.location }}
          </span>
        {% endif %}
      </div>

      {% if section.settings.show_social %}
        <div class="lb-footer__social">
          {% if settings.instagram != blank %}
            <a href="{{ settings.instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
              {% if section.settings.social_style == 'handles' %}
                @{{ settings.instagram | split: '/' | last }}
              {% else %}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              {% endif %}
            </a>
          {% endif %}
          {% if settings.facebook != blank %}
            <a href="{{ settings.facebook }}" target="_blank" rel="noopener" aria-label="Facebook">
              {% if section.settings.social_style == 'handles' %}
                Facebook
              {% else %}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              {% endif %}
            </a>
          {% endif %}
          {% if settings.youtube != blank %}
            <a href="{{ settings.youtube }}" target="_blank" rel="noopener" aria-label="YouTube">
              {% if section.settings.social_style == 'handles' %}
                YouTube
              {% else %}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
              {% endif %}
            </a>
          {% endif %}
          {% if settings.tiktok != blank %}
            <a href="{{ settings.tiktok }}" target="_blank" rel="noopener" aria-label="TikTok">
              {% if section.settings.social_style == 'handles' %}
                TikTok
              {% else %}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
              {% endif %}
            </a>
          {% endif %}
          {% if settings.linkedin != blank %}
            <a href="{{ settings.linkedin }}" target="_blank" rel="noopener" aria-label="LinkedIn">
              {% if section.settings.social_style == 'handles' %}
                LinkedIn
              {% else %}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
              {% endif %}
            </a>
          {% endif %}
        </div>
      {% endif %}
    </div>

    {%- comment -%} NAV COLUMNS {%- endcomment -%}
    {% if section.settings.col1_menu != blank %}
      <div class="lb-footer__col">
        {% if section.settings.col1_heading != blank %}
          <h4 class="lb-footer__col-heading">{{ section.settings.col1_heading }}</h4>
        {% endif %}
        {% for link in section.settings.col1_menu.links %}
          <a href="{{ link.url }}" class="lb-footer__col-link">{{ link.title }}</a>
        {% endfor %}
      </div>
    {% endif %}

    {% if section.settings.col2_menu != blank %}
      <div class="lb-footer__col">
        {% if section.settings.col2_heading != blank %}
          <h4 class="lb-footer__col-heading">{{ section.settings.col2_heading }}</h4>
        {% endif %}
        {% for link in section.settings.col2_menu.links %}
          <a href="{{ link.url }}" class="lb-footer__col-link">{{ link.title }}</a>
        {% endfor %}
      </div>
    {% endif %}

    {% if section.settings.col3_menu != blank %}
      <div class="lb-footer__col">
        {% if section.settings.col3_heading != blank %}
          <h4 class="lb-footer__col-heading">{{ section.settings.col3_heading }}</h4>
        {% endif %}
        {% for link in section.settings.col3_menu.links %}
          <a href="{{ link.url }}" class="lb-footer__col-link">{{ link.title }}</a>
        {% endfor %}
      </div>
    {% endif %}

    {% if section.settings.col4_menu != blank %}
      <div class="lb-footer__col">
        {% if section.settings.col4_heading != blank %}
          <h4 class="lb-footer__col-heading">{{ section.settings.col4_heading }}</h4>
        {% endif %}
        {% for link in section.settings.col4_menu.links %}
          <a href="{{ link.url }}" class="lb-footer__col-link">{{ link.title }}</a>
        {% endfor %}
      </div>
    {% endif %}

  </div>

  {%- comment -%} TRUST STRIP {%- endcomment -%}
  {% if section.settings.show_trust_strip %}
  <div class="lb-footer__trust">
    {% for i in (1..4) %}
      {%- assign icon_key = 'trust_' | append: i | append: '_icon' -%}
      {%- assign label_key = 'trust_' | append: i | append: '_label' -%}
      {%- assign val_key = 'trust_' | append: i | append: '_value' -%}
      {% if section.settings[label_key] != blank %}
        <div class="lb-footer__trust-item">
          {% if section.settings[icon_key] != blank %}
            <span class="lb-footer__trust-icon">{{ section.settings[icon_key] }}</span>
          {% endif %}
          <div>
            <div class="lb-footer__trust-label">{{ section.settings[label_key] }}</div>
            <div class="lb-footer__trust-val">{{ section.settings[val_key] }}</div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
  {% endif %}

  {%- comment -%} BOTTOM BAR {%- endcomment -%}
  <div class="lb-footer__bottom">
    <span class="lb-footer__copy">
      &copy; {{ 'now' | date: '%Y' }}
      {% if section.settings.copyright_text != blank %}
        {{ section.settings.copyright_text }}
      {% else %}
        {{ settings.business_name | default: shop.name }}. All rights reserved.
      {% endif %}
    </span>

    <div class="lb-footer__legal">
      {% if shop.privacy_policy != blank %}
        <a href="{{ shop.privacy_policy.url }}">{{ shop.privacy_policy.title }}</a>
      {% endif %}
      {% if shop.refund_policy != blank %}
        <a href="{{ shop.refund_policy.url }}">{{ shop.refund_policy.title }}</a>
      {% endif %}
      {% if shop.terms_of_service != blank %}
        <a href="{{ shop.terms_of_service.url }}">{{ shop.terms_of_service.title }}</a>
      {% endif %}
      {% if section.settings.extra_legal_menu != blank %}
        {% for link in section.settings.extra_legal_menu.links %}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {% endfor %}
      {% endif %}
    </div>

    {% if section.settings.show_payment_badges %}
      <div class="lb-footer__payments">
        <span class="lb-footer__payments-label">Payments via</span>
        {% if section.settings.payment_badge_1 != blank %}
          <span class="lb-footer__pay-badge">{{ section.settings.payment_badge_1 }}</span>
        {% endif %}
        {% if section.settings.payment_badge_2 != blank %}
          <span class="lb-footer__pay-badge">{{ section.settings.payment_badge_2 }}</span>
        {% endif %}
        {% if section.settings.payment_badge_3 != blank %}
          <span class="lb-footer__pay-badge">{{ section.settings.payment_badge_3 }}</span>
        {% endif %}
      </div>
    {% endif %}
  </div>

</footer>

<style>
  :root {
    --lb-nav-bg:     {{ section.settings.nav_bg }};
    --lb-nav-text:   {{ section.settings.nav_text_color }};
    --lb-nav-accent: {{ section.settings.nav_accent_color }};
    --lb-nav-height: {{ section.settings.nav_height }}px;
  }

  [data-theme="light"] .lb-nav { background: var(--lb-header-bg) !important; color: var(--lb-header-text) !important; border-bottom-color: rgba(0,0,0,0.08) !important; }
  [data-theme="light"] .lb-nav__link { color: rgba(0,0,0,0.55); }
  [data-theme="light"] .lb-nav__link:hover,
  [data-theme="light"] .lb-nav__link--active { color: var(--lb-accent); }
  [data-theme="light"] .lb-nav__icon { color: rgba(0,0,0,0.55); }
  [data-theme="light"] .lb-nav__icon:hover { color: var(--lb-accent); }
  [data-theme="light"] .lb-nav__hamburger span { background: #0A0A0A; }
  [data-theme="light"] .lb-nav__dropdown { background: #FFFFFF; border-color: rgba(0,0,0,0.1); }
  [data-theme="light"] .lb-nav__dropdown-link { color: rgba(0,0,0,0.55); }
  [data-theme="light"] .lb-nav__dropdown-link:hover { background: rgba(0,0,0,0.04); color: var(--lb-accent); }
  [data-theme="light"] .lb-mobile-menu { background: rgba(20,20,20,0.92); }
  [data-theme="light"] .lb-mobile-menu__link { color: #fff; }
  [data-theme="light"] .lb-mobile-menu__close { color: rgba(255,255,255,0.5); }

  .lb-announcement {
    text-align: center;
    padding: var(--lb-space-xs) var(--lb-container-pad);
    font-size: var(--lb-text-xs);
    font-weight: 500;
    letter-spacing: 0.08em;
  }
  .lb-announcement a { text-decoration: underline; }

  .lb-nav {
    position: {% if section.settings.sticky_header %}fixed{% else %}relative{% endif %};
    top: 0; left: 0; width: 100%;
    z-index: 1000;
    padding: var(--lb-space-sm) var(--lb-container-pad);
    display: flex;
    align-items: center;
    gap: var(--lb-space-md);
    background: var(--lb-nav-bg);
    backdrop-filter: blur(14px);
    border-bottom: 0.5px solid rgba(255,255,255,0.08);
    transition: padding var(--lb-transition), background var(--lb-transition), color var(--lb-transition);
    color: var(--lb-nav-text);
  }
  .lb-nav.lb-nav--scrolled {
    padding-top: var(--lb-space-xs);
    padding-bottom: var(--lb-space-xs);
    background: {{ section.settings.nav_bg_scrolled }};
  }

  .lb-nav__logo { display: flex; flex-direction: column; line-height: 1; text-decoration: none; flex-shrink: 0; }
  .lb-nav__logo-img { height: 40px; width: auto; }
  .lb-nav__logo-top { font-size: var(--lb-text-xs); font-weight: 500; letter-spacing: 0.26em; text-transform: uppercase; color: var(--lb-nav-text); }
  .lb-nav__logo-bot { font-size: clamp(18px, 2vw, 23px); font-weight: 700; color: var(--lb-nav-accent); letter-spacing: 0.05em; text-transform: uppercase; line-height: 1; }

  .lb-nav__links { display: flex; gap: 0; list-style: none; align-items: center; margin: 0; padding: 0; flex: 1; }
  .lb-nav__item { position: relative; }
  .lb-nav__link { display: flex; align-items: center; gap: 5px; padding: var(--lb-space-xs) var(--lb-space-sm); font-size: var(--lb-text-xs); font-weight: 500; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(255,255,255,0.6); text-decoration: none; transition: color var(--lb-transition); white-space: nowrap; cursor: pointer; }
  .lb-nav__link:hover, .lb-nav__link--active { color: var(--lb-nav-accent); }
  .lb-nav__chevron { transition: transform 0.25s; flex-shrink: 0; }
  .lb-nav__item--has-dropdown.lb-dropdown--open .lb-nav__chevron { transform: rotate(180deg); }

  .lb-nav__dropdown { position: absolute; top: calc(100% + 12px); left: 0; background: #0e0e0e; border: 0.5px solid rgba(255,255,255,0.1); min-width: 200px; padding: var(--lb-space-xs) 0; list-style: none; margin: 0; opacity: 0; pointer-events: none; transform: translateY(-6px); transition: opacity 0.22s ease, transform 0.22s ease; z-index: 10; }
  .lb-nav__item--has-dropdown.lb-dropdown--open .lb-nav__dropdown { opacity: 1; pointer-events: all; transform: translateY(0); }
  .lb-nav__dropdown-link { display: block; padding: var(--lb-space-xs) var(--lb-space-md); font-size: var(--lb-text-xs); font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.55); text-decoration: none; transition: color var(--lb-transition), background var(--lb-transition); }
  .lb-nav__dropdown-link:hover { color: var(--lb-nav-accent); background: rgba(255,255,255,0.04); }

  .lb-nav__actions { display: flex; align-items: center; gap: var(--lb-space-sm); margin-left: auto; flex-shrink: 0; }
  .lb-nav__icon { position: relative; color: rgba(255,255,255,0.65); display: flex; align-items: center; text-decoration: none; transition: color var(--lb-transition); }
  .lb-nav__icon:hover { color: var(--lb-nav-accent); }
  .lb-nav__cart-count { position: absolute; top: -7px; right: -9px; background: var(--lb-nav-accent); color: #000; font-size: 9px; font-weight: 700; width: 16px; height: 16px; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
  .lb-nav__cta { background: #7DD8E8 !important; color: #FFFFFF !important; font-size: var(--lb-text-xs); font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; padding: var(--lb-space-xs) var(--lb-space-md); text-decoration: none; border: 1.5px solid #7DD8E8 !important; transition: opacity var(--lb-transition); white-space: nowrap; }
  .lb-nav__cta:hover { opacity: 0.85; }

  .lb-theme-toggle { background: none; border: 1px solid rgba(128,128,128,0.3); color: inherit; width: 34px; height: 34px; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: border-color var(--lb-transition), color var(--lb-transition); flex-shrink: 0; padding: 0; }
  .lb-theme-toggle:hover { border-color: var(--lb-nav-accent); color: var(--lb-nav-accent); }
  .lb-theme-toggle__icon { display: flex; align-items: center; justify-content: center; }
  .lb-theme-toggle__icon--light { display: none; }
  [data-theme="light"] .lb-theme-toggle__icon--dark { display: none; }
  [data-theme="light"] .lb-theme-toggle__icon--light { display: flex; }

  .lb-nav__hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; background: none; border: none; padding: 4px; margin-left: auto; }
  .lb-nav__hamburger span { width: 24px; height: 1.5px; background: var(--lb-nav-text); display: block; transition: all 0.3s; }

  .lb-mobile-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.45); z-index: 1001; }
  .lb-mobile-overlay--visible { display: block; }

  .lb-mobile-menu { position: fixed; top: 0; right: 0; width: 82%; max-width: 360px; height: 100%; background: rgba(0,0,0,0.72); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); z-index: 1002; display: flex; flex-direction: column; padding: clamp(56px, 10vw, 72px) var(--lb-space-md) var(--lb-space-lg); overflow-y: auto; transform: translateX(100%); transition: transform 0.35s cubic-bezier(0.4,0,0.2,1); }
  .lb-mobile-menu.lb-mobile-menu--open { transform: translateX(0); }

  .lb-mobile-menu__close { position: absolute; top: var(--lb-space-sm); right: var(--lb-space-md); font-size: 26px; color: rgba(255,255,255,0.45); cursor: pointer; background: none; border: none; line-height: 1; transition: color var(--lb-transition); }
  .lb-mobile-menu__close:hover { color: var(--lb-nav-accent); }

  .lb-mobile-menu__logo { display: flex; flex-direction: column; align-items: flex-start; margin-bottom: var(--lb-space-lg); }

  .lb-mobile-menu__nav { display: flex; flex-direction: column; gap: 2px; width: 100%; }

  .lb-mobile-menu__link { font-size: var(--lb-text-md); font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: #fff; text-decoration: none; padding: var(--lb-space-xs) 0; border-bottom: 0.5px solid rgba(255,255,255,0.07); transition: color var(--lb-transition); display: flex; align-items: center; justify-content: space-between; width: 100%; background: none; border-left: none; border-right: none; border-top: none; cursor: pointer; text-align: left; }
  .lb-mobile-menu__link:hover, .lb-mobile-menu__link--active { color: var(--lb-nav-accent); }

  .lb-mobile-menu__acc-chevron { transition: transform 0.25s; flex-shrink: 0; }
  .lb-mobile-menu__accordion-toggle[aria-expanded="true"] .lb-mobile-menu__acc-chevron { transform: rotate(180deg); }
  .lb-mobile-menu__accordion-body { display: none; padding-left: var(--lb-space-sm); }
  .lb-mobile-menu__accordion-body.is-open { display: flex; flex-direction: column; }
  .lb-mobile-menu__child { font-size: var(--lb-text-sm); color: rgba(255,255,255,0.6); text-decoration: none; padding: var(--lb-space-xs) 0; transition: color var(--lb-transition); }
  .lb-mobile-menu__child:hover { color: var(--lb-nav-accent); }

  .lb-mobile-menu__footer { margin-top: auto; padding-top: var(--lb-space-md); display: flex; gap: var(--lb-space-md); }
  .lb-mobile-menu__util { font-size: var(--lb-text-xs); color: rgba(255,255,255,0.45); text-decoration: none; letter-spacing: 0.12em; text-transform: uppercase; transition: color var(--lb-transition); }
  .lb-mobile-menu__util:hover { color: var(--lb-nav-accent); }
  .lb-mobile-menu__cta-nav { display: block; margin-top: var(--lb-space-md); background: var(--lb-nav-accent); color: var(--lb-void); font-size: var(--lb-text-xs); font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; padding: var(--lb-space-sm) var(--lb-space-md); text-align: center; text-decoration: none; }

  @media (max-width: 768px) {
    .lb-nav__links { display: none; }
    .lb-nav__hamburger { display: flex; }
    .lb-nav__cta { display: none; }
  }
</style>

{% schema %}
{
  "name": "LB Footer",
  "settings": [
    { "type": "header", "content": "Email Signup Bar" },
    { "type": "checkbox", "id": "show_email_bar", "label": "Show Email Bar", "default": true },
    { "type": "text", "id": "email_bar_text", "label": "Email Bar Message", "default": "New drops first. Join the Lacquer Bru list." },
    { "type": "text", "id": "email_placeholder", "label": "Input Placeholder", "default": "your@email.com" },
    { "type": "text", "id": "email_btn_label", "label": "Subscribe Button Label", "default": "Subscribe" },
    { "type": "color", "id": "email_bar_bg", "label": "Email Bar Background", "default": "#7DD8E8" },
    { "type": "color", "id": "email_bar_color", "label": "Email Bar Text Colour", "default": "#0A0A0A" },

    { "type": "header", "content": "Brand Column" },
    { "type": "text", "id": "logo_top", "label": "Logo Top Line", "default": "Lacquer" },
    { "type": "text", "id": "logo_bot", "label": "Logo Bottom Line", "default": "BRU" },
    { "type": "textarea", "id": "brand_desc", "label": "Brand Description", "default": "Multidisciplinary creative studio built on 16+ years of aerosol culture, digital creation, and immersive visual transformation. Based in Cape Town, working worldwide." },
    { "type": "text", "id": "brand_tagline", "label": "Brand Tagline", "default": "If Not Unique, Why Bother." },
    { "type": "text", "id": "location", "label": "Location Text", "default": "Cape Town, Western Cape, South Africa" },

