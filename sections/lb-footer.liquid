<footer class="lb-footer" style="padding-top:{{ section.settings.padding_top }}px; padding-bottom:{{ section.settings.padding_bottom }}px;">
  <div class="fg">

    <div class="fc fc--brand">
      <div class="flw">
        {% if settings.logo != blank %}
          {{ settings.logo | image_url: width: 240 | image_tag: alt: shop.name, class: 'footer-logo-img' }}
        {% else %}
          <span class="flw-text">{{ settings.business_name | default: shop.name }}</span>
        {% endif %}
      </div>

      {% if section.settings.footer_description != blank %}
        <p class="ftag">{{ section.settings.footer_description }}</p>
      {% elsif settings.business_tagline != blank %}
        <p class="ftag">{{ settings.business_tagline }}</p>
      {% endif %}

      {% if section.settings.show_social %}
        <div class="fsoc">
          {% if settings.instagram != blank %}
            <a href="{{ settings.instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              {% if section.settings.show_social_labels %}Instagram{% endif %}
            </a>
          {% endif %}
          {% if settings.facebook != blank %}
            <a href="{{ settings.facebook }}" target="_blank" rel="noopener" aria-label="Facebook">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              {% if section.settings.show_social_labels %}Facebook{% endif %}
            </a>
          {% endif %}
          {% if settings.youtube != blank %}
            <a href="{{ settings.youtube }}" target="_blank" rel="noopener" aria-label="YouTube">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
              {% if section.settings.show_social_labels %}YouTube{% endif %}
            </a>
          {% endif %}
          {% if settings.tiktok != blank %}
            <a href="{{ settings.tiktok }}" target="_blank" rel="noopener" aria-label="TikTok">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
              {% if section.settings.show_social_labels %}TikTok{% endif %}
            </a>
          {% endif %}
          {% if settings.linkedin != blank %}
            <a href="{{ settings.linkedin }}" target="_blank" rel="noopener" aria-label="LinkedIn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
              {% if section.settings.show_social_labels %}LinkedIn{% endif %}
            </a>
          {% endif %}
        </div>
      {% endif %}
    </div>

    {% if section.settings.column_1_menu != blank %}
      <div class="fc">
        {% if section.settings.column_1_heading != blank %}<h4>{{ section.settings.column_1_heading }}</h4>{% endif %}
        {% for link in section.settings.column_1_menu.links %}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {% endfor %}
      </div>
    {% endif %}

    {% if section.settings.column_2_menu != blank %}
      <div class="fc">
        {% if section.settings.column_2_heading != blank %}<h4>{{ section.settings.column_2_heading }}</h4>{% endif %}
        {% for link in section.settings.column_2_menu.links %}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {% endfor %}
      </div>
    {% endif %}

    {% if section.settings.column_3_menu != blank %}
      <div class="fc">
        {% if section.settings.column_3_heading != blank %}<h4>{{ section.settings.column_3_heading }}</h4>{% endif %}
        {% for link in section.settings.column_3_menu.links %}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {% endfor %}
      </div>
    {% endif %}

    {% if settings.contact_email != blank or settings.contact_phone != blank %}
      <div class="fc">
        <h4>{{ section.settings.contact_heading | default: 'Contact' }}</h4>
        {% if settings.contact_email != blank %}
          <a href="mailto:{{ settings.contact_email }}">{{ settings.contact_email }}</a>
        {% endif %}
        {% if settings.contact_phone != blank %}
          <a href="tel:{{ settings.contact_phone | remove: ' ' }}">{{ settings.contact_phone }}</a>
        {% endif %}
      </div>
    {% endif %}

  </div>

  <div class="fb">
    <p class="fcp">
      &copy; {{ 'now' | date: '%Y' }}
      {% if section.settings.copyright_text != blank %}
        {{ section.settings.copyright_text }}
      {% else %}
        {{ settings.business_name | default: shop.name }}. All rights reserved.
      {% endif %}
    </p>
    <div class="fleg">
      {% if shop.privacy_policy %}<a href="{{ shop.privacy_policy.url }}">{{ shop.privacy_policy.title }}</a>{% endif %}
      {% if shop.refund_policy %}<a href="{{ shop.refund_policy.url }}">{{ shop.refund_policy.title }}</a>{% endif %}
      {% if shop.terms_of_service %}<a href="{{ shop.terms_of_service.url }}">{{ shop.terms_of_service.title }}</a>{% endif %}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "LB Footer",
  "settings": [
    {
      "type": "header",
      "content": "Brand Column"
    },
    {
      "type": "textarea",
      "id": "footer_description",
      "label": "Footer Description",
      "info": "Short brand description shown under the logo. Overrides the global tagline if set."
    },
    {
      "type": "header",
      "content": "Social Icons"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show Social Icons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_social_labels",
      "label": "Show Social Labels (text next to icons)",
      "default": false
    },
    {
      "type": "header",
      "content": "Footer Columns"
    },
    {
      "type": "text",
      "id": "column_1_heading",
      "label": "Column 1 Heading",
      "default": "Shop"
    },
    {
      "type": "link_list",
      "id": "column_1_menu",
      "label": "Column 1 Menu"
    },
    {
      "type": "text",
      "id": "column_2_heading",
      "label": "Column 2 Heading",
      "default": "Explore"
    },
    {
      "type": "link_list",
      "id": "column_2_menu",
      "label": "Column 2 Menu"
    },
    {
      "type": "text",
      "id": "column_3_heading",
      "label": "Column 3 Heading"
    },
    {
      "type": "link_list",
      "id": "column_3_menu",
      "label": "Column 3 Menu"
    },
    {
      "type": "header",
      "content": "Contact Column"
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "Contact Column Heading",
      "default": "Contact"
    },
    {
      "type": "header",
      "content": "Bottom Bar"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "info": "Overrides the default. E.g. 'Lacquer Bru. All rights reserved.'"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding",
      "min": 20,
      "max": 120,
      "step": 10,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding",
      "min": 20,
      "max": 120,
      "step": 10,
      "default": 40,
      "unit": "px"
    }
  ]
}
{% endschema %}
