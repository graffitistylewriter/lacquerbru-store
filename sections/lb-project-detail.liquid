{% assign project = metaobject %}
{% assign title = project.title.value | default: project.title %}
{% assign category = project.category.value | default: project.category %}
{% assign summary = project.summary.value | default: project.summary %}
{% assign story = project.story %}
{% assign client = project.client.value | default: project.client %}
{% assign completion_date = project.completion_date.value | default: project.completion_date %}
{% assign featured_image = project.featured_image.value | default: project.featured_image %}
{% assign gallery = project.gallery.value | default: project.gallery %}

<article class="lb-project-detail">

  <header class="lb-project-detail__hero">

    {% if featured_image != blank %}
      <div class="lb-project-detail__media">
        {{
          featured_image
          | image_url: width: 2200
          | image_tag: class: 'lb-project-detail__image', loading: 'eager'
        }}
      </div>
    {% endif %}

    <div class="lb-project-detail__intro">

      {% if category != blank %}
        <p class="lb-kicker">{{ category }}</p>
      {% endif %}

      <h1>{{ title }}</h1>

      {% if summary != blank %}
        <p class="lb-project-detail__summary">{{ summary }}</p>
      {% endif %}

      <dl class="lb-project-detail__meta">
        {% if client != blank %}
          <div>
            <dt>Client</dt>
            <dd>{{ client }}</dd>
          </div>
        {% endif %}

        {% if completion_date != blank %}
          <div>
            <dt>Completed</dt>
            <dd>{{ completion_date | date: '%B %Y' }}</dd>
          </div>
        {% endif %}
      </dl>

    </div>

  </header>

  {% if story != blank %}
    <div class="lb-project-detail__story">
      {{ story | metafield_tag }}
    </div>
  {% endif %}

  {% if gallery != blank %}
    <div class="lb-project-detail__gallery">
      {% for image in gallery %}
        {{
          image
          | image_url: width: 1400
          | image_tag: class: 'lb-project-detail__gallery-image', loading: 'lazy'
        }}
      {% endfor %}
    </div>
  {% endif %}

</article>

<style>
  .lb-project-detail { padding: calc(var(--lb-space-xl) + 24px) var(--lb-container-pad) var(--lb-space-xl); }

  .lb-project-detail__hero { display: grid; max-width: var(--lb-page-width); grid-template-columns: minmax(0, 1.35fr) minmax(300px, 0.65fr); gap: var(--lb-space-lg); align-items: center; margin: 0 auto var(--lb-space-xl); }
  .lb-project-detail__image { width: 100%; max-height: 760px; object-fit: cover; display: block; }
  .lb-project-detail__intro { display: grid; gap: var(--lb-space-sm); }
  .lb-project-detail__intro h1 { font-size: clamp(42px, 7vw, 86px); }
  .lb-project-detail__summary { font-size: var(--lb-text-lg); color: var(--lb-muted); line-height: 1.7; }

  .lb-project-detail__meta { display: grid; gap: var(--lb-space-sm); margin-top: var(--lb-space-sm); padding-top: var(--lb-space-sm); border-top: 1px solid var(--lb-wall); }
  .lb-project-detail__meta dt { margin-bottom: 3px; color: var(--lb-concrete); font-size: var(--lb-text-xs); font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; }
  .lb-project-detail__meta dd { color: var(--lb-white); font-size: var(--lb-text-sm); }

  .lb-project-detail__story { max-width: 820px; margin: 0 auto var(--lb-space-xl); }
  .lb-project-detail__story * + * { margin-top: var(--lb-space-sm); }
  .lb-project-detail__story p { font-size: var(--lb-text-md); color: var(--lb-muted); line-height: 1.85; }

  .lb-project-detail__gallery { display: grid; max-width: var(--lb-page-width); grid-template-columns: repeat(2, minmax(0, 1fr)); gap: var(--lb-grid-gap); margin: 0 auto; }
  .lb-project-detail__gallery-image { width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block; }

  @media (max-width: 960px) {
    .lb-project-detail__hero { grid-template-columns: 1fr; }
    .lb-project-detail__gallery { grid-template-columns: 1fr; }
  }
</style>

{% schema %}
{
  "name": "LB Project Detail",
  "settings": []
}
{% endschema %}
