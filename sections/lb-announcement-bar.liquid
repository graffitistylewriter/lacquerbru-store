<div class="lb-announcement-bar">
  <div class="page-width">

    {% if section.blocks.size > 0 %}

      <div class="lb-announcement-bar__messages">

        {% for block in section.blocks %}

          {% case block.type %}

            {% when 'announcement' %}

              <div
                class="lb-announcement-bar__message"
                {{ block.shopify_attributes }}
              >

                {% if block.settings.link != blank %}
                  <a href="{{ block.settings.link }}">
                    {{ block.settings.text }}
                  </a>
                {% else %}
                  {{ block.settings.text }}
                {% endif %}

              </div>

          {% endcase %}

        {% endfor %}

      </div>

    {% endif %}

  </div>
</div>

{% schema %}
{
  "name": "LB Announcement Bar",
  "tag": "section",
  "class": "section-announcement-bar",
  "max_blocks": 5,
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Announcement",
          "default": "Free shipping on orders over R1000"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LB Announcement Bar",
      "blocks": [
        {
          "type": "announcement"
        }
      ]
    }
  ]
}
{% endschema %}