<div
  class="lb-trust-strip"
  style="background:{{ section.settings.bg_color }};border-top:0.5px solid {{ section.settings.border_color }};border-bottom:0.5px solid {{ section.settings.border_color }};padding:{{ section.settings.padding_v }}px 60px;"
>
  {% for i in (1..4) %}
    {%- assign icon_key = 'item_' | append: i | append: '_icon' -%}
    {%- assign label_key = 'item_' | append: i | append: '_label' -%}
    {%- assign val_key = 'item_' | append: i | append: '_value' -%}
    {% if section.settings[label_key] != blank %}
      <div class="lb-trust-strip__item">
        {% if section.settings[icon_key] != blank %}
          <span class="lb-trust-strip__icon">{{ section.settings[icon_key] }}</span>
        {% endif %}
        <div>
          <div class="lb-trust-strip__label" style="color:{{ section.settings.text_color }};">{{ section.settings[label_key] }}</div>
          {% if section.settings[val_key] != blank %}
            <div class="lb-trust-strip__value" style="color:{{ section.settings.muted_color }};">{{ section.settings[val_key] }}</div>
          {% endif %}
        </div>
      </div>
    {% endif %}
  {% endfor %}
</div>

<style>
  .lb-trust-strip { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; }
  .lb-trust-strip__item { display: flex; align-items: center; gap: var(--lb-space-sm); padding: 0 var(--lb-space-md); border-right: 0.5px solid {{ section.settings.border_color }}; }
  .lb-trust-strip__item:first-child { padding-left: 0; }
  .lb-trust-strip__item:last-child { border-right: none; }
  .lb-trust-strip__icon { font-size: 24px; flex-shrink: 0; }
  .lb-trust-strip__label { font-size: var(--lb-text-xs); font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; }
  .lb-trust-strip__value { font-size: var(--lb-text-sm); margin-top: 3px; line-height: 1.4; }
  @media (max-width: 860px) {
    .lb-trust-strip { grid-template-columns: 1fr 1fr; padding: var(--lb-space-md) var(--lb-container-pad) !important; }
    .lb-trust-strip__item { padding: var(--lb-space-sm); border-right: none; border-bottom: 0.5px solid {{ section.settings.border_color }}; }
    .lb-trust-strip__item:nth-child(odd) { border-right: 0.5px solid {{ section.settings.border_color }}; }
    .lb-trust-strip__item:nth-last-child(-n+2) { border-bottom: none; }
  }
  @media (max-width: 480px) {
    .lb-trust-strip { grid-template-columns: 1fr; }
    .lb-trust-strip__item { border-right: none !important; }
    .lb-trust-strip__item:last-child { border-bottom: none; }
  }
</style>

{% schema %}
{
  "name": "LB Trust Strip",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "item_1_icon", "label": "Item 1 Icon", "default": "⚡" },
    { "type": "text", "id": "item_1_label", "label": "Item 1 Label", "default": "Instant Download" },
    { "type": "text", "id": "item_1_value", "label": "Item 1 Value", "default": "Files delivered immediately after payment" },
    { "type": "text", "id": "item_2_icon", "label": "Item 2 Icon", "default": "🔒" },
    { "type": "text", "id": "item_2_label", "label": "Item 2 Label", "default": "Secure Checkout" },
    { "type": "text", "id": "item_2_value", "label": "Item 2 Value", "default": "Protected transactions" },
    { "type": "text", "id": "item_3_icon", "label": "Item 3 Icon", "default": "🎨" },
    { "type": "text", "id": "item_3_label", "label": "Item 3 Label", "default": "Made by an Artist" },
    { "type": "text", "id": "item_3_value", "label": "Item 3 Value", "default": "Tested in real workflows" },
    { "type": "text", "id": "item_4_icon", "label": "Item 4 Icon", "default": "💬" },
    { "type": "text", "id": "item_4_label", "label": "Item 4 Label", "default": "Real Support" },
    { "type": "text", "id": "item_4_value", "label": "Item 4 Value", "default": "Response within 24–48 hours" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#111111" },
    { "type": "color", "id": "text_color", "label": "Label Colour", "default": "#FFFFFF" },
    { "type": "color", "id": "muted_color", "label": "Value Colour", "default": "#AAAAAA" },
    { "type": "color", "id": "border_color", "label": "Border Colour", "default": "#2A2A2A" },
    { "type": "range", "id": "padding_v", "label": "Vertical Padding", "min": 12, "max": 60, "step": 4, "default": 24, "unit": "px" }
  ],
  "presets": [{ "name": "Trust Strip" }]
}
{% endschema %}
