<section class="lb-blueprint-page lb-blueprint-page--commission">

<div class="comm-body">
  <div class="comm-info">
    {% if section.settings.info_label != blank %}<span class="section-label">{{ section.settings.info_label }}</span>{% endif %}
    <h2 class="section-h2">{{ section.settings.info_heading }}</h2>
    <p>{{ section.settings.info_body }}</p>
    {% if section.settings.services_list != blank %}
      <ul class="what-list">
        {% assign items = section.settings.services_list | split: '|' %}
        {% for item in items %}
          <li>{{ item | strip }}</li>
        {% endfor %}
      </ul>
    {% endif %}
    <div class="comm-details">
      {% if settings.contact_email != blank %}
        <div class="cd">
          <span class="cd-icon">Email</span>
          <span>Email: <a href="mailto:{{ settings.contact_email }}">{{ settings.contact_email }}</a></span>
        </div>
      {% endif %}
      {% if settings.contact_phone != blank %}
        <div class="cd">
          <span class="cd-icon">Phone</span>
          <span>Call or WhatsApp: <a href="tel:{{ settings.contact_phone | remove: ' ' }}">{{ settings.contact_phone }}</a></span>
        </div>
      {% endif %}
      {% if section.settings.location_text != blank %}
        <div class="cd">
          <span class="cd-icon">Location</span>
          <span>{{ section.settings.location_text }}</span>
        </div>
      {% endif %}
      {% if section.settings.response_time != blank %}
        <div class="cd">
          <span class="cd-icon">Time</span>
          <span>{{ section.settings.response_time }}</span>
        </div>
      {% endif %}
    </div>
  </div>

  {% form 'contact', class: 'comm-form' %}
  <div class="form-title">{{ section.settings.form_title }}</div>
  <p class="form-subtext">{{ section.settings.form_subtext }}</p>

  <div class="fg-row">
    <div class="fgrp"><label>First Name *</label><input type="text" name="contact[first_name]" placeholder="Your first name" required></div>
    <div class="fgrp"><label>Last Name *</label><input type="text" name="contact[last_name]" placeholder="Your last name" required></div>
  </div>

  <div class="fg-row">
    <div class="fgrp"><label>Email Address *</label><input type="email" name="contact[email]" placeholder="your@email.com" required></div>
    <div class="fgrp"><label>Phone / WhatsApp</label><input type="tel" name="contact[phone]" placeholder="+27 ..."></div>
  </div>

  <div class="fgrp">
    <label>{{ section.settings.heard_about_label | default: 'How did you hear about us?' }}</label>
    <select name="contact[heard_about]">
      <option value="">Select an option</option>
      {% assign heard_options = section.settings.heard_about_options | default: 'Instagram|Word of Mouth|Google|Behance|Referral|Other' | split: '|' %}
      {% for opt in heard_options %}
        <option>{{ opt | strip }}</option>
      {% endfor %}
    </select>
  </div>

  <div class="fgrp">
    <label>Project Type *</label>
    <select name="contact[project_type]" required>
      <option value="">Select a project type</option>
      {% assign project_options = section.settings.project_type_options | default: 'Mural (Exterior)|Mural (Interior)|Feature Wall|Fine Art Print|Vehicle Graphics|Digital Illustration|Brand Installation|Live Painting / Activation|Other' | split: '|' %}
      {% for opt in project_options %}
        <option>{{ opt | strip }}</option>
      {% endfor %}
    </select>
  </div>

  <div class="fgrp">
    <label>{{ section.settings.preferred_style_label | default: 'Preferred Style / Medium' }}</label>
    <select name="contact[preferred_style]">
      <option value="">Select a style</option>
      {% assign style_options = section.settings.preferred_style_options | default: 'Realistic|Abstract|Geometric|Typographic|Mixed Media|Open to Direction' | split: '|' %}
      {% for opt in style_options %}
        <option>{{ opt | strip }}</option>
      {% endfor %}
    </select>
  </div>

  <div class="fg-row">
    <div class="fgrp"><label>Country</label><input type="text" name="contact[country]" placeholder="e.g. South Africa"></div>
    <div class="fgrp"><label>City</label><input type="text" name="contact[city]" placeholder="e.g. Cape Town"></div>
  </div>

  <div class="fgrp">
    <label>{{ section.settings.completion_date_label | default: 'Desired Completion Date' }}</label>
    <input type="date" name="contact[completion_date]">
  </div>

  <div class="fgrp">
    <label>{{ section.settings.file_note_heading | default: 'Reference Files' }}</label>
    <div class="comm-file-note">
      <p>{{ section.settings.file_note_text | default: 'To share reference images, mood boards or site photos — email them directly to howzit@lacquerbru.co.za with your name in the subject line.' }}</p>
    </div>
  </div>

  <div class="fgrp">
    <label>Project Description *</label>
    <textarea name="contact[body]" placeholder="Tell us about your project — the more detail the better." required></textarea>
  </div>

  {% if section.settings.form_disclaimer != blank %}
    <p class="form-note">{{ section.settings.form_disclaimer }}</p>
  {% endif %}

  <button class="form-sbmt" type="submit">{{ section.settings.form_btn_label | default: 'Submit Commission Inquiry' }}</button>
{% endform %}

</div>

<section class="comm-work">
  {% if section.settings.work_label != blank %}<span class="section-label">{{ section.settings.work_label }}</span>{% endif %}
  <h2 class="section-h2">{{ section.settings.work_heading }}</h2>
  <p class="section-subtext">{{ section.settings.work_subtext }}</p>
  <div class="cw-grid">
    {% if section.settings.work_img1 != blank %}<div class="cw-item">{{ section.settings.work_img1 | image_url: width: 1200 | image_tag: alt: 'Commission example', loading: 'lazy', width: 1200, height: 800 }}</div>{% endif %}
    {% if section.settings.work_img2 != blank %}<div class="cw-item">{{ section.settings.work_img2 | image_url: width: 1200 | image_tag: alt: 'Commission example', loading: 'lazy', width: 1200, height: 800 }}</div>{% endif %}
    {% if section.settings.work_img3 != blank %}<div class="cw-item">{{ section.settings.work_img3 | image_url: width: 1200 | image_tag: alt: 'Commission example', loading: 'lazy', width: 1200, height: 800 }}</div>{% endif %}
    {% if section.settings.work_img4 != blank %}<div class="cw-item">{{ section.settings.work_img4 | image_url: width: 1200 | image_tag: alt: 'Commission example', loading: 'lazy', width: 1200, height: 800 }}</div>{% endif %}
  </div>
</section>

</section>

<style>
.comm-form select { width: 100%; background: #111; border: 1px solid #2a2a2a; color: #fff; padding: 14px 16px; font-size: 13px; font-family: inherit; appearance: none; -webkit-appearance: none; border-radius: 0; cursor: pointer; }
.comm-form select:focus { outline: none; border-color: #00e5ff; }
.comm-form input[type="date"] { width: 100%; background: #111; border: 1px solid #2a2a2a; color: #fff; padding: 14px 16px; font-size: 13px; font-family: inherit; border-radius: 0; color-scheme: dark; }
.comm-form input[type="date"]:focus { outline: none; border-color: #00e5ff; }
.comm-file-note { background: rgba(0,229,255,0.05); border-left: 3px solid #00e5ff; padding: 16px 20px; margin-top: 4px; }
.comm-file-note p { color: #aaaaaa; font-size: 13px; line-height: 1.6; margin: 0; }
</style>

{% schema %}
{
  "name": "LB Blueprint Commission",
  "settings": [
    { "type": "header", "content": "Info Panel" },
    { "type": "text", "id": "info_label", "label": "Section Label", "default": "Work Together" },
    { "type": "text", "id": "info_heading", "label": "Heading", "default": "Let's Create Something Original" },
    { "type": "textarea", "id": "info_body", "label": "Intro Paragraph", "default": "Whether you arrive with a clear concept or allow full creative freedom — both approaches are equally valued." },
    { "type": "textarea", "id": "services_list", "label": "Services List (separate with |)", "default": "Large scale exterior and interior murals|Textured feature walls and surface finishes|Brand spaces and commercial environments|Private residences and estates|Hospitality venues and retail environments|Vehicle graphics and custom artwork|Event live painting and activations|Digital illustration and design projects|Limited edition fine art print runs" },
    { "type": "text", "id": "location_text", "label": "Location Text", "default": "Based in Cape Town, South Africa. Working locally and internationally." },
    { "type": "text", "id": "response_time", "label": "Response Time Text", "default": "We respond to all inquiries within 24 to 48 hours." },
    { "type": "header", "content": "Contact Form" },
    { "type": "text", "id": "form_title", "label": "Form Title", "default": "Tell Us About Your Project" },
    { "type": "textarea", "id": "form_subtext", "label": "Form Subtext", "default": "The more detail you can share the better. Fill in what you know — we'll work through the rest together." },
    { "type": "textarea", "id": "form_disclaimer", "label": "Form Disclaimer Text" },
    { "type": "text", "id": "form_btn_label", "label": "Submit Button Label", "default": "Submit Commission Inquiry" },
    { "type": "header", "content": "Form Field Labels" },
    { "type": "text", "id": "heard_about_label", "label": "Heard About Label", "default": "How did you hear about us?" },
    { "type": "text", "id": "preferred_style_label", "label": "Preferred Style Label", "default": "Preferred Style / Medium" },
    { "type": "text", "id": "completion_date_label", "label": "Completion Date Label", "default": "Desired Completion Date" },
    { "type": "text", "id": "file_note_heading", "label": "File Upload Heading", "default": "Reference Files" },
    { "type": "textarea", "id": "file_note_text", "label": "File Upload Note", "default": "To share reference images, mood boards or site photos — email them directly to howzit@lacquerbru.co.za with your name in the subject line." },
    { "type": "header", "content": "Previous Work Gallery" },
    { "type": "text", "id": "work_label", "label": "Section Label", "default": "Previous Work" },
    { "type": "text", "id": "work_heading", "label": "Heading", "default": "Commission Examples" },
    { "type": "textarea", "id": "work_subtext", "label": "Subtext", "default": "A selection of commissioned projects across different environments and scales." },
    { "type": "image_picker", "id": "work_img1", "label": "Work Image 1" },
    { "type": "image_picker", "id": "work_img2", "label": "Work Image 2" },
    { "type": "image_picker", "id": "work_img3", "label": "Work Image 3" },
    { "type": "image_picker", "id": "work_img4", "label": "Work Image 4" }
  ]
}
{% endschema %}
