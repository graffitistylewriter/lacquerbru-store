        "preferred_style_options": "Realistic|Abstract|Geometric|Typographic|Mixed Media|Open to Direction",
        "work_label": "Previous Work",
        "work_heading": "Commission Examples",
        "work_subtext": "A selection of commissioned projects across different environments and scales."
      }
