{% comment %}
  ------------------------------------------------------------------------
  Section: Main Collection
  File: sections/main-collection.liquid

  Renders the collection template. Fully schema-driven — every string,
  layout choice, and behaviour toggle is a merchant setting. Nothing in
  this file is hardcoded to a specific collection, product, or copy.

  Reuses existing global classes so the rest of the theme keeps working:
    .lb-collection-main, .lb-collection-main__header,
    .lb-collection-main__grid, .lb-product-card, .lb-kicker,
    .lb-btn / .lb-btn--ghost, .lb-empty-state

  New behaviour (filtering, sorting, pagination, badges, hover image) is
  scoped under .lb-collection-{{ section.id }} via a {% style %} block so
  it cannot collide with other sections.
  ------------------------------------------------------------------------
{% endcomment %}

{%- liquid
  assign columns_desktop = section.settings.columns_desktop
  assign columns_mobile = section.settings.columns_mobile | plus: 0

  case section.settings.image_ratio
    when 'portrait'
      assign aspect_ratio = '3/4'
    when 'landscape'
      assign aspect_ratio = '4/3'
    when 'natural'
      assign aspect_ratio = 'auto'
    else
      assign aspect_ratio = '1/1'
  endcase

  assign has_filters = false
  if section.settings.enable_filtering and collection.filters.size > 0
    assign has_filters = true
  endif

  assign has_active_filters = false
  for filter in collection.filters
    if filter.active_values.size > 0
      assign has_active_filters = true
    endif
    if filter.type == 'price_range' and filter.min_value.value != nil or filter.type == 'price_range' and filter.max_value.value != nil
      assign has_active_filters = true
    endif
  endfor
-%}

<section
  class="lb-collection-main lb-collection-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-section-type="main-collection"
>

  {%- comment %} ---------------- Header ---------------- {% endcomment -%}
  <header class="lb-collection-main__header lb-collection-header">

    {%- if section.settings.show_collection_image and collection.image != blank -%}
      <div class="lb-collection-banner">
        {{
          collection.image
          | image_url: width: 1600
          | image_tag: loading: 'eager', class: 'lb-collection-banner__img', alt: collection.image.alt | default: collection.title
        }}
      </div>
    {%- endif -%}

    {%- if section.settings.eyebrow != blank -%}
      <p class="lb-kicker">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    <h1>{{ collection.title }}</h1>

    {%- if section.settings.show_description and collection.description != blank -%}
      <div class="lb-collection-main__description">{{ collection.description }}</div>
    {%- endif -%}

  </header>

  {%- comment %} ---------------- Filter + Sort form ---------------- {% endcomment -%}
  <form
    id="lb-collection-form-{{ section.id }}"
    class="lb-collection-toolbar-form"
    method="get"
    action="{{ collection.url }}"
  >

    <div class="lb-collection-toolbar">

      {%- if has_filters -%}
        <button
          type="button"
          class="lb-filter-toggle"
          id="lb-filter-toggle-{{ section.id }}"
          aria-expanded="false"
          aria-controls="lb-filters-{{ section.id }}"
        >
          {{ section.settings.filters_heading | default: 'Filter' }}
          {%- if has_active_filters -%}
            <span class="lb-filter-toggle__count">•</span>
          {%- endif -%}
        </button>
      {%- endif -%}

      <p class="lb-results-count">
        {{ collection.products_count }}
        {%- if collection.products_count == 1 %} product{% else %} products{% endif -%}
      </p>

      {%- if section.settings.enable_sorting -%}
        <div class="lb-sort">
          <label for="lb-sort-{{ section.id }}" class="lb-sort__label">
            {{ section.settings.sort_label | default: 'Sort by' }}
          </label>
          <select
            name="sort_by"
            id="lb-sort-{{ section.id }}"
            class="lb-sort__select"
            data-lb-auto-submit
          >
            {%- for option in collection.sort_options -%}
              <option value="{{ option.value }}" {% if option.value == collection.sort_by %}selected{% endif %}>
                {{ option.name }}
              </option>
            {%- endfor -%}
          </select>
        </div>
      {%- endif -%}

    </div>

    {%- comment %} ---------------- Active filter chips ---------------- {% endcomment -%}
    {%- if has_active_filters -%}
      <div class="lb-active-filters" aria-live="polite">
        {%- for filter in collection.filters -%}
          {%- for value in filter.active_values -%}
            <a href="{{ value.url_to_remove }}" class="lb-active-filter">
              {{ filter.label }}: {{ value.label }}
              <span aria-hidden="true">&times;</span>
            </a>
          {%- endfor -%}
          {%- if filter.type == 'price_range' -%}
            {%- if filter.min_value.value != nil or filter.max_value.value != nil -%}
              <a href="{{ filter.url_to_remove }}" class="lb-active-filter">
                {{ filter.label }}
                <span aria-hidden="true">&times;</span>
              </a>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}

        <a href="{{ collection.url }}?sort_by={{ collection.sort_by }}" class="lb-active-filter lb-active-filter--clear">
          {{ section.settings.clear_filters_text | default: 'Clear All' }}
        </a>
      </div>
    {%- endif -%}

    <div class="lb-collection-layout">

      {%- comment %} ---------------- Filters panel ---------------- {% endcomment -%}
      {%- if has_filters -%}
        <aside
          class="lb-filters"
          id="lb-filters-{{ section.id }}"
          data-lb-filters
          hidden
        >
          {%- for filter in collection.filters -%}
            <div class="lb-filter-group">
              <h3 class="lb-filter-group__title">{{ filter.label }}</h3>

              {%- case filter.type -%}

                {%- when 'list' or 'boolean' -%}
                  <ul class="lb-filter-values">
                    {%- for value in filter.values -%}
                      {%- if value.count > 0 or value.active -%}
                        <li class="lb-filter-value">
                          <label
                            for="lb-filter-{{ section.id }}-{{ filter.label | handleize }}-{{ forloop.index }}"
                            class="lb-filter-value__label {% if value.count == 0 and value.active == false %}is-disabled{% endif %}"
                          >
                            <input
                              type="checkbox"
                              id="lb-filter-{{ section.id }}-{{ filter.label | handleize }}-{{ forloop.index }}"
                              name="{{ value.param_name }}"
                              value="{{ value.value }}"
                              {% if value.active %}checked{% endif %}
                              {% if value.count == 0 and value.active == false %}disabled{% endif %}
                              data-lb-auto-submit
                            >
                            <span>{{ value.label }}</span>
                            <span class="lb-filter-value__count">({{ value.count }})</span>
                          </label>
                        </li>
                      {%- endif -%}
                    {%- endfor -%}
                  </ul>

                {%- when 'price_range' -%}
                  <div class="lb-filter-price">
                    <label class="lb-filter-price__field">
                      <span>Min</span>
                      <input
                        type="number"
                        name="{{ filter.min_value.param_name }}"
                        value="{{ filter.min_value.value }}"
                        placeholder="{{ filter.range_min | money_without_currency | default: 0 }}"
                        min="0"
                      >
                    </label>
                    <span class="lb-filter-price__sep" aria-hidden="true">&ndash;</span>
                    <label class="lb-filter-price__field">
                      <span>Max</span>
                      <input
                        type="number"
                        name="{{ filter.max_value.param_name }}"
                        value="{{ filter.max_value.value }}"
                        placeholder="{{ filter.range_max | money_without_currency }}"
                        min="0"
                      >
                    </label>
                  </div>

              {%- endcase -%}
            </div>
          {%- endfor -%}

          <button type="submit" class="lb-btn lb-filters__apply">
            {{ section.settings.apply_filters_text | default: 'Apply Filters' }}
          </button>
        </aside>
      {%- endif -%}

      {%- comment %} ---------------- Product grid + pagination ---------------- {% endcomment -%}
      <div class="lb-collection-results">

        {%- paginate collection.products by section.settings.products_per_page -%}

          {%- if collection.products.size > 0 -%}
            <div
              class="lb-collection-main__grid"
              style="--lb-columns-desktop: {{ columns_desktop }}; --lb-columns-mobile: {{ columns_mobile }};"
            >
              {%- for product in collection.products -%}
                <article class="lb-product-card">
                  <a href="{{ product.url }}" class="lb-product-card__link">

                    <div class="lb-product-card__media" style="aspect-ratio: {{ aspect_ratio }};">

                      {%- if product.featured_image -%}
                        {{
                          product.featured_image
                          | image_url: width: 900
                          | image_tag: loading: 'lazy', class: 'lb-product-card__img lb-product-card__img--primary', alt: product.featured_image.alt | default: product.title
                        }}
                      {%- else -%}
                        <div class="lb-product-card__placeholder"></div>
                      {%- endif -%}

                      {%- if section.settings.show_secondary_image and product.media[1] -%}
                        {{
                          product.media[1]
                          | image_url: width: 900
                          | image_tag: loading: 'lazy', class: 'lb-product-card__img lb-product-card__img--secondary', alt: ''
                        }}
                      {%- endif -%}

                      <div class="lb-product-card__badges">
                        {%- if product.available == false -%}
                          <span class="lb-badge lb-badge--sold-out">
                            {{ section.settings.sold_out_text | default: 'Sold Out' }}
                          </span>
                        {%- elsif product.compare_at_price > product.price -%}
                          <span class="lb-badge lb-badge--sale">
                            {{ section.settings.sale_badge_text | default: 'Sale' }}
                          </span>
                        {%- endif -%}
                      </div>

                    </div>

                    <div class="lb-product-card__info">

                      {%- if section.settings.show_vendor and product.vendor != blank -%}
                        <p class="lb-product-card__vendor">{{ product.vendor }}</p>
                      {%- endif -%}

                      <h3>{{ product.title }}</h3>

                      <p class="lb-product-card__price">
                        {%- if product.price_varies -%}
                          {{ 'products.general.from_text' | default: 'From' }} {{ product.price_min | money }}
                        {%- else -%}
                          {{ product.price | money }}
                        {%- endif -%}

                        {%- if product.compare_at_price > product.price -%}
                          <s class="lb-product-card__compare-price">{{ product.compare_at_price | money }}</s>
                        {%- endif -%}
                      </p>

                    </div>

                  </a>
                </article>
              {%- endfor -%}
            </div>
          {%- else -%}
            <p class="lb-empty-state">
              {{ section.settings.empty_state_text | default: 'Add products to this collection to populate this page.' }}
            </p>
          {%- endif -%}

          {%- if paginate.pages > 1 -%}
            <nav class="lb-pagination" role="navigation" aria-label="Pagination">
              <ul class="lb-pagination__list">

                {%- if paginate.previous -%}
                  <li>
                    <a href="{{ paginate.previous.url }}" class="lb-pagination__link lb-pagination__link--prev" rel="prev">
                      &larr; {{ 'general.pagination.previous' | default: 'Previous' }}
                    </a>
                  </li>
                {%- endif -%}

                {%- for part in paginate.parts -%}
                  <li>
                    {%- if part.is_link -%}
                      <a href="{{ part.url }}" class="lb-pagination__link">{{ part.title }}</a>
                    {%- else -%}
                      {%- if part.title == paginate.current_page -%}
                        <span class="lb-pagination__link is-current" aria-current="page">{{ part.title }}</span>
                      {%- else -%}
                        <span class="lb-pagination__link lb-pagination__link--gap">{{ part.title }}</span>
                      {%- endif -%}
                    {%- endif -%}
                  </li>
                {%- endfor -%}

                {%- if paginate.next -%}
                  <li>
                    <a href="{{ paginate.next.url }}" class="lb-pagination__link lb-pagination__link--next" rel="next">
                      {{ 'general.pagination.next' | default: 'Next' }} &rarr;
                    </a>
                  </li>
                {%- endif -%}

              </ul>
            </nav>
          {%- endif -%}

        {%- endpaginate -%}

      </div>

    </div>

  </form>

</section>

{% style %}
  .lb-collection-{{ section.id }} .lb-collection-header {
    display: grid;
    max-width: var(--lb-page-width);
    gap: 16px;
    margin: 0 auto 34px;
  }

  .lb-collection-{{ section.id }} .lb-collection-banner {
    margin-bottom: 12px;
  }

  .lb-collection-{{ section.id }} .lb-collection-banner__img {
    width: 100%;
    max-height: 420px;
    object-fit: cover;
  }

  .lb-collection-{{ section.id }} .lb-collection-main__description {
    color: var(--lb-muted);
    font-size: 15px;
    line-height: 1.8;
  }

  .lb-collection-{{ section.id }} .lb-collection-toolbar-form {
    max-width: var(--lb-page-width);
    margin: 0 auto;
  }

  .lb-collection-{{ section.id }} .lb-collection-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--lb-wall);
    margin-bottom: 24px;
  }

  .lb-collection-{{ section.id }} .lb-filter-toggle {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    border: 1px solid var(--lb-wall);
    color: var(--lb-white);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .14em;
    text-transform: uppercase;
    padding: 10px 18px;
    cursor: pointer;
    transition: border-color .2s ease, color .2s ease;
  }

  .lb-collection-{{ section.id }} .lb-filter-toggle:hover,
  .lb-collection-{{ section.id }} .lb-filter-toggle[aria-expanded="true"] {
    border-color: var(--lb-blue);
    color: var(--lb-blue);
  }

  .lb-collection-{{ section.id }} .lb-filter-toggle__count {
    color: var(--lb-blue);
  }

  .lb-collection-{{ section.id }} .lb-results-count {
    color: var(--lb-muted);
    font-size: 12px;
    letter-spacing: .04em;
    margin: 0;
  }

  .lb-collection-{{ section.id }} .lb-sort {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-left: auto;
  }

  .lb-collection-{{ section.id }} .lb-sort__label {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--lb-muted);
  }

  .lb-collection-{{ section.id }} .lb-sort__select {
    background: var(--lb-ink);
    color: var(--lb-white);
    border: 1px solid var(--lb-wall);
    padding: 10px 14px;
    font-size: 12px;
    font-family: 'Inter', sans-serif;
  }

  .lb-collection-{{ section.id }} .lb-active-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    max-width: var(--lb-page-width);
    margin: -8px auto 24px;
  }

  .lb-collection-{{ section.id }} .lb-active-filter {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--lb-ink);
    border: 1px solid var(--lb-wall);
    color: var(--lb-muted);
    font-size: 11px;
    letter-spacing: .04em;
    padding: 6px 12px;
    transition: color .2s ease, border-color .2s ease;
  }

  .lb-collection-{{ section.id }} .lb-active-filter:hover {
    color: var(--lb-blue);
    border-color: var(--lb-blue);
  }

  .lb-collection-{{ section.id }} .lb-active-filter--clear {
    color: var(--lb-blue);
    border-color: var(--lb-blue);
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: .12em;
  }

  .lb-collection-{{ section.id }} .lb-collection-layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 40px;
    max-width: var(--lb-page-width);
    margin: 0 auto;
    align-items: start;
  }

  .lb-collection-{{ section.id }} .lb-collection-layout:has(.lb-collection-results:only-child) {
    grid-template-columns: 1fr;
  }

  .lb-collection-{{ section.id }} .lb-filters {
    display: grid;
    gap: 28px;
    position: sticky;
    top: 96px;
  }

  .lb-collection-{{ section.id }} .lb-filters[hidden] {
    display: none;
  }

  .lb-collection-{{ section.id }} .lb-filter-group__title {
    font-family: 'Oswald', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--lb-white);
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 0.5px solid var(--lb-wall);
  }

  .lb-collection-{{ section.id }} .lb-filter-values {
    list-style: none;
    display: grid;
    gap: 10px;
    margin: 0;
    padding: 0;
  }

  .lb-collection-{{ section.id }} .lb-filter-value__label {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: var(--lb-muted);
    cursor: pointer;
  }

  .lb-collection-{{ section.id }} .lb-filter-value__label.is-disabled {
    opacity: .35;
    cursor: not-allowed;
  }

  .lb-collection-{{ section.id }} .lb-filter-value__count {
    color: var(--lb-concrete);
    font-size: 11px;
  }

  .lb-collection-{{ section.id }} .lb-filter-price {
    display: flex;
    align-items: flex-end;
    gap: 10px;
  }

  .lb-collection-{{ section.id }} .lb-filter-price__field {
    display: grid;
    gap: 6px;
    font-size: 10px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--lb-muted);
    flex: 1;
  }

  .lb-collection-{{ section.id }} .lb-filter-price__field input {
    background: var(--lb-ink);
    border: 1px solid var(--lb-wall);
    color: var(--lb-white);
    padding: 10px;
    width: 100%;
  }

  .lb-collection-{{ section.id }} .lb-filters__apply {
    width: 100%;
  }

  .lb-collection-{{ section.id }} .lb-collection-main__grid {
    grid-template-columns: repeat(var(--lb-columns-desktop, 3), minmax(0, 1fr));
  }

  .lb-collection-{{ section.id }} .lb-product-card__link {
    display: grid;
    gap: 14px;
  }

  .lb-collection-{{ section.id }} .lb-product-card__media {
    position: relative;
    overflow: hidden;
    background: var(--lb-ink);
  }

  .lb-collection-{{ section.id }} .lb-product-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .lb-collection-{{ section.id }} .lb-product-card__img--primary,
  .lb-collection-{{ section.id }} .lb-product-card__img--secondary {
    position: absolute;
    inset: 0;
    transition: opacity .35s ease;
  }

  .lb-collection-{{ section.id }} .lb-product-card__img--secondary {
    opacity: 0;
  }

  .lb-collection-{{ section.id }} .lb-product-card:hover .lb-product-card__img--secondary {
    opacity: 1;
  }

  .lb-collection-{{ section.id }} .lb-product-card__placeholder {
    width: 100%;
    height: 100%;
    background: var(--lb-wall);
  }

  .lb-collection-{{ section.id }} .lb-product-card__badges {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 2;
    display: flex;
    gap: 6px;
  }

  .lb-collection-{{ section.id }} .lb-badge {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    padding: 5px 10px;
  }

  .lb-collection-{{ section.id }} .lb-badge--sale {
    background: var(--lb-blue);
    color: var(--lb-void);
  }

  .lb-collection-{{ section.id }} .lb-badge--sold-out {
    background: var(--lb-concrete);
    color: var(--lb-white);
  }

  .lb-collection-{{ section.id }} .lb-product-card__vendor {
    color: var(--lb-concrete);
    font-size: 10px;
    letter-spacing: .12em;
    text-transform: uppercase;
    margin: 0;
  }

  .lb-collection-{{ section.id }} .lb-product-card__price {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .lb-collection-{{ section.id }} .lb-product-card__compare-price {
    color: var(--lb-concrete);
    font-weight: 400;
    font-size: 12px;
  }

  .lb-collection-{{ section.id }} .lb-pagination {
    margin-top: 48px;
  }

  .lb-collection-{{ section.id }} .lb-pagination__list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 8px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .lb-collection-{{ section.id }} .lb-pagination__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 38px;
    min-height: 38px;
    padding: 0 12px;
    border: 1px solid var(--lb-wall);
    color: var(--lb-muted);
    font-size: 12px;
    transition: border-color .2s ease, color .2s ease;
  }

  .lb-collection-{{ section.id }} .lb-pagination__link:hover {
    border-color: var(--lb-blue);
    color: var(--lb-blue);
  }

  .lb-collection-{{ section.id }} .lb-pagination__link.is-current {
    background: var(--lb-blue);
    border-color: var(--lb-blue);
    color: var(--lb-void);
  }

  .lb-collection-{{ section.id }} .lb-pagination__link--gap {
    border: none;
    color: var(--lb-concrete);
  }

  @media (max-width: 960px) {
    .lb-collection-{{ section.id }} .lb-collection-layout {
      grid-template-columns: 1fr;
    }

    .lb-collection-{{ section.id }} .lb-filters {
      position: fixed;
      inset: 0;
      z-index: 200;
      background: var(--lb-void);
      padding: 90px 24px 24px;
      overflow-y: auto;
      top: 0;
    }

    .lb-collection-{{ section.id }} .lb-sort {
      margin-left: 0;
    }
  }

  @media (max-width: 640px) {
    .lb-collection-{{ section.id }} .lb-collection-main__grid {
      grid-template-columns: repeat(var(--lb-columns-mobile, 2), minmax(0, 1fr));
    }

    .lb-collection-{{ section.id }} .lb-collection-toolbar {
      flex-direction: column;
      align-items: flex-start;
    }
  }
{% endstyle %}

<script>
  (function () {
    var root = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!root) return;

    var toggle = root.querySelector('#lb-filter-toggle-{{ section.id }}');
    var panel = root.querySelector('#lb-filters-{{ section.id }}');

    if (toggle && panel) {
      toggle.addEventListener('click', function () {
        var isOpen = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!isOpen));
        if (isOpen) {
          panel.setAttribute('hidden', '');
        } else {
          panel.removeAttribute('hidden');
        }
      });
    }

    // Progressive enhancement: auto-submit the form when a filter or sort
    // control changes, so the page updates without requiring the manual
    // "Apply Filters" button. The button remains functional without JS.
    var form = root.querySelector('#lb-collection-form-{{ section.id }}');
    if (form) {
      form.querySelectorAll('[data-lb-auto-submit]').forEach(function (input) {
        input.addEventListener('change', function () {
          form.requestSubmit ? form.requestSubmit() : form.submit();
        });
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Main Collection",
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
