<section class="lb-collection" style="background:{{ section.settings.bg_color }};">

  {%- comment -%} PAGE HEADER {%- endcomment -%}
  <div class="lb-collection__header" style="background:{{ section.settings.header_bg }};">
    <div class="lb-collection__header-inner">
      {% if section.settings.show_eyebrow %}
        <span class="lb-collection__eyebrow" style="color:{{ section.settings.accent_color }};">
          {{ section.settings.eyebrow | default: collection.title }}
        </span>
      {% endif %}
      <h1 class="lb-collection__title" style="color:{{ section.settings.text_color }};">
        {{ collection.title }}
      </h1>
      {% if collection.description != blank and section.settings.show_description %}
        <div class="lb-collection__desc" style="color:{{ section.settings.muted_color }};">
          {{ collection.description }}
        </div>
      {% endif %}
      <p class="lb-collection__count" style="color:{{ section.settings.muted_color }};">
        {{ collection.products_count }}
        {{ collection.products_count | pluralize: 'product', 'products' }}
      </p>
    </div>
  </div>

  {%- comment -%} TOOLBAR {%- endcomment -%}
  {% if section.settings.show_sort or section.settings.show_filter_count %}
  <div class="lb-collection__toolbar" style="border-color:rgba(255,255,255,0.08);">
    {% if section.settings.show_filter_count %}
      <span class="lb-collection__filter-count" style="color:{{ section.settings.muted_color }};">
        Showing {{ collection.products_count }} results
      </span>
    {% endif %}
    {% if section.settings.show_sort %}
      <div class="lb-collection__sort">
        <label for="lb-sort" style="color:{{ section.settings.muted_color }};">Sort by</label>
        <select id="lb-sort" class="lb-collection__sort-select" style="color:{{ section.settings.text_color }};border-color:rgba(255,255,255,0.15);background:{{ section.settings.bg_color }};" onchange="window.location.href=this.value">
          <option value="{{ collection.url }}?sort_by=manual"{% if collection.sort_by == 'manual' %} selected{% endif %}>Featured</option>
          <option value="{{ collection.url }}?sort_by=best-selling"{% if collection.sort_by == 'best-selling' %} selected{% endif %}>Best Selling</option>
          <option value="{{ collection.url }}?sort_by=price-ascending"{% if collection.sort_by == 'price-ascending' %} selected{% endif %}>Price: Low to High</option>
          <option value="{{ collection.url }}?sort_by=price-descending"{% if collection.sort_by == 'price-descending' %} selected{% endif %}>Price: High to Low</option>
          <option value="{{ collection.url }}?sort_by=created-descending"{% if collection.sort_by == 'created-descending' %} selected{% endif %}>Newest</option>
          <option value="{{ collection.url }}?sort_by=title-ascending"{% if collection.sort_by == 'title-ascending' %} selected{% endif %}>A–Z</option>
        </select>
      </div>
    {% endif %}
  </div>
  {% endif %}

  {%- comment -%} PRODUCT GRID {%- endcomment -%}
  <div
    class="lb-collection__grid"
    style="
      padding: {{ section.settings.padding_top }}px 60px {{ section.settings.padding_bottom }}px;
      grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
      gap: {{ section.settings.grid_gap }}px;
    "
  >
    {% paginate collection.products by section.settings.products_per_page %}

      {% for product in collection.products %}
        {% render 'lb-product-card',
          product: product,
          accent_color: section.settings.accent_color,
          card_bg: section.settings.card_bg,
          text_color: section.settings.text_color,
          muted_color: section.settings.muted_color,
          show_vendor: section.settings.show_vendor,
          show_badge: section.settings.show_badge
        %}
      {% else %}
        <div class="lb-collection__empty" style="color:{{ section.settings.muted_color }};">
          <p>{{ section.settings.empty_text | default: 'No products found in this collection.' }}</p>
        </div>
      {% endfor %}

      {%- comment -%} PAGINATION {%- endcomment -%}
      {% if paginate.pages > 1 %}
        <div class="lb-collection__pagination">
          {% if paginate.previous %}
            <a href="{{ paginate.previous.url }}" class="lb-pagination__btn" style="color:{{ section.settings.text_color }};border-color:rgba(255,255,255,0.15);">
              &larr; Previous
            </a>
          {% endif %}
          {% for part in paginate.parts %}
            {% if part.is_link %}
              <a href="{{ part.url }}" class="lb-pagination__btn" style="color:{{ section.settings.muted_color }};border-color:rgba(255,255,255,0.1);">{{ part.title }}</a>
            {% elsif part.title == paginate.current_page %}
              <span class="lb-pagination__btn lb-pagination__btn--active" style="background:{{ section.settings.accent_color }};color:#000;border-color:{{ section.settings.accent_color }};">{{ part.title }}</span>
            {% else %}
              <span class="lb-pagination__ellipsis" style="color:{{ section.settings.muted_color }};">{{ part.title }}</span>
            {% endif %}
          {% endfor %}
          {% if paginate.next %}
            <a href="{{ paginate.next.url }}" class="lb-pagination__btn" style="color:{{ section.settings.text_color }};border-color:rgba(255,255,255,0.15);">
              Next &rarr;
            </a>
          {% endif %}
        </div>
      {% endif %}

    {% endpaginate %}
  </div>

</section>

<style>
  .lb-collection__header {
    padding: {{ section.settings.header_padding }}px 60px;
    border-bottom: 0.5px solid rgba(255,255,255,0.08);
  }
  .lb-collection__header-inner { max-width: 800px; }
  .lb-collection__eyebrow {
    display: block;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .lb-collection__title {
    font-size: clamp(28px, 5vw, 60px);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.0;
    margin: 0 0 14px;
    text-transform: uppercase;
  }
  .lb-collection__desc {
    font-size: 15px;
    line-height: 1.75;
    max-width: 560px;
    margin-bottom: 12px;
  }
  .lb-collection__count {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0;
  }

  .lb-collection__toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 60px;
    border-bottom: 0.5px solid;
    flex-wrap: wrap;
    gap: 12px;
  }
  .lb-collection__filter-count { font-size: 12px; letter-spacing: 0.06em; }
  .lb-collection__sort { display: flex; align-items: center; gap: 10px; }
  .lb-collection__sort label { font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; }
  .lb-collection__sort-select {
    font-size: 12px;
    padding: 8px 12px;
    border: 1px solid;
    font-family: inherit;
    cursor: pointer;
    outline: none;
  }

  .lb-collection__grid {
    display: grid;
  }
  .lb-collection__empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 80px 0;
    font-size: 15px;
  }

  .lb-collection__pagination {
    grid-column: 1 / -1;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    padding-top: 40px;
    flex-wrap: wrap;
  }
  .lb-pagination__btn {
    padding: 10px 18px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-decoration: none;
    border: 1px solid;
    transition: all 0.2s;
    display: inline-block;
  }
  .lb-pagination__btn:hover { opacity: 0.75; }
  .lb-pagination__btn--active { font-weight: 700; }
  .lb-pagination__ellipsis { padding: 10px 6px; font-size: 12px; }

  @media (max-width: 960px) {
    .lb-collection__header { padding: 40px 24px; }
    .lb-collection__toolbar { padding: 12px 24px; }
    .lb-collection__grid { padding-left: 24px !important; padding-right: 24px !important; grid-template-columns: repeat(2, 1fr) !important; }
  }
  @media (max-width: 540px) {
    .lb-collection__grid { grid-template-columns: 1fr !important; }
  }
</style>

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Page Header" },
    { "type": "checkbox", "id": "show_eyebrow", "label": "Show Eyebrow Label", "default": true },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow Text", "info": "Leave blank to use collection title" },
    { "type": "checkbox", "id": "show_description", "label": "Show Collection Description", "default": true },
    { "type": "range", "id": "header_padding", "label": "Header Padding", "min": 20, "max": 120, "step": 10, "default": 60, "unit": "px" },

    { "type": "header", "content": "Toolbar" },
    { "type": "checkbox", "id": "show_sort", "label": "Show Sort Dropdown", "default": true },
    { "type": "checkbox", "id": "show_filter_count", "label": "Show Product Count", "default": true },

    { "type": "header", "content": "Grid" },
    { "type": "select", "id": "columns", "label": "Columns (desktop)", "options": [
      { "value": "2", "label": "2 Columns" },
      { "value": "3", "label": "3 Columns" },
      { "value": "4", "label": "4 Columns" }
    ], "default": "3" },
    { "type": "range", "id": "products_per_page", "label": "Products Per Page", "min": 6, "max": 48, "step": 6, "default": 12 },
    { "type": "range", "id": "grid_gap", "label": "Grid Gap", "min": 8, "max": 48, "step": 4, "default": 24, "unit": "px" },
    { "type": "checkbox", "id": "show_vendor", "label": "Show Product Type", "default": true },
    { "type": "checkbox", "id": "show_badge", "label": "Show Sale / New Badges", "default": true },
    { "type": "text", "id": "empty_text", "label": "Empty Collection Message", "default": "No products found in this collection." },

    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "bg_color", "label": "Page Background", "default": "#0A0A0A" },
    { "type": "color", "id": "header_bg", "label": "Header Background", "default": "#111111" },
    { "type": "color", "id": "card_bg", "label": "Card Background", "default": "#1A1A1A" },
    { "type": "color", "id": "text_color", "label": "Text Colour", "default": "#FFFFFF" },
    { "type": "color", "id": "muted_color", "label": "Muted Text Colour", "default": "#AAAAAA" },
    { "type": "color", "id": "accent_color", "label": "Accent Colour", "default": "#7DD8E8" },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Grid Top Padding", "min": 20, "max": 120, "step": 10, "default": 40, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Grid Bottom Padding", "min": 20, "max": 160, "step": 10, "default": 100, "unit": "px" }
  ]
}
{% endschema %}
