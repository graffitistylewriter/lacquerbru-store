{% assign projects = shop.metaobjects.project.values %}

<section class="lb-project-grid">

  <div class="lb-project-grid__header">
    {% if section.settings.eyebrow != blank %}
      <p class="lb-kicker">{{ section.settings.eyebrow }}</p>
    {% endif %}
    <h2>{{ section.settings.heading }}</h2>
    {% if section.settings.copy != blank %}
      <p>{{ section.settings.copy }}</p>
    {% endif %}
  </div>

  {% if section.settings.show_filters %}
    <div class="lb-project-grid__filters" data-lb-project-filters>
      <button class="lb-filter-button is-active" type="button" data-category="all">All</button>
      {% assign categories_string = '' %}
      {% for project in projects %}
        {% assign project_category = project.category.value | default: project.category %}
        {% if project_category != blank %}
          {% assign category_token = project_category | strip | append: '||' %}
          {% unless categories_string contains category_token %}
            {% assign categories_string = categories_string | append: category_token %}
          {% endunless %}
        {% endif %}
      {% endfor %}
      {% assign categories = categories_string | split: '||' %}
      {% for category in categories %}
        {% if category != blank %}
          <button class="lb-filter-button" type="button" data-category="{{ category | handleize }}">{{ category }}</button>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}

  <div class="lb-project-grid__grid" data-lb-project-grid>
    {% assign visible_count = 0 %}
    {% for project in projects %}
      {% assign project_featured = project.featured.value | default: project.featured %}
      {% assign project_category = project.category.value | default: project.category %}
      {% assign project_title = project.title.value | default: project.title %}
      {% assign project_summary = project.summary.value | default: project.summary %}
      {% assign project_image = project.featured_image.value | default: project.featured_image %}
      {% assign project_url = project.system.url %}
      {% assign project_handle = project.system.handle %}

      {% if section.settings.only_featured and project_featured != true and project_featured != 'true' %}
        {% continue %}
      {% endif %}
      {% if section.settings.category != blank and project_category != section.settings.category %}
        {% continue %}
      {% endif %}

      {% assign visible_count = visible_count | plus: 1 %}

      {% if visible_count <= section.settings.limit %}
        <article
          class="lb-project-card"
          data-project-category="{{ project_category | handleize }}"
          data-project-title="{{ project_title | escape }}"
          data-project-summary="{{ project_summary | escape }}"
          data-project-category-label="{{ project_category | escape }}"
          data-project-url="{{ project_url }}"
          data-project-image="{{ project_image | image_url: width: 1400 }}"
          role="button"
          tabindex="0"
          aria-label="View {{ project_title }}"
        >
          {% if project_image != blank %}
            {{
              project_image
              | image_url: width: 1200
              | image_tag:
                class: 'lb-project-card__image',
                loading: 'lazy',
                draggable: 'false'
            }}
          {% endif %}
          <div class="lb-project-card__content">
            {% if project_category != blank %}
              <p class="lb-project-card__category">{{ project_category }}</p>
            {% endif %}
            <h3>{{ project_title }}</h3>
            {% if project_summary != blank %}
              <p>{{ project_summary }}</p>
            {% endif %}
            <span class="lb-project-card__cta">View Project →</span>
          </div>
          <div class="lb-project-card__shield"></div>
        </article>
      {% endif %}
    {% endfor %}

    {% if visible_count == 0 %}
      <p class="lb-empty-state">Add Project metaobjects in Shopify Admin to populate this section.</p>
    {% endif %}
  </div>

</section>

{%- comment -%} ── PROJECT LIGHTBOX ── {%- endcomment -%}
<div id="lbpg-lightbox" aria-hidden="true">
  <div id="lbpg-backdrop"></div>
  <div id="lbpg-panel">
    <button id="lbpg-close" aria-label="Close">✕</button>
    <div id="lbpg-body">
      <div id="lbpg-img-wrap">
        <img id="lbpg-img" src="" alt="" draggable="false">
        <div id="lbpg-img-shield"></div>
      </div>
      <div id="lbpg-content">
        <p id="lbpg-category"></p>
        <h2 id="lbpg-title"></h2>
        <p id="lbpg-summary"></p>
        <a id="lbpg-link" href="#">View Full Project →</a>
      </div>
    </div>
  </div>
</div>

<style>
  .lb-project-grid__header { padding: 0 60px; margin-bottom: 48px; }
  .lb-project-grid__header h2 { font-size: clamp(1.8rem, 3vw, 2.8rem); font-weight: 900; text-transform: uppercase; letter-spacing: 0.03em; margin: 8px 0 12px; }
  .lb-project-grid__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; padding: 0 60px; }

  .lb-project-card {
    position: relative;
    overflow: hidden;
    cursor: pointer;
    aspect-ratio: 4/3;
    background: #111;
    display: block;
  }
  .lb-project-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
    pointer-events: none;
    user-select: none;
    -webkit-user-drag: none;
  }
  .lb-project-card:hover .lb-project-card__image { transform: scale(1.04); }
  .lb-project-card__shield {
    position: absolute;
    inset: 0;
    z-index: 2;
  }
  .lb-project-card__content {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 24px;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, transparent 100%);
    z-index: 3;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .lb-project-card:hover .lb-project-card__content { opacity: 1; }
  .lb-project-card__category { font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: #7dd8e8; margin: 0 0 6px; }
  .lb-project-card h3 { font-size: 1rem; font-weight: 700; text-transform: uppercase; color: #fff; margin: 0 0 6px; }
  .lb-project-card p { font-size: 12px; color: #aaa; margin: 0 0 10px; line-height: 1.5; }
  .lb-project-card__cta { font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: #7dd8e8; font-weight: 600; }

  /* ── LIGHTBOX ── */
  #lbpg-lightbox {
    position: fixed; inset: 0; z-index: 10000;
    display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none;
    transition: opacity 0.3s ease;
  }
  #lbpg-lightbox.is-open { opacity: 1; pointer-events: all; }
  #lbpg-backdrop { position: absolute; inset: 0; background: rgba(0,0,0,0.92); }
  #lbpg-panel {
    position: relative; z-index: 1;
    background: #0a0a0a;
    width: min(900px, 92vw);
    max-height: 90vh;
    overflow-y: auto;
    transform: translateY(20px);
    transition: transform 0.35s cubic-bezier(0.16,1,0.3,1);
  }
  #lbpg-lightbox.is-open #lbpg-panel { transform: translateY(0); }
  #lbpg-close {
    position: absolute; top: 16px; right: 16px;
    background: none; border: none; color: #fff;
    font-size: 18px; cursor: pointer; z-index: 10;
    transition: color 0.2s;
  }
  #lbpg-close:hover { color: #7dd8e8; }
  #lbpg-body { display: flex; flex-direction: column; }
  #lbpg-img-wrap { position: relative; aspect-ratio: 16/8; overflow: hidden; }
  #lbpg-img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    pointer-events: none; user-select: none; -webkit-user-drag: none;
  }
  #lbpg-img-shield { position: absolute; inset: 0; z-index: 2; }
  #lbpg-content { padding: 32px; }
  #lbpg-category { font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: #7dd8e8; margin: 0 0 10px; }
  #lbpg-title { font-size: clamp(1.2rem, 2.5vw, 1.8rem); font-weight: 900; text-transform: uppercase; color: #fff; margin: 0 0 14px; letter-spacing: 0.03em; }
  #lbpg-summary { font-size: 13px; color: #aaa; line-height: 1.8; margin: 0 0 24px; }
  #lbpg-link { font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: #7dd8e8; text-decoration: none; font-weight: 600; transition: opacity 0.2s; }
  #lbpg-link:hover { opacity: 0.7; }

  @media (max-width: 860px) {
    .lb-project-grid__header { padding: 0 24px; }
    .lb-project-grid__grid { grid-template-columns: 1fr; padding: 0 24px; }
  }
</style>

<script>
(function() {
  var lightbox = document.getElementById('lbpg-lightbox');
  var backdrop = document.getElementById('lbpg-backdrop');
  var closeBtn = document.getElementById('lbpg-close');
  var lbImg = document.getElementById('lbpg-img');
  var lbCategory = document.getElementById('lbpg-category');
  var lbTitle = document.getElementById('lbpg-title');
  var lbSummary = document.getElementById('lbpg-summary');
  var lbLink = document.getElementById('lbpg-link');

  function openLightbox(card) {
    lbImg.src = card.dataset.projectImage || '';
    lbImg.alt = card.dataset.projectTitle || '';
    lbCategory.textContent = card.dataset.projectCategoryLabel || '';
    lbTitle.textContent = card.dataset.projectTitle || '';
    lbSummary.textContent = card.dataset.projectSummary || '';
    lbLink.href = card.dataset.projectUrl || '#';
    lbSummary.style.display = card.dataset.projectSummary ? '' : 'none';
    lightbox.classList.add('is-open');
    lightbox.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    document.getElementById('lbpg-panel').scrollTop = 0;
  }

  function closeLightbox() {
    lightbox.classList.remove('is-open');
    lightbox.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    setTimeout(function() { lbImg.src = ''; }, 300);
  }

  document.querySelectorAll('.lb-project-card').forEach(function(card) {
    card.addEventListener('click', function() { openLightbox(card); });
    card.addEventListener('keydown', function(e) { if (e.key === 'Enter' || e.key === ' ') openLightbox(card); });
  });

  closeBtn.addEventListener('click', closeLightbox);
  backdrop.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && lightbox.classList.contains('is-open')) closeLightbox();
  });

  /* ── IMAGE PROTECTION ── */
  document.querySelectorAll('.lb-project-card__image, #lbpg-img').forEach(function(img) {
    img.addEventListener('contextmenu', function(e) { e.preventDefault(); });
    img.setAttribute('draggable', 'false');
  });
})();
</script>

{% schema %}
{
  "name": "LB Project Grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Portfolio" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Featured Projects" },
    { "type": "textarea", "id": "copy", "label": "Intro Copy", "default": "Murals, campaigns, installations, and commercial creative work." },
    { "type": "checkbox", "id": "only_featured", "label": "Only Show Featured Projects", "default": false },
    { "type": "text", "id": "category", "label": "Category Filter", "info": "Optional. Must match the Project Category field exactly." },
    { "type": "checkbox", "id": "show_filters", "label": "Show Category Filter Buttons", "default": false },
    { "type": "range", "id": "limit", "label": "Projects To Show", "min": 3, "max": 24, "step": 1, "default": 6 }
  ],
  "presets": [{ "name": "LB Project Grid" }]
}
{% endschema %}
