{% assign projects = shop.metaobjects.project.values %}

<section class="lb-project-grid">

  <div class="lb-project-grid__header">
    {% if section.settings.eyebrow != blank %}
      <p class="lb-kicker">{{ section.settings.eyebrow }}</p>
    {% endif %}
    <h2>{{ section.settings.heading }}</h2>
    {% if section.settings.copy != blank %}
      <p>{{ section.settings.copy }}</p>
    {% endif %}
  </div>

  {% if section.settings.show_filters %}
    <div class="lb-project-grid__filters" data-lb-project-filters>
      <button class="lb-filter-button is-active" type="button" data-category="all">All</button>
      {% assign categories_string = '' %}
      {% for project in projects %}
        {% assign project_category = project.category.value | default: project.category %}
        {% if project_category != blank %}
          {% assign category_token = project_category | strip | append: '||' %}
          {% unless categories_string contains category_token %}
            {% assign categories_string = categories_string | append: category_token %}
          {% endunless %}
        {% endif %}
      {% endfor %}
      {% assign categories = categories_string | split: '||' %}
      {% for category in categories %}
        {% if category != blank %}
          <button class="lb-filter-button" type="button" data-category="{{ category | handleize }}">{{ category }}</button>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}

  <div class="lb-project-grid__grid" data-lb-project-grid>
    {% assign visible_count = 0 %}
    {% for project in projects %}
      {% assign project_featured = project.featured.value | default: project.featured %}
      {% assign project_category = project.category.value | default: project.category %}
      {% assign project_title = project.title.value | default: project.title %}
      {% assign project_summary = project.summary.value | default: project.summary %}
      {% assign project_image = project.featured_image.value | default: project.featured_image %}
      {% assign project_handle = project.system.handle %}
      {% assign project_client = project.client.value | default: '' %}
      {% assign project_year = project.completion_date.value | date: "%Y" %}
      {% assign project_story = project.story.value | default: '' %}
      {% assign project_hero_url = project_image | image_url: width: 1600 %}

      {% if section.settings.only_featured and project_featured != true and project_featured != 'true' %}
        {% continue %}
      {% endif %}
      {% if section.settings.category != blank and project_category != section.settings.category %}
        {% continue %}
      {% endif %}

      {% assign visible_count = visible_count | plus: 1 %}

      {% if visible_count <= section.settings.limit %}
        <article
          class="lb-project-card"
          data-project-category="{{ project_category | handleize }}"
          data-project-handle="{{ project_handle }}"
          data-title="{{ project_title | escape }}"
          data-category="{{ project_category | escape }}"
          data-year="{{ project_year }}"
          data-client="{{ project_client | escape }}"
          data-summary="{{ project_summary | escape }}"
          data-story="{{ project_story | escape }}"
          data-hero="{{ project_hero_url }}"
          data-gallery="{% for gimg in project.gallery.value %}{{ gimg | image_url: width: 1200 }}{% unless forloop.last %}|{% endunless %}{% endfor %}"
          role="button"
          tabindex="0"
          aria-label="View {{ project_title }}"
        >
          {% if project_image != blank %}
            {{ project_image | image_url: width: 1200 | image_tag: class: 'lb-project-card__image', loading: 'lazy', draggable: 'false' }}
          {% endif %}
          <div class="lb-project-card__content">
            {% if project_category != blank %}
              <p class="lb-project-card__category">{{ project_category }}</p>
            {% endif %}
            <h3>{{ project_title }}</h3>
            {% if project_summary != blank %}
              <p>{{ project_summary | truncate: 100 }}</p>
            {% endif %}
            <span class="lb-project-card__cta">View Project →</span>
          </div>
          <div class="lb-project-card__shield"></div>
        </article>
      {% endif %}
    {% endfor %}

    {% if visible_count == 0 %}
      <p class="lb-empty-state">Add Project metaobjects in Shopify Admin to populate this section.</p>
    {% endif %}
  </div>

</section>

<div id="lbpg-lightbox" aria-hidden="true">
  <div id="lbpg-backdrop"></div>
  <div id="lbpg-panel">
    <button id="lbpg-close" aria-label="Close">✕</button>
    <div id="lbpg-content">
      <div id="lbpg-hero">
        <img id="lbpg-hero-img" src="data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs=" alt="" draggable="false">
        <div id="lbpg-hero-overlay"></div>
        <div id="lbpg-hero-text">
          <p id="lbpg-kicker"></p>
          <h2 id="lbpg-title"></h2>
          <p id="lbpg-summary"></p>
        </div>
      </div>
      <div id="lbpg-meta-strip">
        <div class="lbpg-meta-item" id="lbpg-client-wrap">
          <span class="lbpg-meta-label">Client</span>
          <span class="lbpg-meta-value" id="lbpg-client"></span>
        </div>
        <div class="lbpg-meta-item" id="lbpg-type-wrap">
          <span class="lbpg-meta-label">Type</span>
          <span class="lbpg-meta-value" id="lbpg-type"></span>
        </div>
        <div class="lbpg-meta-item" id="lbpg-year-wrap">
          <span class="lbpg-meta-label">Year</span>
          <span class="lbpg-meta-value" id="lbpg-year"></span>
        </div>
      </div>
      <div id="lbpg-story-wrap">
        <p class="lbpg-section-label">Project Story</p>
        <div id="lbpg-story"></div>
      </div>
      <div id="lbpg-gallery-wrap">
        <p class="lbpg-section-label">Project Gallery</p>
        <div id="lbpg-gallery-grid"></div>
      </div>
      <div id="lbpg-footer">
        <a id="lbpg-more-link" href="/pages/featured-projects">View More Projects →</a>
      </div>
    </div>
  </div>
</div>
<script>
(function() {
  var lightbox = document.getElementById('lbpg-lightbox');
  var backdrop = document.getElementById('lbpg-backdrop');
  var closeBtn = document.getElementById('lbpg-close');
  var heroImg = document.getElementById('lbpg-hero-img');
  var kicker = document.getElementById('lbpg-kicker');
  var title = document.getElementById('lbpg-title');
  var summary = document.getElementById('lbpg-summary');
  var client = document.getElementById('lbpg-client');
  var clientWrap = document.getElementById('lbpg-client-wrap');
  var type = document.getElementById('lbpg-type');
  var typeWrap = document.getElementById('lbpg-type-wrap');
  var year = document.getElementById('lbpg-year');
  var yearWrap = document.getElementById('lbpg-year-wrap');
  var story = document.getElementById('lbpg-story');
  var storyWrap = document.getElementById('lbpg-story-wrap');
  var galleryGrid = document.getElementById('lbpg-gallery-grid');
  var galleryWrap = document.getElementById('lbpg-gallery-wrap');

  function openLightbox(card) {
    var d = card.dataset;
    heroImg.src = d.hero || '';
    heroImg.alt = d.title || '';
    kicker.textContent = [d.category, d.year].filter(Boolean).join(' · ');
    title.textContent = d.title || '';
    summary.textContent = d.summary || '';
    if (d.client) { client.textContent = d.client; clientWrap.style.display = ''; }
    else { clientWrap.style.display = 'none'; }
    if (d.category) { type.textContent = d.category; typeWrap.style.display = ''; }
    else { typeWrap.style.display = 'none'; }
    if (d.year) { year.textContent = d.year; yearWrap.style.display = ''; }
    else { yearWrap.style.display = 'none'; }
    if (d.story) { story.textContent = d.story; storyWrap.style.display = ''; }
    else { storyWrap.style.display = 'none'; }
    galleryGrid.innerHTML = '';
    if (d.gallery) {
      var imgs = d.gallery.split('|').filter(Boolean);
      if (imgs.length > 0) {
        imgs.forEach(function(src) {
          var img = document.createElement('img');
          img.src = src; img.alt = d.title; img.loading = 'lazy'; img.draggable = false;
          img.addEventListener('contextmenu', function(e){ e.preventDefault(); });
          galleryGrid.appendChild(img);
        });
        galleryWrap.style.display = '';
      } else { galleryWrap.style.display = 'none'; }
    } else { galleryWrap.style.display = 'none'; }
    lightbox.classList.add('is-open');
    lightbox.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    document.getElementById('lbpg-panel').scrollTop = 0;
  }

  function closeLightbox() {
    lightbox.classList.remove('is-open');
    lightbox.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.lb-project-card').forEach(function(card) {
    card.addEventListener('click', function() { openLightbox(card); });
    card.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' || e.key === ' ') openLightbox(card);
    });
  });

  closeBtn.addEventListener('click', closeLightbox);
  backdrop.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && lightbox.classList.contains('is-open')) closeLightbox();
  });

  document.querySelectorAll('.lb-project-card__image').forEach(function(img) {
    img.addEventListener('contextmenu', function(e){ e.preventDefault(); });
  });
})();
</script>

{% schema %}
{
  "name": "LB Project Grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Portfolio" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Featured Projects" },
    { "type": "textarea", "id": "copy", "label": "Intro Copy", "default": "Murals, campaigns, installations, and commercial creative work." },
    { "type": "checkbox", "id": "only_featured", "label": "Only Show Featured Projects", "default": false },
    { "type": "text", "id": "category", "label": "Category Filter", "info": "Optional. Must match the Project Category field exactly." },
    { "type": "checkbox", "id": "show_filters", "label": "Show Category Filter Buttons", "default": false },
    { "type": "range", "id": "limit", "label": "Projects To Show", "min": 3, "max": 24, "step": 1, "default": 6 }
  ],
  "presets": [{ "name": "LB Project Grid" }]
}
{% endschema %}
