{% comment %} lb-product-grid.liquid {% endcomment %}

{%- assign bg = section.settings.bg_color -%}
{%- assign card_bg = section.settings.card_bg -%}
{%- assign text_col = section.settings.text_color -%}
{%- assign muted = section.settings.muted_color -%}
{%- assign accent = section.settings.accent_color -%}
{%- assign cols = section.settings.columns | plus: 0 -%}
{%- assign gap = section.settings.grid_gap -%}
{%- assign pt = section.settings.padding_top -%}
{%- assign pb = section.settings.padding_bottom -%}

<style>
  #lb-grid-{{ section.id }} {
    background: {{ bg }};
    padding: {{ pt }}px 0 {{ pb }}px;
  }
  #lb-grid-{{ section.id }} .lb-grid__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
  }
  #lb-grid-{{ section.id }} .lb-grid__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 48px;
  }
  #lb-grid-{{ section.id }} .lb-grid__label {
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: {{ accent }};
    margin-bottom: 8px;
  }
  #lb-grid-{{ section.id }} .lb-grid__heading {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 700;
    color: {{ text_col }};
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0;
  }
  #lb-grid-{{ section.id }} .lb-grid__count {
    font-size: 12px;
    color: {{ muted }};
    letter-spacing: 0.08em;
  }
  #lb-grid-{{ section.id }} .lb-grid__grid {
    display: grid;
    grid-template-columns: repeat({{ cols }}, 1fr);
    gap: {{ gap }}px;
  }
  @media (max-width: 900px) {
    #lb-grid-{{ section.id }} .lb-grid__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 560px) {
    #lb-grid-{{ section.id }} .lb-grid__grid {
      grid-template-columns: 1fr;
    }
  }
  #lb-grid-{{ section.id }} .lb-grid__card {
    background: {{ card_bg }};
    border: 1px solid #2a2a2a;
    border-radius: 4px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s ease, transform 0.2s ease;
    cursor: pointer;
  }
  #lb-grid-{{ section.id }} .lb-grid__card:hover {
    border-color: {{ accent }};
    transform: translateY(-2px);
  }
  #lb-grid-{{ section.id }} .lb-grid__img-wrap {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: #111;
  }
  #lb-grid-{{ section.id }} .lb-grid__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  #lb-grid-{{ section.id }} .lb-grid__card:hover .lb-grid__img-wrap img {
    transform: scale(1.04);
  }
  #lb-grid-{{ section.id }} .lb-grid__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: {{ accent }};
    color: #0a0a0a;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 2px;
  }
  #lb-grid-{{ section.id }} .lb-grid__body {
    padding: 20px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  #lb-grid-{{ section.id }} .lb-grid__vendor {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: {{ muted }};
  }
  #lb-grid-{{ section.id }} .lb-grid__title {
    font-size: 1rem;
    font-weight: 700;
    color: {{ text_col }};
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1.3;
    margin: 0;
  }
  #lb-grid-{{ section.id }} .lb-grid__price {
    font-size: 1rem;
    color: {{ accent }};
    font-weight: 600;
    margin-top: auto;
    padding-top: 12px;
  }
  #lb-grid-{{ section.id }} .lb-grid__price s {
    color: {{ muted }};
    font-weight: 400;
    margin-left: 8px;
    font-size: 0.85rem;
  }
  #lb-grid-{{ section.id }} .lb-grid__atc {
    margin-top: 12px;
    width: 100%;
    background: transparent;
    border: 1px solid {{ accent }};
    color: {{ accent }};
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 10px 0;
    border-radius: 2px;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }
  #lb-grid-{{ section.id }} .lb-grid__atc:hover {
    background: {{ accent }};
    color: #0a0a0a;
  }
  #lb-grid-{{ section.id }} .lb-grid__empty {
    text-align: center;
    padding: 80px 24px;
    color: {{ muted }};
  }
  #lb-grid-{{ section.id }} .lb-grid__empty-icon {
    font-size: 2.5rem;
    margin-bottom: 16px;
    opacity: 0.4;
  }
  #lb-grid-{{ section.id }} .lb-grid__empty-heading {
    font-size: 1.2rem;
    font-weight: 700;
    color: {{ text_col }};
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 8px;
  }
  #lb-grid-{{ section.id }} .lb-grid__empty-text {
    font-size: 0.9rem;
    color: {{ muted }};
  }
</style>

<section id="lb-grid-{{ section.id }}">
  <div class="lb-grid__inner">

    <div class="lb-grid__header">
      <div>
        {%- if section.settings.label != blank -%}
          <p class="lb-grid__label">{{ section.settings.label }}</p>
        {%- endif -%}
        <h2 class="lb-grid__heading">{{ section.settings.heading | default: collection.title }}</h2>
      </div>
      {%- if collection.products_count > 0 -%}
        <span class="lb-grid__count">{{ collection.products_count }} {{ collection.products_count | pluralize: 'product', 'products' }}</span>
      {%- endif -%}
    </div>

    {%- if collection.products_count > 0 -%}
      <div class="lb-grid__grid">
        {%- for product in collection.products -%}
          <div class="lb-grid__card" data-product-url="{{ product.url }}">
            <div class="lb-grid__img-wrap">
              {%- if product.featured_image -%}
                <img
                  src="{{ product.featured_image | image_url: width: 800 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  loading="lazy"
                  width="800"
                >
              {%- else -%}
                <div style="width:100%;height:100%;background:#1a1a1a;"></div>
              {%- endif -%}
              {%- if product.compare_at_price > product.price -%}
                <span class="lb-grid__badge">Sale</span>
              {%- elsif product.tags contains 'new' -%}
                <span class="lb-grid__badge">New</span>
              {%- endif -%}
            </div>
            <div class="lb-grid__body">
              {%- if section.settings.show_vendor -%}
                <p class="lb-grid__vendor">{{ product.vendor }}</p>
              {%- endif -%}
              <h3 class="lb-grid__title">{{ product.title }}</h3>
              <p class="lb-grid__price">
                {{ product.price | money }}
                {%- if product.compare_at_price > product.price -%}
                  <s>{{ product.compare_at_price | money }}</s>
                {%- endif -%}
              </p>
              <form action="/cart/add" method="post">
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                <button type="submit" class="lb-grid__atc"
                  {%- unless product.available -%} disabled style="opacity:0.4;cursor:not-allowed;"{%- endunless -%}>
                  {%- if product.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
                </button>
              </form>
            </div>
          </div>
        {%- endfor -%}
      </div>

    {%- else -%}
      <div class="lb-grid__empty">
        <div class="lb-grid__empty-icon">◻</div>
        <p class="lb-grid__empty-heading">Nothing Here Yet</p>
        <p class="lb-grid__empty-text">{{ section.settings.empty_text | default: 'New products are on their way. Check back soon.' }}</p>
      </div>
    {%- endif -%}

  </div>
</section>

<script>
  document.querySelectorAll('#lb-grid-{{ section.id }} .lb-grid__card').forEach(function(card) {
    card.addEventListener('click', function(e) {
      if (e.target.closest('form')) return;
      window.location.href = card.dataset.productUrl;
    });
  });
</script>

{% schema %}
{
  "name": "LB Product Grid",
  "tag": "section",
  "class": "lb-product-grid",
  "settings": [
    { "type": "text", "id": "label", "label": "Eyebrow Label", "default": "The Collection" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "All Products" },
    { "type": "textarea", "id": "empty_text", "label": "Empty State Text", "default": "New products are on their way. Check back soon." },
    { "type": "select", "id": "columns", "label": "Columns (desktop)", "options": [
      { "value": "2", "label": "2" },
      { "value": "3", "label": "3" },
      { "value": "4", "label": "4" }
    ], "default": "3" },
    { "type": "range", "id": "grid_gap", "label": "Grid Gap (px)", "min": 8, "max": 48, "step": 4, "default": 24 },
    { "type": "checkbox", "id": "show_vendor", "label": "Show Vendor", "default": true },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#0a0a0a" },
    { "type": "color", "id": "card_bg", "label": "Card Background", "default": "#1a1a1a" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#ffffff" },
    { "type": "color", "id": "muted_color", "label": "Muted Text", "default": "#aaaaaa" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#7dd8e8" },
    { "type": "range", "id": "padding_top", "label": "Padding Top", "min": 0, "max": 200, "step": 8, "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding Bottom", "min": 0, "max": 200, "step": 8, "default": 96 }
  ],
  "presets": [{ "name": "LB Product Grid" }]
}
{% endschema %}
