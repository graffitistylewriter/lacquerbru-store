{% assign collection = collections[section.settings.collection] %}

<section class="lb-product-grid">
  <div class="lb-product-grid__header">
    {% if section.settings.eyebrow != blank %}
      <p class="lb-kicker">{{ section.settings.eyebrow }}</p>
    {% endif %}
    <h2>{{ section.settings.heading }}</h2>
    {% if section.settings.copy != blank %}
      <p>{{ section.settings.copy }}</p>
    {% endif %}
  </div>

  <div class="lb-product-grid__grid">
    {% if collection %}
      {% for product in collection.products limit: section.settings.limit %}
        <a class="lb-product-card" href="{{ product.url }}">
          {% if product.featured_image %}
            {{ product.featured_image | image_url: width: 800 | image_tag: class: 'lb-product-card__image', loading: 'lazy' }}
          {% endif %}
          <div class="lb-product-card__content">
            <h3>{{ product.title }}</h3>
            <p>{{ product.price | money }}</p>
          </div>
        </a>
      {% endfor %}
    {% else %}
      <p class="lb-empty-state">Select a collection in the section settings.</p>
    {% endif %}
  </div>
</section>

<style>
  .lb-product-grid__header { padding: 0 var(--lb-container-pad); margin-bottom: var(--lb-space-lg); }
  .lb-product-grid__header h2 { font-size: var(--lb-text-xl); font-weight: 900; text-transform: uppercase; letter-spacing: 0.03em; margin: var(--lb-space-xs) 0 var(--lb-space-sm); }
  .lb-product-grid__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--lb-space-md); padding: 0 var(--lb-container-pad); }
  .lb-product-card { display: block; text-decoration: none; color: var(--lb-white); position: relative; overflow: hidden; background: var(--lb-ink); aspect-ratio: 4/3; }
  .lb-product-card__image { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.5s ease; }
  .lb-product-card:hover .lb-product-card__image { transform: scale(1.04); }
  .lb-product-card__content { position: absolute; bottom: 0; left: 0; right: 0; padding: var(--lb-space-md); background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, transparent 100%); }
  .lb-product-card h3 { font-size: var(--lb-text-sm); font-weight: 700; text-transform: uppercase; margin: 0 0 4px; }
  .lb-product-card p { font-size: var(--lb-text-sm); color: var(--lb-blue); margin: 0; }
  @media (max-width: 860px) {
    .lb-product-grid__header { padding: 0 var(--lb-container-pad); }
    .lb-product-grid__grid { grid-template-columns: 1fr; padding: 0 var(--lb-container-pad); }
  }
</style>

{% schema %}
{
  "name": "LB Product Grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Featured Products" },
    { "type": "textarea", "id": "copy", "label": "Intro Copy" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "limit", "label": "Products To Show", "min": 3, "max": 12, "step": 1, "default": 6 }
  ],
  "presets": [{ "name": "LB Product Grid" }]
}
{% endschema %}
