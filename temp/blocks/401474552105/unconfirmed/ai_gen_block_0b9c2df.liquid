{% doc %}
  @prompt
    In the Payment methods block (ai_gen_block_96b5033), completely remove the PayFast payment method option. This means removing the "Show PayFast" toggle/checkbox from the block schema settings, removing the PayFast logo from the block's rendered output, and removing any associated PayFast variables or conditionals from the code. The remaining payment methods (PayPal, Visa, Mastercard, American Express) and all social icon functionality must remain completely intact and unchanged.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-payment-methods-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-payment-methods-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.spacing }}px;
  }

  .ai-payment-methods-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.spacing }}px 0;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-payment-methods-icons-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.icon_spacing }}px;
    justify-content: {{ block.settings.icon_alignment }};
    align-items: center;
  }

  .ai-payment-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: auto;
    opacity: {{ block.settings.icon_opacity }};
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .ai-payment-icon-{{ ai_gen_id }}:hover {
    opacity: 1;
    transform: scale(1.05);
  }

  .ai-social-icons-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.social_icon_spacing }}px;
    justify-content: {{ block.settings.social_icon_alignment }};
    align-items: center;
    margin-top: {{ block.settings.spacing }}px;
  }

  .ai-social-icon-link-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    width: {{ block.settings.social_icon_size }}px;
    height: {{ block.settings.social_icon_size }}px;
    background-color: {{ block.settings.social_icon_bg_color }};
    border-radius: {{ block.settings.social_icon_border_radius }}px;
    transition: background-color 0.3s ease, transform 0.3s ease;
  }

  .ai-social-icon-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.social_icon_hover_bg_color }};
    transform: scale(1.1);
  }

  .ai-social-icon-{{ ai_gen_id }} {
    width: calc({{ block.settings.social_icon_size }}px * 0.5);
    height: calc({{ block.settings.social_icon_size }}px * 0.5);
    fill: {{ block.settings.social_icon_color }};
  }

  .ai-social-icon-link-{{ ai_gen_id }}:hover .ai-social-icon-{{ ai_gen_id }} {
    fill: {{ block.settings.social_icon_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-payment-methods-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-payment-icon-{{ ai_gen_id }} {
      width: calc({{ block.settings.icon_size }}px * 0.8);
    }

    .ai-social-icon-link-{{ ai_gen_id }} {
      width: calc({{ block.settings.social_icon_size }}px * 0.9);
      height: calc({{ block.settings.social_icon_size }}px * 0.9);
    }
  }
{% endstyle %}

