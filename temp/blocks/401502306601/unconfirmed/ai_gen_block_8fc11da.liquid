{% doc %}
  @prompt
    In the LB Hero block section (section id: lb-header), add a transparent overlay band that sits above the hero image but beneath the Heading Text and Heading Italic Text elements. The overlay requirements are:
    
    1. It must be a semi-transparent color band/strip that sits directly behind the heading texts, floating above the hero image.
    2. It must have the following Shopify theme editor settings panel controls:
       - A color picker for the overlay background color (defaulting to black or dark)
       - An opacity/transparency slider (range 0–100%, defaulting to ~65–70% transparent, i.e. opacity around 0.30–0.35)
       - A height/thickness control so the user can choose between a narrow band, medium band, or thick band overlay
       - A toggle/checkbox to show or hide the overlay entirely
    3. The overlay must respond to the store's light/dark theme mode toggle — in light mode use a light/white semi-transparent overlay, in dark mode use a dark/black semi-transparent overlay using CSS variables tied to the theme's color scheme.
    4. The overlay should be positioned absolutely over the hero image, centered vertically behind the heading text block, and span the full width of the hero section.
    5. Ensure the heading texts remain above the overlay (higher z-index than the overlay).
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .lb-hero-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    height: {{ block.settings.hero_height }}vh;
    overflow: hidden;
    display: block;
  }

  .lb-hero-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .lb-hero-overlay-band-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    transform: translateY(-50%);
    z-index: 2;
    transition: opacity 0.3s ease, background-color 0.3s ease;
  }

  .lb-hero-overlay-band-{{ ai_gen_id }}--narrow {
    height: 80px;
  }

  .lb-hero-overlay-band-{{ ai_gen_id }}--medium {
    height: 150px;
  }

  .lb-hero-overlay-band-{{ ai_gen_id }}--thick {
    height: 250px;
  }

  .lb-hero-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    padding: 20px;
    text-align: center;
  }

  .lb-hero-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    font-weight: {{ block.settings.heading_weight }};
    line-height: 1.2;
  }

  .lb-hero-heading-italic-{{ ai_gen_id }} {
    font-size: {{ block.settings.italic_size }}px;
    color: {{ block.settings.italic_color }};
    font-style: italic;
    margin: 0;
    font-weight: {{ block.settings.italic_weight }};
    line-height: 1.3;
  }

  @media screen and (max-width: 749px) {
    .lb-hero-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_height }}vh;
    }

    .lb-hero-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.6);
    }

    .lb-hero-heading-italic-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.italic_size }}px * 0.6);
    }

    .lb-hero-overlay-band-{{ ai_gen_id }}--narrow {
      height: 60px;
    }

    .lb-hero-overlay-band-{{ ai_gen_id }}--medium {
      height: 100px;
    }

    .lb-hero-overlay-band-{{ ai_gen_id }}--thick {
      height: 180px;
    }
  }
{% endstyle %}

<div class="lb-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.hero_image %}
    <img
      src="{{ block.settings.hero_image | image_url: width: 2000 }}"
      alt="{{ block.settings.hero_image.alt | escape }}"
      loading="lazy"
      width="{{ block.settings.hero_image.width }}"
      height="{{ block.settings.hero_image.height }}"
      class="lb-hero-image-{{ ai_gen_id }}"
    >
  {% else %}
    <div class="lb-hero-image-{{ ai_gen_id }}" style="background-color: #111111;">
      {{ 'hero-apparel-1' | placeholder_svg_tag }}
    </div>
  {% endif %}

  {% if block.settings.show_overlay %}
    <div 
      class="lb-hero-overlay-band-{{ ai_gen_id }} lb-hero-overlay-band-{{ ai_gen_id }}--{{ block.settings.overlay_height }}"
      style="
        background-color: {{ block.settings.overlay_color }};
        opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
      "
    ></div>
  {% endif %}

  <div class="lb-hero-content-{{ ai_gen_id }}">
    {% if block.settings.heading_text != blank %}
      <h1 class="lb-hero-heading-{{ ai_gen_id }}">
        {{ block.settings.heading_text }}
      </h1>
    {% endif %}

    {% if block.settings.heading_italic_text != blank %}
      <h2 class="lb-hero-heading-italic-{{ ai_gen_id }}">
        {{ block.settings.heading_italic_text }}
      </h2>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "LB Hero",
  "tag": null,
  "class": "lb-header",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "range",
      "id": "hero_height",
      "label": "Desktop height",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 70
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile height",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 50
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Overlay band"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show overlay band",
      "default": true
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 35
    },
    {
      "type": "select",
      "id": "overlay_height",
      "label": "Overlay height",
      "options": [
        {
          "value": "narrow",
          "label": "Narrow"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "thick",
          "label": "Thick"
        }
      ],
      "default": "medium"
    },
    {
      "type": "header",
      "content": "Heading text"
    },
    {
      "type": "text",
      "id": "heading_text",
      "label": "Heading text",
      "default": "Welcome to Lacquer Bru"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#f0ede6"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 20,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 64
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading weight",
      "options": [
        {
          "value": "300",
          "label": "Light"
        },
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        },
        {
          "value": "800",
          "label": "Extra bold"
        }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Spacing below heading",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Italic text"
    },
    {
      "type": "text",
      "id": "heading_italic_text",
      "label": "Italic text",
      "default": "Premium Graffiti Supplies"
    },
    {
      "type": "color",
      "id": "italic_color",
      "label": "Italic text color",
      "default": "#f0ede6"
    },
    {
      "type": "range",
      "id": "italic_size",
      "label": "Italic text size",
      "min": 16,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "select",
      "id": "italic_weight",
      "label": "Italic text weight",
      "options": [
        {
          "value": "300",
          "label": "Light"
        },
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "400"
    }
  ],
  "presets": [
    {
      "name": "LB Hero"
    }
  ]
